 한 번 더 실행돼야 한다” → ",[15,1567,1568],{},"trailing","을 고려\n옵션은 UX 요구사항(즉시성 vs 확정 시점)에 맞춰 결정하는 게 안전합니다.",[41,1571],{},[44,1573,1575],{"id":1574},"요약35줄","요약(3~5줄)",[52,1577,1578,1585,1596,1603],{},[55,1579,1580,1581,1584],{},"이벤트 자체를 줄이기 어렵다면, ",[24,1582,1583],{},"함수 실행 타이밍을 제어","하는 게 정답이다.",[55,1586,1587,1589,1590,1592,1593,1595],{},[15,1588,77],{},"는 “초기화 1회”, ",[15,1591,81],{},"는 “멈춘 뒤 1회”, ",[15,1594,84],{},"은 “간격마다 1회”다.",[55,1597,1598,1599,1602],{},"Next.js에서는 브라우저 API를 쓰는 코드가 ",[24,1600,1601],{},"Client Component 경계"," 안에 있어야 한다.",[55,1604,1605,1606,1609,1610,1613],{},"래퍼 함수는 ",[24,1607,1608],{},"참조를 고정(useMemo/useRef)"," 하고, 언마운트 시 ",[24,1611,1612],{},"cancel/리스너 정리","를 습관화한다.",[41,1615],{},[44,1617,1618],{"id":1618},"결론",[20,1620,1621,1622,1625],{},"함수 실행 제어는 “미세 최적화”가 아니라 ",[24,1623,1624],{},"UX 안정화 전략","입니다.",[20,1627,1628],{},"한 번만, 멈춘 뒤 한 번만, 일정 간격으로만. 이 세 가지 규칙만 잘 적용해도 스크롤·입력·리사이즈에서 발생하는 대부분의 호출 폭주는 정리됩니다.",[41,1630],{},[44,1632,1634],{"id":1633},"참고공식-문서-링크","참고(공식 문서 링크)",[52,1636,1637,1646,1663,1676,1687,1698,1710,1721],{},[55,1638,1639],{},[1640,1641,1645],"a",{"href":1642,"rel":1643},"https://lodash.com/docs",[1644],"nofollow","Lodash Docs",[55,1647,1648,1653,1659],{},[1640,1649,1652],{"href":1650,"rel":1651},"https://nextjs.org/docs/app/api-reference/directives/use-client",[1644],"Next.js: ",[1640,1654,1656],{"href":1650,"rel":1655},[1644],[15,1657,1658],{},"use client",[1640,1660,1662],{"href":1650,"rel":1661},[1644]," Directive",[55,1664,1665,1670],{},[1640,1666,1669],{"href":1667,"rel":1668},"https://react.dev/reference/react/useEffect",[1644],"React: ",[1640,1671,1673],{"href":1667,"rel":1672},[1644],[15,1674,1675],{},"useEffect",[55,1677,1678,1682],{},[1640,1679,1669],{"href":1680,"rel":1681},"https://react.dev/reference/react/useDeferredValue",[1644],[1640,1683,1685],{"href":1680,"rel":1684},[1644],[15,1686,295],{},[55,1688,1689,1693],{},[1640,1690,1669],{"href":1691,"rel":1692},"https://react.dev/reference/react/startTransition",[1644],[1640,1