232,"code":233,"language":234,"meta":194,"style":194},"language-typescript shiki shiki-themes github-dark","// app/download-zip/downloadBlob.ts\nexport function downloadBlob(blob: Blob, filename: string) {\n  const url = URL.createObjectURL(blob);\n\n  const a = document.createElement(\"a\");\n  a.href = url;\n  a.download = filename;\n\n  // 일부 환경에서 DOM에 붙어 있어야 안정적으로 동작하는 케이스를 줄이기 위해 append\n  document.body.appendChild(a);\n  a.click();\n  a.remove();\n\n  // 너무 빨리 revoke 하면 다운로드가 끊기는 환경이 있어, 다음 tick에 해제\n  setTimeout(() => URL.revokeObjectURL(url), 0);\n}\n","typescript",[41,236,237,243,284,308,315,339,351,362,367,373,385,397,407,412,418,445],{"__ignoreMap":194},[198,238,239],{"class":200,"line":201},[198,240,242],{"class":241},"sAwPA","// app/download-zip/downloadBlob.ts\n",[198,244,246,250,253,256,260,264,267,270,272,275,277,281],{"class":200,"line":245},2,[198,247,249],{"class":248},"snl16","export",[198,251,252],{"class":248}," function",[198,254,255],{"class":204}," downloadBlob",[198,257,259],{"class":258},"s95oV","(",[198,261,263],{"class":262},"s9osk","blob",[198,265,266],{"class":248},":",[198,268,269],{"class":204}," Blob",[198,271,135],{"class":258},[198,273,274],{"class":262},"filename",[198,276,266],{"class":248},[198,278,280],{"class":279},"sDLfK"," string",[198,282,283],{"class":258},") {\n",[198,285,287,290,293,296,299,302,305],{"class":200,"line":286},3,[198,288,289],{"class":248},"  const",[198,291,292],{"class":279}," url",[198,294,295],{"class":248}," =",[198,297,298],{"class":279}," URL",[198,300,301],{"class":258},".",[198,303,304],{"class":204},"createObjectURL",[198,306,307],{"class":258},"(blob);\n",[198,309,311],{"class":200,"line":310},4,[198,312,314],{"emptyLinePlaceholder":313},true,"\n",[198,316,318,320,323,325,328,331,333,336],{"class":200,"line":317},5,[198,319,289],{"class":248},[198,321,322],{"class":279}," a",[198,324,295],{"class":248},[198,326,327],{"class":258}," document.",[198,329,330],{"class":204},"createElement",[198,332,