[{"data":1,"prerenderedAt":2116},["ShallowReactive",2],{"writing:meta:/writing/mutation-observer":3},{"id":4,"title":5,"body":6,"date":2103,"description":2104,"extension":2105,"meta":2106,"navigation":163,"notionPageId":2107,"path":2108,"seo":2109,"source":2110,"stem":2111,"tags":2112,"__hash__":2115},"content/writing/mutation-observer.md","MutationObserver로 DOM 변경 감지",{"type":7,"value":8,"toc":2077},"minimark",[9,14,27,34,41,44,49,66,72,74,78,87,107,114,117,201,204,206,210,215,218,221,229,232,235,239,245,248,252,272,274,278,286,549,552,554,558,1849,1866,1868,1872,1918,1920,1924,1928,1942,1946,1949,1961,1965,1968,1979,1983,1990,1992,1996,2015,2017,2020,2023,2028,2030,2034,2073],[10,11,13],"h1",{"id":12},"몰래-바뀌면-바로-알자-mutationobserver로-dom-변경-감지","몰래 바뀌면 바로 알자: MutationObserver로 DOM 변경 감지",[15,16,17,21,22,26],"p",{},[18,19,20],"strong",{},"한 문장 결론:"," 내가 직접 건드리지 않은 DOM 변경이 문제를 만든다면, ",[23,24,25],"code",{},"MutationObserver","로 “변경 지점”을 로그로 잡아내면 해결 속도가 빨라진다.",[15,28,29,30,33],{},"UI는 “원래 이렇게 생겼는데?”라는 순간부터 디버깅이 어렵습니다. 특히 ",[18,31,32],{},"서드파티 위젯/DOM 조작 라이브러리","가 섞이면, React/Next.js가 모르는 사이에 DOM이 바뀌는 상황이 생깁니다.",[15,35,36,37,40],{},"이때 중요한 건 “누가 바꿨는지”를 추측하는 게 아니라, ",[18,38,39],{},"무엇이/어디서/언제 바뀌었는지","를 증거로 남기는 겁니다.",[42,43],"hr",{},[45,46,48],"h2",{"id":47},"배경문제","배경/문제",[50,51,52,56,59],"ul",{},[53,54,55],"li",{},"내가 관리하지 않는 코드(서드파티, 레거시 위젯)가 DOM을 바꾸면, 변경 원인을 추적하기가 급격히 어려워집니다.",[53,57,58],{},"React/Next.js 환경에서는 DOM을 직접 조작하는 코드가 렌더링 흐름과 충돌할 수 있어, “가끔 깨지는” 형태로 나타나기도 합니다.",[53,60,61,62,65],{},"함수마다 로그를 심는 방식은 ",[18,63,64],{},"코드를 오염","시키고, 변경 주체가 여러 곳이면 빠르게 관리 불가능해집니다.",[15,67,68,69,71],{},"정리하면, “변경 감지” 자체가 요구 사항인 순간이 있고, 그때 ",[23,70,25],{},"는 꽤 실용적인 도구가 됩니다.",[42,73],{},[45,75,77],{"id":76},"핵심-개념","핵심 개념",[15,79,80,82,83,86],{},[23,81,25],{},"는 특정 DOM 노드(또는 그 하위 트리)의 변경을 감지해 ",[18,84,85],{},"콜백을 호출","합니다. 감지 대상은 크게 3가지로 정리됩니다.",[50,88,89,95,101],{},[53,90,91,94],{},[23,92,93],{},"childList",": 자식 노드 추가/삭제",[53,96,97,100],{},[23,98,99],{},"attributes",": 속성(attribute) 변경",[53,102,103,106],{},[23,104,105],{},"characterData",": 텍스트 노드 변경",[15,108,109,110,113],{},"또, ",[23,111,112],{},"subtree","를 켜면 해당 노드 아래의 모든 하위 노드까지 감시 범위를 확장할 수 있습니다.",[15,115,116],{},"아래 다이어그램을 보면 흐름이 단순합니다. “관측 시작 → DOM 변경 발생 → 기록(records) 전달 → 처리(로그/동기화)”.",[118,119,124],"pre",{"className":120,"code":121,"language":122,"meta":123,"style":123},"language-mermaid shiki shiki-themes github-dark","sequenceDiagram\n  participant C as Client Component\n  participant O as MutationObserver\n  participant D as Observed DOM\n  participant L as writeLog()\n\n  C->>O: new MutationObserver(callback)\n  C->>O: observe(target, options)\n  Note over D: 서드파티 위젯이 DOM 변경\n  D-->>O: mutations 발생\n  O-->>C: callback(records)\n  C->>L: records를 로그/처리\n","mermaid","",[23,125,126,134,140,146,152,158,165,171,177,183,189,195],{"__ignoreMap":123},[127,128,131],"span",{"class":129,"line":130},"line",1,[127,132,133],{},"sequenceDiagram\n",[127,135,137],{"class":129,"line":136},2,[127,138,139],{},"  participant C as Client Component\n",[127,141,143],{"class":129,"line":142},3,[127,144,145],{},"  participant O as MutationObserver\n",[127,147,149],{"class":129,"line":148},4,[127,150,151],{},"  participant D as Observed DOM\n",[127,153,155],{"class":129,"line":154},5,[127,156,157],{},"  participant L as writeLog()\n",[127,159,161],{"class":129,"line":160},6,[127,162,164],{"emptyLinePlaceholder":163},true,"\n",[127,166,168],{"class":129,"line":167},7,[127,169,170],{},"  C->>O: new MutationObserver(callback)\n",[127,172,174],{"class":129,"line":173},8,[127,175,176],{},"  C->>O: observe(target, options)\n",[127,178,180],{"class":129,"line":179},9,[127,181,182],{},"  Note over D: 서드파티 위젯이 DOM 변경\n",[127,184,186],{"class":129,"line":185},10,[127,187,188],{},"  D-->>O: mutations 발생\n",[127,190,192],{"class":129,"line":191},11,[127,193,194],{},"  O-->>C: callback(records)\n",[127,196,198],{"class":129,"line":197},12,[127,199,200],{},"  C->>L: records를 로그/처리\n",[15,202,203],{},"→ 기대 결과/무엇이 달라졌는지: “누가 바꿨는지” 추측 대신, 실제로 바뀐 기록(records)을 기준으로 원인 추적이 가능해집니다.",[42,205],{},[45,207,209],{"id":208},"해결-접근","해결 접근",[211,212,214],"h3",{"id":213},"_1-관측-범위를-최소화한다","1) 관측 범위를 최소화한다",[15,216,217],{},"왜 하냐면, 넓게 잡을수록 기록이 늘고 콜백 비용이 커집니다.",[15,219,220],{},"기대 결과는 “노이즈 감소 + 성능 안정”입니다.",[211,222,224,225,228],{"id":223},"_2-속성-감지는-attributefilter로-좁힌다","2) 속성 감지는 ",[23,226,227],{},"attributeFilter","로 좁힌다",[15,230,231],{},"왜 하냐면, 모든 속성 변경을 받으면 로그가 의미 없이 커집니다.",[15,233,234],{},"기대 결과는 “원하는 변경만 남긴 로그”입니다.",[211,236,238],{"id":237},"_3-nextjs에서는-client-component에서만-연결한다","3) Next.js에서는 Client Component에서만 연결한다",[15,240,241,242,244],{},"왜 하냐면, ",[23,243,25],{},"는 브라우저 DOM API라서 서버 렌더링 문맥에서는 동작하지 않습니다.",[15,246,247],{},"기대 결과는 “실행 위치가 명확한, 재현 가능한 코드”입니다.",[211,249,251],{"id":250},"대안비교-최소-2개","대안/비교 (최소 2개)",[50,253,254,260,266],{},[53,255,256,259],{},[18,257,258],{},"대안 A: 폴링(Polling)으로 DOM 상태를 주기적으로 비교","\n단순하지만 불필요한 비교가 계속 발생할 수 있습니다.",[53,261,262,265],{},[18,263,264],{},"대안 B: 변경이 발생하는 함수에 직접 로그 삽입(래핑/계측)","\n변경 주체가 명확할 땐 좋지만, 서드파티/간접 변경에는 취약합니다.",[53,267,268,271],{},[18,269,270],{},"대안 C: 가능하다면 “이벤트 기반”으로 전환(CustomEvent/콜백 제공)","\n라이브러리가 공식 이벤트를 제공한다면 그쪽이 더 명시적이고 비용이 예측 가능합니다.",[42,273],{},[45,275,277],{"id":276},"구현코드","구현(코드)",[211,279,281,282,285],{"id":280},"_1-usemutationobserver-훅-연결해제-책임을-고정하기","1) ",[23,283,284],{},"useMutationObserver"," 훅: 연결/해제 책임을 고정하기",[118,287,291],{"className":288,"code":289,"language":290,"meta":123,"style":123},"language-javascript shiki shiki-themes github-dark","'use client'\n\nimport { useEffect, useRef } from 'react'\n\nexport function useMutationObserver(targetRef, callback, options) {\n  const callbackRef = useRef(callback)\n  callbackRef.current = callback\n\n  useEffect(() => {\n    const target = targetRef.current\n    if (!target) return\n\n    const observer = new MutationObserver((records) => {\n      callbackRef.current(records)\n    })\n\n    observer.observe(target, options)\n\n    return () => {\n      observer.disconnect()\n    }\n  }, [targetRef, options])\n}\n","javascript",[23,292,293,299,303,319,323,356,374,385,389,403,416,433,437,466,478,484,489,501,506,519,531,537,543],{"__ignoreMap":123},[127,294,295],{"class":129,"line":130},[127,296,298],{"class":297},"sU2Wk","'use client'\n",[127,300,301],{"class":129,"line":136},[127,302,164],{"emptyLinePlaceholder":163},[127,304,305,309,313,316],{"class":129,"line":142},[127,306,308],{"class":307},"snl16","import",[127,310,312],{"class":311},"s95oV"," { useEffect, useRef } ",[127,314,315],{"class":307},"from",[127,317,318],{"class":297}," 'react'\n",[127,320,321],{"class":129,"line":148},[127,322,164],{"emptyLinePlaceholder":163},[127,324,325,328,331,335,338,342,345,348,350,353],{"class":129,"line":154},[127,326,327],{"class":307},"export",[127,329,330],{"class":307}," function",[127,332,334],{"class":333},"svObZ"," useMutationObserver",[127,336,337],{"class":311},"(",[127,339,341],{"class":340},"s9osk","targetRef",[127,343,344],{"class":311},", ",[127,346,347],{"class":340},"callback",[127,349,344],{"class":311},[127,351,352],{"class":340},"options",[127,354,355],{"class":311},") {\n",[127,357,358,361,365,368,371],{"class":129,"line":160},[127,359,360],{"class":307},"  const",[127,362,364],{"class":363},"sDLfK"," callbackRef",[127,366,367],{"class":307}," =",[127,369,370],{"class":333}," useRef",[127,372,373],{"class":311},"(callback)\n",[127,375,376,379,382],{"class":129,"line":167},[127,377,378],{"class":311},"  callbackRef.current ",[127,380,381],{"class":307},"=",[127,383,384],{"class":311}," callback\n",[127,386,387],{"class":129,"line":173},[127,388,164],{"emptyLinePlaceholder":163},[127,390,391,394,397,400],{"class":129,"line":179},[127,392,393],{"class":333},"  useEffect",[127,395,396],{"class":311},"(() ",[127,398,399],{"class":307},"=>",[127,401,402],{"class":311}," {\n",[127,404,405,408,411,413],{"class":129,"line":185},[127,406,407],{"class":307},"    const",[127,409,410],{"class":363}," target",[127,412,367],{"class":307},[127,414,415],{"class":311}," targetRef.current\n",[127,417,418,421,424,427,430],{"class":129,"line":191},[127,419,420],{"class":307},"    if",[127,422,423],{"class":311}," (",[127,425,426],{"class":307},"!",[127,428,429],{"class":311},"target) ",[127,431,432],{"class":307},"return\n",[127,434,435],{"class":129,"line":197},[127,436,164],{"emptyLinePlaceholder":163},[127,438,440,442,445,447,450,453,456,459,462,464],{"class":129,"line":439},13,[127,441,407],{"class":307},[127,443,444],{"class":363}," observer",[127,446,367],{"class":307},[127,448,449],{"class":307}," new",[127,451,452],{"class":333}," MutationObserver",[127,454,455],{"class":311},"((",[127,457,458],{"class":340},"records",[127,460,461],{"class":311},") ",[127,463,399],{"class":307},[127,465,402],{"class":311},[127,467,469,472,475],{"class":129,"line":468},14,[127,470,471],{"class":311},"      callbackRef.",[127,473,474],{"class":333},"current",[127,476,477],{"class":311},"(records)\n",[127,479,481],{"class":129,"line":480},15,[127,482,483],{"class":311},"    })\n",[127,485,487],{"class":129,"line":486},16,[127,488,164],{"emptyLinePlaceholder":163},[127,490,492,495,498],{"class":129,"line":491},17,[127,493,494],{"class":311},"    observer.",[127,496,497],{"class":333},"observe",[127,499,500],{"class":311},"(target, options)\n",[127,502,504],{"class":129,"line":503},18,[127,505,164],{"emptyLinePlaceholder":163},[127,507,509,512,515,517],{"class":129,"line":508},19,[127,510,511],{"class":307},"    return",[127,513,514],{"class":311}," () ",[127,516,399],{"class":307},[127,518,402],{"class":311},[127,520,522,525,528],{"class":129,"line":521},20,[127,523,524],{"class":311},"      observer.",[127,526,527],{"class":333},"disconnect",[127,529,530],{"class":311},"()\n",[127,532,534],{"class":129,"line":533},21,[127,535,536],{"class":311},"    }\n",[127,538,540],{"class":129,"line":539},22,[127,541,542],{"class":311},"  }, [targetRef, options])\n",[127,544,546],{"class":129,"line":545},23,[127,547,548],{"class":311},"}\n",[15,550,551],{},"→ 기대 결과/무엇이 달라졌는지: 관측 시작/종료가 컴포넌트 생명주기와 함께 움직여 “끊지 못한 observer”가 남는 문제를 줄입니다.",[42,553],{},[211,555,557],{"id":556},"_2-데모-함수에-로그를-심지-않고-변경-기록만으로-추적하기","2) 데모: 함수에 로그를 심지 않고, 변경 기록만으로 추적하기",[118,559,561],{"className":288,"code":560,"language":290,"meta":123,"style":123},"'use client'\n\nimport { useMemo, useRef, useState } from 'react'\nimport { useMutationObserver } from './useMutationObserver'\n\nfunction writeLog(records, setLogs) {\n  const lines = records.map((r) => {\n    if (r.type === 'attributes') {\n      return `attributes:${r.attributeName}`\n    }\n    if (r.type === 'childList') {\n      return `childList: +${r.addedNodes.length} -${r.removedNodes.length}`\n    }\n    if (r.type === 'characterData') {\n      return `characterData`\n    }\n    return `unknown:${r.type}`\n  })\n\n  setLogs((prev) => [...lines, ...prev].slice(0, 20))\n}\n\nexport default function MutationObserverDemo() {\n  const boxRef = useRef(null)\n  const [logs, setLogs] = useState([])\n\n  const options = useMemo(\n    () => ({\n      subtree: true,\n      childList: true,\n      attributes: true,\n      attributeFilter: ['class', 'style'],\n    }),\n    []\n  )\n\n  useMutationObserver(\n    boxRef,\n    (records) => writeLog(records, setLogs),\n    options\n  )\n\n  const appendChild = () => {\n    const box = boxRef.current\n    if (!box) return\n    const el = document.createElement('div')\n    el.textContent = `item-${Math.random().toString(16).slice(2, 6)}`\n    el.style.padding = '6px'\n    el.style.border = '1px solid #ddd'\n    el.style.borderRadius = '8px'\n    box.appendChild(el)\n  }\n\n  const setColor = () => {\n    const box = boxRef.current\n    if (!box) return\n    box.style.background = box.style.background ? '' : 'rgba(0,0,0,0.04)'\n  }\n\n  const toggleClass = () => {\n    const box = boxRef.current\n    if (!box) return\n    box.classList.toggle('active')\n  }\n\n  return (\n    \u003Cdiv style={{ display: 'grid', gap: 12, maxWidth: 720 }}>\n      \u003Cdiv style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>\n        \u003Cbutton onClick={appendChild}>appendChild()\u003C/button>\n        \u003Cbutton onClick={setColor}>setColor()\u003C/button>\n        \u003Cbutton onClick={toggleClass}>toggleClass()\u003C/button>\n      \u003C/div>\n\n      \u003Cdiv\n        ref={boxRef}\n        style={{\n          minHeight: 120,\n          padding: 12,\n          border: '2px dashed #bbb',\n          borderRadius: 12,\n        }}\n      >\n        \u003Cdiv style={{ opacity: 0.7 }}>여기가 관측 대상입니다.\u003C/div>\n      \u003C/div>\n\n      \u003Cdiv\n        style={{\n          padding: 12,\n          border: '1px solid #eee',\n          borderRadius: 12,\n          background: 'rgba(0,0,0,0.02)',\n        }}\n      >\n        \u003Cdiv style={{ fontWeight: 700, marginBottom: 8 }}>Logs\u003C/div>\n        \u003Cul style={{ margin: 0, paddingLeft: 18 }}>\n          {logs.map((l, i) => (\n            \u003Cli key={`${l}-${i}`}>{l}\u003C/li>\n          ))}\n        \u003C/ul>\n      \u003C/div>\n    \u003C/div>\n  )\n}\n",[23,562,563,567,571,582,594,598,617,643,658,677,681,694,729,733,746,753,757,773,778,782,826,830,834,849,869,894,899,915,926,938,948,958,975,981,987,993,998,1006,1012,1029,1035,1040,1045,1061,1074,1088,1111,1161,1172,1183,1194,1206,1212,1217,1233,1244,1257,1280,1285,1290,1306,1317,1330,1346,1351,1356,1365,1401,1431,1453,1471,1489,1499,1504,1512,1523,1534,1545,1555,1566,1576,1582,1588,1612,1621,1626,1633,1642,1651,1661,1670,1681,1686,1691,1720,1744,1768,1804,1810,1820,1829,1839,1844],{"__ignoreMap":123},[127,564,565],{"class":129,"line":130},[127,566,298],{"class":297},[127,568,569],{"class":129,"line":136},[127,570,164],{"emptyLinePlaceholder":163},[127,572,573,575,578,580],{"class":129,"line":142},[127,574,308],{"class":307},[127,576,577],{"class":311}," { useMemo, useRef, useState } ",[127,579,315],{"class":307},[127,581,318],{"class":297},[127,583,584,586,589,591],{"class":129,"line":148},[127,585,308],{