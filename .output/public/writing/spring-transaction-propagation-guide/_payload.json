[{"data":1,"prerenderedAt":1026},["ShallowReactive",2],{"writing:meta:/writing/spring-transaction-propagation-guide":3},{"id":4,"title":5,"body":6,"date":1015,"description":1016,"extension":1017,"meta":1018,"navigation":807,"notionPageId":1019,"path":1020,"seo":1021,"source":1022,"stem":1023,"tags":1024,"__hash__":1025},"content/writing/spring-transaction-propagation-guide.md","트랜잭션 경계를 설계하라: 스프링 전파(Propagation) 옵션을 안전하게 쓰는 법",{"type":7,"value":8,"toc":985},"minimark",[9,13,35,40,47,72,79,83,88,99,102,114,118,165,168,171,175,182,208,212,379,381,385,388,392,441,452,454,458,495,505,510,525,527,531,568,571,573,577,614,617,619,623,660,663,665,669,711,718,723,733,741,743,747,784,787,789,793,796,845,847,851,855,862,870,877,880,887,896,911,913,917,939,942,945,958,960,964,981],[10,11,5],"h1",{"id":12},"트랜잭션-경계를-설계하라-스프링-전파propagation-옵션을-안전하게-쓰는-법",[14,15,16,17,21,22,26,27,30,31],"p",{},"트랜잭션 전파(Transaction Propagation)는 ",[18,19,20],"strong",{},"이미 트랜잭션이 진행 중일 때(또는 없을 때)"," ",[23,24,25],"code",{},"@Transactional","이 붙은 메서드가 ",[18,28,29],{},"어떤 경계로 실행될지","를 결정합니다. 핵심은 간단합니다. ",[32,33,34],"em",{},"“지금 이 작업은 기존 트랜잭션에 묶여야 하나, 아니면 분리돼야 하나?”",[36,37,39],"h2",{"id":38},"배경문제","배경/문제",[14,41,42,43,46],{},"서비스 메서드가 여러 레이어(서비스 → 저장소, 또는 서비스 → 다른 서비스)를 호출하는 구조에서는 한 요청 안에서 트랜잭션이 ",[18,44,45],{},"중첩 호출","되는 일이 흔합니다.",[48,49,50,58,65],"ul",{},[51,52,53,54,57],"li",{},"같은 트랜잭션에 묶이면: 실패 시 ",[18,55,56],{},"한 번에 롤백","되어 일관성이 쉽습니다.",[51,59,60,61,64],{},"분리하면: 일부 작업(예: 감사 로그, 알림 기록)은 ",[18,62,63],{},"비즈니스 실패와 무관하게 남길 수"," 있습니다.",[51,66,67,68,71],{},"반대로 잘못 분리하면: 잠금/격리/플러시 타이밍 때문에 ",[18,69,70],{},"성능 저하나 교착","이 생길 수 있습니다.",[14,73,74,75,78],{},"포인트는 “전파 옵션은 기능이 아니라 ",[18,76,77],{},"경계 설계 도구","”라는 점입니다.",[36,80,82],{"id":81},"핵심-개념","핵심 개념",[84,85,87],"h3",{"id":86},"물리-트랜잭션과-논리-트랜잭션을-구분하기","“물리 트랜잭션”과 “논리 트랜잭션”을 구분하기",[14,89,90,91,94,95,98],{},"스프링은 전파 옵션을 통해 메서드 호출들이 ",[18,92,93],{},"같은 물리 트랜잭션(같은 DB 트랜잭션)"," 을 공유할지, 별도의 트랜잭션을 만들지 제어합니다. 기본값인 ",[23,96,97],{},"REQUIRED","는 보통 “논리적으로는 여러 메서드가 각각 트랜잭션처럼 보이지만, 실제로는 하나의 물리 트랜잭션”으로 동작합니다.",[14,100,101],{},"(공식 문서가 이 차이를 강조합니다.)",[48,103,104],{},[51,105,106,107],{},"참고: ",[108,109,113],"a",{"href":110,"rel":111},"https://docs.spring.io/spring-framework/reference/data-access/transaction/declarative/tx-propagation.html",[112],"nofollow","Spring Transaction Propagation",[84,115,117],{"id":116},"전파-옵션-흐름을-한-번에-잡는-다이어그램","전파 옵션 흐름을 한 번에 잡는 다이어그램",[119,120,125],"pre",{"className":121,"code":122,"language":123,"meta":124,"style":124},"language-mermaid shiki shiki-themes github-dark","flowchart TD\n  A[\"메서드 진입\u003Cbr/>@Transactional\"] --> B{\"기존 트랜잭션 존재?\"}\n  B -->|\"예\"| C[\"전파 옵션 규칙 적용\"]\n  B -->|\"아니오\"| D[\"전파 옵션 규칙 적용\"]\n  C --> E[\"기존 TX 참여/중단/예외/중첩/신규 생성\"]\n  D --> F[\"신규 생성/비TX 실행/예외\"]\n","mermaid","",[23,126,127,135,141,147,153,159],{"__ignoreMap":124},[128,129,132],"span",{"class":130,"line":131},"line",1,[128,133,134],{},"flowchart TD\n",[128,136,138],{"class":130,"line":137},2,[128,139,140],{},"  A[\"메서드 진입\u003Cbr/>@Transactional\"] --> B{\"기존 트랜잭션 존재?\"}\n",[128,142,144],{"class":130,"line":143},3,[128,145,146],{},"  B -->|\"예\"| C[\"전파 옵션 규칙 적용\"]\n",[128,148,150],{"class":130,"line":149},4,[128,151,152],{},"  B -->|\"아니오\"| D[\"전파 옵션 규칙 적용\"]\n",[128,154,156],{"class":130,"line":155},5,[128,157,158],{},"  C --> E[\"기존 TX 참여/중단/예외/중첩/신규 생성\"]\n",[128,160,162],{"class":130,"line":161},6,[128,163,164],{},"  D --> F[\"신규 생성/비TX 실행/예외\"]\n",[14,166,167],{},"→ 기대 결과/무엇이 달라졌는지: 호출 시점에 “있던 트랜잭션을 쓸지/끊을지/막을지”를 전파 옵션이 결정한다는 그림이 고정됩니다.",[169,170],"hr",{},[36,172,174],{"id":173},"해결-접근","해결 접근",[14,176,177,178,181],{},"아래의 전파 옵션 7개를 ",[18,179,180],{},"“기존 트랜잭션이 있을 때 / 없을 때”"," 로 나눠 기억하면 헷갈림이 줄어듭니다.",[183,184,185,192],"blockquote",{},[14,186,187,188,191],{},"공식 정의(요약)는 ",[23,189,190],{},"Propagation"," 열거형 문서가 가장 정확합니다.",[48,193,194,201],{},[51,195,196],{},[108,197,200],{"href":198,"rel":199},"https://docs.spring.io/spring-framework/docs/current/javadoc-api/org/springframework/transaction/annotation/Propagation.html",[112],"Propagation Enum (Spring)",[51,202,203],{},[108,204,207],{"href":205,"rel":206},"https://docs.spring.io/spring-framework/docs/current/javadoc-api/org/springframework/transaction/annotation/Transactional.html",[112],"@Transactional (Spring)",[84,209,211],{"id":210},"전파-옵션-요약표","전파 옵션 요약표",[213,214,215,234],"table",{},[216,217,218],"thead",{},[219,220,221,225,228,231],"tr",{},[222,223,224],"th",{},"옵션",[222,226,227],{},"기존 TX가 있을 때",[222,229,230],{},"기존 TX가 없을 때",[222,232,233],{},"주로 쓰는 상황",[235,236,237,258,281,300,319,340,361],"tbody",{},[219,238,239,244,250,255],{},[240,241,242],"td",{},[23,243,97],{},[240,245,246,247],{},"기존 TX에 ",[18,248,249],{},"참여",[240,251,252],{},[18,253,254],{},"새 TX 생성",[240,256,257],{},"대부분의 서비스 로직 기본값",[219,259,260,265,274,278],{},[240,261,262],{},[23,263,264],{},"REQUIRES_NEW",[240,266,267,268,271,272],{},"기존 TX ",[18,269,270],{},"일시 중단(suspend)"," 후 ",[18,273,254],{},[240,275,276],{},[18,277,254],{},[240,279,280],{},"로깅/감사/아웃박스 기록 등 “반드시 남겨야 하는 작업”",[219,282,283,288,292,297],{},[240,284,285],{},[23,286,287],{},"MANDATORY",[240,289,246,290],{},[18,291,249],{},[240,293,294],{},[18,295,296],{},"예외 발생",[240,298,299],{},"“반드시 상위에서 TX를 시작해야 한다”를 강제",[219,301,302,307,311,316],{},[240,303,304],{},[23,305,306],{},"SUPPORTS",[240,308,246,309],{},[18,310,249],{},[240,312,313],{},[18,314,315],{},"비TX로 실행",[240,317,318],{},"읽기 전용/선택적 트랜잭션(일관성 요구가 낮을 때)",[219,320,321,326,333,337],{},[240,322,323],{},[23,324,325],{},"NOT_SUPPORTED",[240,327,267,328,271,331],{},[18,329,330],{},"일시 중단",[18,332,315],{},[240,334,335],{},[18,336,315],{},[240,338,339],{},"TX로 묶고 싶지 않은 호출(외부 API, 긴 작업 등)",[219,341,342,347,353,358],{},[240,343,344],{},[23,345,346],{},"NESTED",[240,348,349,352],{},[18,350,351],{},"세이브포인트(SAVEPOINT)"," 기반 중첩",[240,354,355],{},[18,356,357],{},"새 TX 생성(=REQUIRED처럼)",[240,359,360],{},"부분 롤백이 필요할 때(지원 조건 중요)",[219,362,363,368,372,376],{},[240,364,365],{},[23,366,367],{},"NEVER",[240,369,370],{},[18,371,296],{},[240,373,374],{},[18,375,315],{},[240,377,378],{},"“트랜잭션 안에서 실행되면 안 된다”를 강제",[169,380],{},[36,382,384],{"id":383},"구현코드","구현(코드)",[14,386,387],{},"아래 예시는 “주문 생성” 흐름에서 전파 옵션 차이를 보여줍니다.",[84,389,391],{"id":390},"_1-required-있으면-참여-없으면-생성","1) REQUIRED: 있으면 참여, 없으면 생성",[119,393,397],{"className":394,"code":395,"language":396,"meta":124,"style":124},"language-java shiki shiki-themes github-dark","@Service\npublic class OrderService {\n  @Transactional // propagation = REQUIRED (기본값)\n  public void placeOrder() {\n    orderRepository.save(...);\n    paymentService.capture(); // 기본적으로 같은 TX에 참여\n  }\n}\n","java",[23,398,399,404,409,414,419,424,429,435],{"__ignoreMap":124},[128,400,401],{"class":130,"line":131},[128,402,403],{},"@Service\n",[128,405,406],{"class":130,"line":137},[128,407,408],{},"public class OrderService {\n",[128,410,411],{"class":130,"line":143},[128,412,413],{},"  @Transactional // propagation = REQUIRED (기본값)\n",[128,415,416],{"class":130,"line":149},[128,417,418],{},"  public void placeOrder() {\n",[128,420,421],{"class":130,"line":155},[128,422,423],{},"    orderRepository.save(...);\n",[128,425,426],{"class":130,"line":161},[128,427,428],{},"    paymentService.capture(); // 기본적으로 같은 TX에 참여\n",[128,430,432],{"class":130,"line":431},7,[128,433,434],{},"  }\n",[128,436,438],{"class":130,"line":437},8,[128,439,440],{},"}\n",[14,442,443,444,447,448,451],{},"→ 기대 결과/무엇이 달라졌는지: ",[23,445,446],{},"placeOrder()","가 시작한 트랜잭션(또는 상위 트랜잭션)에 ",[23,449,450],{},"paymentService.capture()","가 묶입니다. 내부에서 예외가 나면 보통 전체가 같은 경계로 롤백됩니다.",[169,453],{},[84,455,457],{"id":456},"_2-requires_new-기존-tx를-잠시-멈추고-새-tx로-분리","2) REQUIRES_NEW: 기존 TX를 잠시 멈추고 새 TX로 분리",[119,459,461],{"className":394,"code":460,"language":396,"meta":124,"style":124},"@Service\npublic class AuditService {\n  @Transactional(propagation = Propagation.REQUIRES_NEW)\n  public void writeAuditLog(AuditLog log) {\n    auditLogRepository.save(log);\n  }\n}\n",[23,462,463,467,472,477,482,487,491],{"__ignoreMap":124},[128,464,465],{"class":130,"line":131},[128,466,403],{},[128,468,469],{"class":130,"line":137},[128,470,471],{},"public class AuditService {\n",[128,473,474],{"class":130,"line":143},[128,475,476],{},"  @Transactional(propagation = Propagation.REQUIRES_NEW)\n",[128,478,479],{"class":130,"line":149},[128,480,481],{},"  public void writeAuditLog(AuditLog log) {\n",[128,483,484],{"class":130,"line":155},[128,485,486],{},"    auditLogRepository.save(log);\n",[128,488,489],{"class":130,"line":161},[128,490,434],{},[128,492,493],{"class":130,"line":431},[128,494,440],{},[14,496,497,498,501,502,504],{},"→ 기대 결과/무엇이 달라졌는지: 상위 트랜잭션이 실패해도 ",[23,499,500],{},"writeAuditLog()","는 별도의 트랜잭션으로 커밋될 수 있습니다(반대로 ",[23,503,500],{}," 실패가 상위에 영향을 주는 방식은 예외 처리에 따라 달라질 수 있습니다).",[14,506,507],{},[18,508,509],{},"주의 포인트(실무에서 자주 터지는 지점)",[48,511,512,515,518],{},[51,513,514],{},"상위 TX가 잡고 있는 락(잠금)과 분리된 TX가 같은 리소스를 건드리면 교착/지연이 발생할 수 있습니다.",[51,516,517],{},"JPA를 쓰는 경우, 플러시/영속성 컨텍스트 경계가 “생각보다” 복잡해질 수 있습니다.",[51,519,520,521,524],{},"전파 옵션을 바꿔도 ",[18,522,523],{},"프록시 기반 호출 규칙(자기 자신 메서드 호출은 적용되지 않는 경우 등)"," 에 영향을 받습니다.",[169,526],{},[84,528,530],{"id":529},"_3-mandatory-트랜잭션이-반드시-있어야-함","3) MANDATORY: 트랜잭션이 “반드시” 있어야 함",[119,532,534],{"className":394,"code":533,"language":396,"meta":124,"style":124},"@Service\npublic class InventoryService {\n  @Transactional(propagation = Propagation.MANDATORY)\n  public void decreaseStock(...) {\n    inventoryRepository.update(...);\n  }\n}\n",[23,535,536,540,545,550,555,560,564],{"__ignoreMap":124},[128,537,538],{"class":130,"line":131},[128,539,403],{},[128,541,542],{"class":130,"line":137},[128,543,544],{},"public class InventoryService {\n",[128,546,547],{"class":130,"line":143},[128,548,549],{},"  @Transactional(propagation = Propagation.MANDATORY)\n",[128,551,552],{"class":130,"line":149},[128,553,554],{},"  public void decreaseStock(...) {\n",[128,556,557],{"class":130,"line":155},[128,558,559],{},"    inventoryRepository.update(...);\n",[128,561,562],{"class":130,"line":161},[128,563,434],{},[128,565,566],{"class":130,"line":431},[128,567,440],{},[14,569,570],{},"→ 기대 결과/무엇이 달라졌는지: 호출자가 트랜잭션을 시작하지 않았다면 즉시 예외가 발생합니다. “재고 감소는 반드시 트랜잭션 안에서만” 같은 규칙을 코드로 강제할 때 유용합니다.",[169,572],{},[84,574,576],{"id":575},"_4-supports-있으면-참여-없으면-그냥-실행","4) SUPPORTS: 있으면 참여, 없으면 그냥 실행",[119,578,580],{"className":394,"code":579,"language":396,"meta":124,"style":124},"@Service\npublic class CatalogService {\n  @Transactional(propagation = Propagation.SUPPORTS, readOnly = true)\n  public Product findProduct(...) {\n    return productRepository.findById(...);\n  }\n}\n",[23,581,582,586,591,596,601,606,610],{"__ignoreMap":124},[128,583,584],{"class":130,"line":131},[128,585,403],{},[128,587,588],{"class":130,"line":137},[128,589,590],{},"public class CatalogService {\n",[128,592,593],{"class":130,"line":143},[128,594,595],{},"  @Transactional(propagation = Propagation.SUPPORTS, readOnly = true)\n",[128,597,598],{"class":130,"line":149},[128,599,600],{},"  public Product findProduct(...) {\n",[128,602,603],{"class":130,"line":155},[128,604,605],{},"    return productRepository.findById(...);\n",[128,607,608],{"class":130,"line":161},[128,609,434],{},[128,611,612],{"class":130,"line":431},[128,613,440],{},[14,615,616],{},"→ 기대 결과/무엇이 달라졌는지: 상위가 트랜잭션이면 그 안에서 읽고, 아니면 트랜잭션 없이 읽습니다. 조회 로직을 광범위하게 재사용할 때 부담이 줄 수 있습니다.",[169,618],{},[84,620,622],{"id":621},"_5-not_supported-트랜잭션을-끊고중단하고-비tx로-실행","5) NOT_SUPPORTED: 트랜잭션을 끊고(중단하고) 비TX로 실행",[119,624,626],{"className":394,"code":625,"language":396,"meta":124,"style":124},"@Service\npublic class ExternalApiService {\n  @Transactional(propagation = Propagation.NOT_SUPPORTED)\n  public ApiResult callExternal(...) {\n    return httpClient.call(...);\n  }\n}\n",[23,627,628,632,637,642,647,652,656],{"__ignoreMap":124},[128,629,630],{"class":130,"line":131},[128,631,403],{},[128,633,634],{"class":130,"line":137},[128,635,636],{},"public class ExternalApiService {\n",[128,638,639],{"class":130,"line":143},[128,640,641],{},"  @Transactional(propagation = Propagation.NOT_SUPPORTED)\n",[128,643,644],{"class":130,"line":149},[128,645,646],{},"  public ApiResult callExternal(...) {\n",[128,648,649],{"class":130,"line":155},[128,650,651],{},"    return httpClient.call(...);\n",[128,653,654],{"class":130,"line":161},[128,655,434],{},[128,657,658],{"class":130,"line":431},[128,659,440],{},[14,661,662],{},"→ 기대 결과/무엇이 달라졌는지: 상위 트랜잭션이 있어도 외부 API 호출은 트랜잭션 밖에서 수행됩니다. 긴 네트워크 호출로 DB 트랜잭션을 오래 붙잡지 않게 할 때 사용합니다.",[169,664],{},[84,666,668],{"id":667},"_6-nested-세이브포인트-기반-부분-롤백-경계","6) NESTED: 세이브포인트 기반 “부분 롤백” 경계",[119,670,672],{"className":394,"code":671,"language":396,"meta":124,"style":124},"@Service\npublic class CouponService {\n  @Transactional(propagation = Propagation.NESTED)\n  public void applyCoupon(...) {\n    couponRepository.use(...);\n    // 여기서 실패하면 이 블록만 롤백(가능한 환경에서)\n  }\n}\n",[23,673,674,678,683,688,693,698,703,707],{"__ignoreMap":124},[128,675,676],{"class":130,"line":131},[128,677,403],{},[128,679,680],{"class":130,"line":137},[128,681,682],{},"public class CouponService {\n",[128,684,685],{"class":130,"line":143},[128,686,687],{},"  @Transactional(propagation = Propagation.NESTED)\n",[128,689,690],{"class":130,"line":149},[128,691,692],{},"  public void applyCoupon(...) {\n",[128,694,695],{"class":130,"line":155},[128,696,697],{},"    couponRepository.use(...);\n",[128,699,700],{"class":130,"line":161},[128,701,702],{},"    // 여기서 실패하면 이 블록만 롤백(가능한 환경에서)\n",[128,704,705],{"class":130,"line":431},[128,706,434],{},[128,708,709],{"class":130,"line":437},[128,710,440],{},[14,712,713,714,717],{},"→ 기대 결과/무엇이 달라졌는지: 상위 트랜잭션이 있을 때 ",[23,715,716],{},"SAVEPOINT","를 만들어 두고, 내부 실패 시 “상위 전체 롤백”이 아니라 “세이브포인트까지 롤백”이 가능해집니다.",[14,719,720],{},[18,721,722],{},"중요: NESTED는 트랜잭션 매니저/환경에 따라 동작이 달라질 수 있습니다.",[14,724,725,726,728,729,732],{},"공식 문서/자바독은 ",[23,727,346],{},"가 ",[18,730,731],{},"특정 트랜잭션 매니저에서만"," 세이브포인트 기반으로 동작한다고 명시합니다.",[48,734,735],{},[51,736,106,737],{},[108,738,740],{"href":198,"rel":739},[112],"Propagation.NESTED javadoc",[169,742],{},[84,744,746],{"id":745},"_7-never-트랜잭션이-있으면-실패-없으면-비tx로-실행","7) NEVER: 트랜잭션이 있으면 실패, 없으면 비TX로 실행",[119,748,750],{"className":394,"code":749,"language":396,"meta":124,"style":124},"@Service\npublic class NonTransactionalJobService {\n  @Transactional(propagation = Propagation.NEVER)\n  public void runJob(...) {\n    // 트랜잭션 안에서 실행되면 안 되는 작업\n  }\n}\n",[23,751,752,756,761,766,771,776,780],{"__ignoreMap":124},[128,753,754],{"class":130,"line":131},[128,755,403],{},[128,757,758],{"class":130,"line":137},[128,759,760],{},"public class NonTransactionalJobService {\n",[128,762,763],{"class":130,"line":143},[128,764,765],{},"  @Transactional(propagation = Propagation.NEVER)\n",[128,767,768],{"class":130,"line":149},[128,769,770],{},"  public void runJob(...) {\n",[128,772,773],{"class":130,"line":155},[128,774,775],{},"    // 트랜잭션 안에서 실행되면 안 되는 작업\n",[128,777,778],{"class":130,"line":161},[128,779,434],{},[128,781,782],{"class":130,"line":431},[128,783,440],{},[14,785,786],{},"→ 기대 결과/무엇이 달라졌는지: 누군가 실수로 트랜잭션 안에서 호출하면 즉시 예외로 막습니다. “절대 트랜잭션에 묶이면 안 되는 작업”을 보호하는 안전장치입니다.",[169,788],{},[36,790,792],{"id":791},"검증-방법체크리스트","검증 방법(체크리스트)",[14,794,795],{},"전파 옵션을 적용했다면, 아래를 테스트로 “증명”하는 게 안전합니다.",[48,797,800,810,816,828,836],{"className":798},[799],"contains-task-list",[51,801,804,809],{"className":802},[803],"task-list-item",[805,806],"input",{"disabled":807,"type":808},true,"checkbox"," 상위 트랜잭션이 롤백될 때, 하위 메서드 결과가 어떻게 되는지(커밋/롤백/예외) 확인",[51,811,813,815],{"className":812},[803],[805,814],{"disabled":807,"type":808}," 하위 메서드에서 예외가 발생할 때, 상위 트랜잭션에 미치는 영향 확인",[51,817,819,821,822,824,825,827],{"className":818},[803],[805,820],{"disabled":807,"type":808}," ",[23,823,264],{},"/",[23,826,325],{}," 사용 시, 데이터 정합성(중간 상태 노출 가능성) 확인",[51,829,831,821,833,835],{"className":830},[803],[805,832],{"disabled":807,"type":808},[23,834,346],{}," 사용 시, 실제로 세이브포인트가 생성/롤백되는지(환경별 차이) 확인",[51,837,839,841,842,844],{"className":838},[803],[805,840],{"disabled":807,"type":808}," 프록시 기반 AOP 적용 범위(호출 방식/가시성)에 의해 ",[23,843,25],{},"이 무시되는 경로가 없는지 확인",[169,846],{},[36,848,850],{"id":849},"흔한-실수faq","흔한 실수/FAQ",[84,852,854],{"id":853},"q1-내부-메서드에-transactional을-붙였는데-전파가-안-먹는-것-같아요","Q1. “내부 메서드에 @Transactional을 붙였는데 전파가 안 먹는 것 같아요.”",[14,856,857,858,861],{},"스프링의 선언적 트랜잭션은 보통 ",[18,859,860],{},"프록시 기반","으로 동작합니다. 같은 클래스 내부에서 자기 자신 메서드를 직접 호출하면 프록시를 거치지 않아 적용이 달라질 수 있습니다.",[48,863,864],{},[51,865,106,866],{},[108,867,869],{"href":205,"rel":868},[112],"@Transactional javadoc",[84,871,873,874,876],{"id":872},"q2requires_new면-내부-실패가-외부에-절대-영향-없다가-맞나요","Q2. ",[23,875,264],{},"면 “내부 실패가 외부에 절대 영향 없다”가 맞나요?",[14,878,879],{},"항상 그렇지는 않습니다. 내부에서 던진 예외를 외부에서 어떻게 처리하느냐(전파/재던짐/캐치)에 따라 외부 트랜잭션이 롤백 마킹되는 흐름이 달라질 수 있습니다. 또한 락/리소스 경합 관점에서는 외부에 영향을 줄 수도 있습니다.",[84,881,883,884,886],{"id":882},"q3nested는-왜-환경에-따라-실패하나요","Q3. ",[23,885,346],{},"는 왜 환경에 따라 실패하나요?",[14,888,889,891,892,895],{},[23,890,346],{},"는 ",[18,893,894],{},"세이브포인트 지원","이 필요한데, 트랜잭션 매니저/드라이버/JPA 설정에 따라 지원 범위가 달라질 수 있습니다. 자바독은 기본적으로 JDBC 기반 매니저에서 주로 동작한다고 설명합니다.",[48,897,898,903],{},[51,899,106,900],{},[108,901,740],{"href":198,"rel":902},[112],[51,904,905,906],{},"참고(사례): ",[108,907,910],{"href":908,"rel":909},"https://techblog.woowahan.com/2606/",[112],"우아한형제들 기술블로그 - NESTED 동작 실패 사례",[169,912],{},[36,914,916],{"id":915},"요약35줄","요약(3~5줄)",[48,918,919,922,927,934],{},[51,920,921],{},"전파 옵션은 “트랜잭션 경계를 어떻게 나눌지”를 결정하는 설계 도구입니다.",[51,923,924,926],{},[23,925,97],{},"는 기본값으로 대부분의 서비스 로직에 적합합니다.",[51,928,929,824,931,933],{},[23,930,264],{},[23,932,325],{},"는 기존 트랜잭션을 중단시키므로 락/정합성/성능 영향을 반드시 고려해야 합니다.",[51,935,936,938],{},[23,937,346],{},"는 세이브포인트 기반이며 환경(트랜잭션 매니저)에 따라 동작이 달라질 수 있습니다.",[36,940,941],{"id":941},"결론",[14,943,944],{},"전파 옵션을 외우는 것보다 중요한 건 “이 작업은 어떤 경계로 커밋/롤백되어야 안전한가”를 먼저 결정하는 것입니다.",[14,946,947,948,950,951,824,953,824,955,957],{},"기본은 ",[23,949,97],{},"로 두고, 정말 필요한 경우에만 ",[23,952,264],{},[23,954,325],{},[23,956,346],{},"로 경계를 조정하면 트러블 슈팅 비용이 크게 줄어듭니다.",[169,959],{},[36,961,963],{"id":962},"참고공식-문서-링크","참고(공식 문서 링크)",[48,965,966,971,976],{},[51,967,968],{},[108,969,113],{"href":110,"rel":970},[112],[51,972,973],{},[108,974,200],{"href":198,"rel":975},[112],[51,977,978],{},[108,979,207],{"href":205,"rel":980},[112],[982,983,984],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":124,"searchDepth":137,"depth":137,"links":986},[987,988,992,995,1004,1005,1012,1013,1014],{"id":38,"depth":137,"text":39},{"id":81,"depth":137,"text":82,"children":989},[990,991],{"id":86,"depth":143,"text":87},{"id":116,"depth":143,"text":117},{"id":173,"depth":137,"text":174,"children":993},[994],{"id":210,"depth":143,"text":211},{"id":383,"depth":137,"text":384,"children":996},[997,998,999,1000,1001,1002,1003],{"id":390,"depth":143,"text":391},{"id":456,"depth":143,"text":457},{"id":529,"depth":143,"text":530},{"id":575,"depth":143,"text":576},{"id":621,"depth":143,"text":622},{"id":667,"depth":143,"text":668},{"id":745,"depth":143,"text":746},{"id":791,"depth":137,"text":792},{"id":849,"depth":137,"text":850,"children":1006},[1007,1008,1010],{"id":853,"depth":143,"text":854},{"id":872,"depth":143,"text":1009},"Q2. REQUIRES_NEW면 “내부 실패가 외부에 절대 영향 없다”가 맞나요?",{"id":882,"depth":143,"text":1011},"Q3. NESTED는 왜 환경에 따라 실패하나요?",{"id":915,"depth":137,"text":916},{"id":941,"depth":137,"text":941},{"id":962,"depth":137,"text":963},"2026-02-10","트랜잭션 전파(Transaction Propagation)는 이미 트랜잭션이 진행 중일 때 @Transactional이 붙은 메서드가 어떤 경계로 실행될지를 결정합니다. REQUIRED는 기본값으로 대부분의 서비스 로직에 적합하며, REQUIRES_NEW/NOT_SUPPORTED는 기존 트랜잭션을 중단시키므로 락/정합성/성능 영향을 반드시 고려해야 합니다. NESTED는 세이브포인트 기반이며 환경에 따라 동작이 달라질 수 있습니다.","md",{},"303c01ed-7f98-8026-81a0-c1ad4385e5d4","/writing/spring-transaction-propagation-guide",{"title":5,"description":1016},"notion","writing/spring-transaction-propagation-guide",[396],"lOl5OLLZAm1nvg_rAOfPL7iOiXqJgIkKyv6WxWstFoA",1772810801359]