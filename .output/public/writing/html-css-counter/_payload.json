},"카운터를 증가",[72,114,115,118,119,122,123,125],{},[40,116,117],{},"counter()",": 카운터 값을 ",[18,120,121],{},"문자열로 꺼내기"," (보통 ",[40,124,42],{},"에서 사용)",[15,127,128],{},"아래 다이어그램을 보면 흐름이 딱 고정된다.",[130,131,136],"pre",{"className":132,"code":133,"language":134,"meta":135,"style":135},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  Scope[\"컨테이너\u003Cbr/>counter-reset\"] -->|\"스코프 생성\"| Items[\"아이템들\u003Cbr/>counter-increment\"]\n  Items -->|\"상태별 증가\"| Checked[\"체크된 input\u003Cbr/>counter-increment\"]\n  Items -->|\"값 누적\"| Summary[\"요약 영역(::before)\u003Cbr/>content: counter()\"]\n  Checked -->|\"값 누적\"| Summary\n","mermaid","",[40,137,138,146,152,158,164],{"__ignoreMap":135},[139,140,143],"span",{"class":141,"line":142},"line",1,[139,144,145],{},"flowchart LR\n",[139,147,149],{"class":141,"line":148},2,[139,150,151],{},"  Scope[\"컨테이너\u003Cbr/>counter-reset\"] -->|\"스코프 생성\"| Items[\"아이템들\u003Cbr/>counter-increment\"]\n",[139,153,155],{"class":141,"line":154},3,[139,156,157],{},"  Items -->|\"상태별 증가\"| Checked[\"체크된 input\u003Cbr/>counter-increment\"]\n",[139,159,161],{"class":141,"line":160},4,[139,162,163],{},"  Items -->|\"값 누적\"| Summary[\"요약 영역(::before)\u003Cbr/>content: counter()\"]\n",[139,165,167],{"class":141,"line":166},5,[139,168,169],{},"  Checked -->|\"값 누적\"| Summary\n",[15,171,172],{},"→ 기대 결과/무엇이 달라졌는지: “어디서 초기화하고, 무엇이 증가시키며, 어디서 출력하는지”를 한 장으로 고정할 수 있다.",[48,174],{},[51,176,178],{"id":177},"해결-접근","해결 접근",[180,181,183],"h3",{"id":182},"접근-1-css-counter로-전체체크됨을-만든다","접근 1) CSS Counter로 “전체/체크됨”을 만든다",[15,185,186],{},"핵심은 두 가지다.",[188,189,190,196],"ol",{},[72,191,192,195],{},[18,193,194],{},"전체 카운트","는 각 아이템이 1번씩 증가시키고",[72,197,198,201,202,205,206,209],{},[18,199,200],{},"체크됨 카운트","는 ",[40,203,204],{},":checked"," 상태의 ",[40,207,208],{},"input","이 1번씩 증가시킨다.",[15,211,212],{},"그리고 중요한 제약이 하나 있다.",[69,214,215,222],{},[72,216,217,218,221],{},"Counter는 **소스 순서(문서 흐름)**를 따라 누적된다.\n그래서 “요약(카운트 출력)”은 ",[18,219,220],{},"증가가 끝난 뒤에 배치","해야 최종 값이 나온다."