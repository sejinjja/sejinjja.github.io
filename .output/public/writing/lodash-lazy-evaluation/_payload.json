,{},[58,109,111],{"id":110},"핵심-개념","핵심 개념",[113,114,116],"h3",{"id":115},"lodash-체이닝이-게으른-평가가-되는-순간","Lodash 체이닝이 “게으른 평가”가 되는 순간",[18,118,119,120,123,124,127,128,131,132,135,136,143],{},"Lodash 는 체이닝 구간에서 ",[35,121,122],{},"shortcut fusion","(이터레이터 합치기) 최적화를 제공한다. 이 최적화는 ",[35,125,126],{},"중간 배열 생성을 줄이고",", ",[30,129,130],{},"take"," 같은 “조기 종료”와 결합되면 ",[35,133,134],{},"필요한 만큼만 평가","할 수 있게 된다. (",[137,138,142],"a",{"href":139,"rel":140},"https://lodash.com/docs/",[141],"nofollow","lodash.com",")",[18,145,146,147,143],{},"또한 shortcut fusion이 적용되려면, 체이닝 구간이 배열에 적용되고 iteratee가 “한 개 인자만 받는 형태”여야 한다는 조건이 있다(휴리스틱은 바뀔 수 있음). (",[137,148,142],{"href":139,"rel":149},[141],[113,151,153],{"id":152},"한-장으로-보는-차이","한 장으로 보는 차이",[155,156,161],"pre",{"className":157,"code":158,"language":159,"meta":160,"style":160},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  subgraph E[\"Eager(단계별 즉시 실행)\"]\n    E1[\"map: 전체 100만건\"] --> E2[\"filter: 전체 재순회\"]\n    E2 --> E3[\"map: 전체 재순회\"]\n    E3 --> E4[\"filter: 전체 재순회\"]\n    E4 --> E5[\"take(2): 이미 늦음\"]\n  end\n\n  subgraph L[\"Lazy(체이닝 + 조기 종료)\"]\n    L1[\"item 1개\"] --> L2[\"map→filter→map→filter\"]\n    L2 -->|\"통과하면 누적\"| L3[\"take(2) 채우기\"]\n    L3 -->|\"2개 되면 즉시 종료\"| L4[\"stop\"]\n  end\n","mermaid","",[30,162,163,171,177,183,189,195,201,207,214,220,226,232,238],{"__ignoreMap":160},[164,165,168],"span",{"class":166,"line":167},"line",1,[164,169,170],{},"flowchart LR\n",[164,172,174],{"class":166,"line":173},2,[164,175,176],{},"  subgraph E[\"Eager(단계별 즉시 실행)\"]\n",[164,178,180],{"class":166,"line":179},3,[164,181,182],{},"    E1[\"map: 전체 100만건\"] --> E2[\"filter: 전체 재순회\"]\n",[164,184,186],{"class":166,"line":185},4,[164,187,188],{},"    E2 --> E3[\"map: 전체 재순회\"]\n",[164,190,192],{"class":166,"line":191},5,[164,193,194],{},"    E3 --> E4[\"filter: 전체 재순회\"]\n",[164,196,198],{"class":166,"line":197},6,[164,199,200],{},"    E4 --> E5[\"take(2): 이미 늦음\"]\n",[164,202,204],{"class":166,"line":203},7,[164,205,206