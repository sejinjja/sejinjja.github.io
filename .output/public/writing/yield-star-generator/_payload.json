,"이터러블/이터레이터 규약은 ",[1363,1364,1368],"a",{"href":1365,"rel":1366},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Iteration_protocols",[1367],"nofollow","MDN Iteration protocols","를 참고하세요.",[324,1371,1373],{"id":1372},"q3-nextjs에서-어디에-두면-좋나요","Q3. Next.js에서 어디에 두면 좋나요?",[20,1375,1376,1377,1380],{},"DOM 의존이 없는 순수 로직이라면 ",[15,1378,1379],{},"lib/"," 같은 공용 모듈에 두고 서버/클라이언트 어디서든 가져다 쓸 수 있습니다.",[20,1382,1383],{},"로그는 실행 위치에 따라 브라우저 콘솔/서버 로그로 나뉩니다.",[64,1385],{},[67,1387,1389],{"id":1388},"요약35줄","요약(3~5줄)",[280,1391,1392,1400,1409,1418],{},[283,1393,1394,1396,1397,348],{},[15,1395,25],{},"는 값을 ",[28,1398,1399],{},"덩어리째 1회",[283,1401,1402,1404,1405,1408],{},[15,1403,17],{},"는 이터러블을 ",[28,1406,1407],{},"펼쳐서 원소 단위","로 내보냅니다.",[283,1410,1411,1412,1414,1415,1417],{},"제너레이터를 ",[15,1413,25],{},"로 내보내면 객체가 나오므로, 값 스트림을 합치려면 ",[15,1416,17],{},"가 자연스럽습니다.",[283,1419,671,1420,1422,1423,1426],{},[15,1421,17],{}," 시 문자 단위로 펼쳐지니, 필요하면 ",[15,1424,1425],{},"yield \"문자열\"","로 단위를 고정하세요.",[64,1428],{},[67,1430,1431],{"id":1431},"결론",[20,1433,1434,1436],{},[15,1435,17],{},"의 역할은 “편리함”이 아니라 “의도 고정”입니다.",[20,1438,1439,1440],{},"이 글에서 다룬 문제는 결국 하나로 귀결됩니다: ",[28,1441,1442],{},"소비자가 기대하는 출력 단위를 생산자에서 확정하라.",[20,1444,1445],{},"그 한 줄이, 중첩 순회와 조건문을 지워줍니다.",[64,1447],{},[67,1449,1451],{"id":1450},"참고공식-문서-링크","참고(공식 문서 링크)",[280,1453,1454,1466,1473,1479,1486],{},[283,1455,1456,1462],{},[1363,1457,1460],{"href":1458,"rel":1459},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/yield*",[1367],[15,1461,17],{},[1363,1463,1465],{"href":1458,"rel":1464},[1367]," (MDN)",[283,1467,1468],{},[1363,1469,1472],{"href":1470,"rel":1471},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Generator",[1367],"Generators (MDN)",[283,1474,1475],{},[1363,1476,1478],{"href":1365,"rel":1477},[1367],"Iteration protocols (MDN)",[283,1480,1481],{},[1363,1482,1485],{"href":1483,"rel":1484},"https://nextjs.org/docs",[1367],"Next.js Docs",[283,1487,1488]