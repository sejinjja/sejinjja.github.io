sm-and-optimized-js?utm_source=chatgpt.com",[27],"tchayen.com",[14,95,96,97,100,101,29],{},"이 글에서는 ",[18,98,99],{},"Next.js에서 재현 가능한 형태로",", AssemblyScript(타입스크립트 문법 기반)로 간단한 WebAssembly 모듈을 만들고, **정확도(BigInt) + 측정(performance.now)**까지 한 번에 정리합니다. (",[23,102,85],{"href":103,"rel":104},"https://www.assemblyscript.org/getting-started.html",[27],[48,106],{},[51,108,110],{"id":109},"핵심-개념","핵심 개념",[14,112,113,114,117,118,121,122,29],{},"WebAssembly는 “브라우저에서 실행 가능한 바이너리 포맷”이고, 자바스크립트와 함께 동작합니다. 즉, ",[18,115,116],{},"UI/이벤트/DOM은 JS(React)가 맡고",", ",[18,119,120],{},"무거운 계산만 Wasm","에 맡기는 그림이 기본입니다. (",[23,123,28],{"href":25,"rel":124},[27],[126,127,132],"pre",{"className":128,"code":129,"language":130,"meta":131,"style":131},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  A[\"AssemblyScript\u003Cbr/>코드 작성\"] -->|\"컴파일\"| B[\".wasm 생성\u003Cbr/>(build/)\"]\n  B -->|\"정적 파일로 배포\"| C[\"Next.js public/\u003Cbr/>wasm 파일 제공\"]\n  C -->|\"fetch + instantiate\u003Cbr/>(Client Component)\"| D[\"Wasm exports 호출\"]\n  D -->|\"결과 표시\"| E[\"React UI 업데이트\"]\n","mermaid","",[73,133,134,142,148,154,160],{"__ignoreMap":131},[135,136,139],"span",{"class":137,"line":138},"line",1,[135,140,141],{},"flowchart LR\n",[135,143,145],{"class":137,"line":144},2,[135,146,147],{},"  A[\"AssemblyScript\u003Cbr/>코드 작성\"] -->|\"컴파일\"| B[\".wasm 생성\u003Cbr/>(build/)\"]\n",[135,149,151],{"class":137,"line":150},3,[135,152,153],{},"  B -->|\"정적 파일로 배포\"| C[\"Next.js public/\u003Cbr/>wasm 파일 제공\"]\n",[135,155,157],{"class":137,"line":156},4,[135,158,159],{},"  C -->|\"fetch + instantiate\u003Cbr/>(Client Component)\"| D[\"Wasm exports 호출\"]\n",[135,161,163],{"class":137,"line":162},5,[135,164,165],{},"  D -->|\"결과 표시\"| E[\"React UI 업데이트\"]\n",[14,167,168],{},"→ 기대 결과/무엇이 달라졌는지: “연산”이 UI 코드에서 분리됩니다. React는 화면만 책임지고, 계산은 Wasm 모듈 경계 안으로 들어갑니다.",[170,171,173,174,177],"h3",{"id":172},"왜-bigint가-중요할까","왜 ",[73,175,176],{},"BigInt","가 중요할까?",[14,179,180,181,183,184,187,188,190,191,29],{},"자바스크립트 