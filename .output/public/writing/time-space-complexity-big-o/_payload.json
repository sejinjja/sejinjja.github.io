[{"data":1,"prerenderedAt":1154},["ShallowReactive",2],{"writing:meta:/writing/time-space-complexity-big-o":3},{"id":4,"title":5,"body":6,"date":1143,"description":1144,"extension":1145,"meta":1146,"navigation":834,"notionPageId":1147,"path":1148,"seo":1149,"source":1150,"stem":1151,"tags":1152,"__hash__":1153},"content/writing/time-space-complexity-big-o.md","속도는 \"측정값\"이 아니라 \"증가율\"이다: 시간·공간 복잡도와 Big-O",{"type":7,"value":8,"toc":1118},"minimark",[9,14,22,25,40,43,48,51,64,67,81,83,87,92,112,119,173,176,178,182,188,220,222,226,229,270,272,276,283,287,391,394,396,400,481,494,496,500,609,615,617,621,714,717,719,723,791,801,803,807,921,924,926,930,975,977,981,985,995,999,1006,1010,1013,1015,1019,1048,1050,1053,1056,1063,1065,1069,1114],[10,11,13],"h1",{"id":12},"속도는-측정값이-아니라-증가율이다-시간공간-복잡도와-big-o","속도는 “측정값”이 아니라 “증가율”이다: 시간·공간 복잡도와 Big-O",[15,16,17,21],"p",{},[18,19,20],"strong",{},"한 문장 결론:"," 알고리즘 비교는 실행 시간 측정보다, 입력 크기에 따라 얼마나 빨리 커지는지(시간/공간 복잡도)를 먼저 고정하는 게 안정적입니다.",[15,23,24],{},"실무에서는 “더 빠른 코드”를 고르는 일이 자주 생깁니다. 그런데 실행 시간은 런타임 최적화(JIT), 서버 스펙, 트래픽 패턴, 캐시 상태에 따라 흔들립니다.",[15,26,27,28,31,32,35,36,39],{},"그래서 먼저 ",[18,29,30],{},"입력 크기(n)가 커질 때 비용이 어떻게 증가하는지","를 보는 게 좋습니다. 포인트는 단순합니다. ",[18,33,34],{},"시간 복잡도는 연산 증가율",", ",[18,37,38],{},"공간 복잡도는 메모리 증가율","입니다.",[41,42],"hr",{},[44,45,47],"h2",{"id":46},"배경문제","배경/문제",[15,49,50],{},"같은 문제를 푸는 알고리즘이 여러 개일 때, 단순히 “몇 ms 걸렸는지”만 비교하면 다음 문제가 생깁니다.",[52,53,54,58,61],"ul",{},[55,56,57],"li",{},"환경이 달라지면 결과가 뒤집힐 수 있다.",[55,59,60],{},"테스트 입력이 작으면 차이가 안 보인다.",[55,62,63],{},"캐시/GC/스케줄링 같은 변수 때문에 재현이 어렵다.",[15,65,66],{},"그래서 성능 의사결정은 보통 이렇게 갑니다.",[68,69,70,75],"ol",{},[55,71,72],{},[18,73,74],{},"복잡도 분석으로 증가율을 먼저 고정",[55,76,77,78],{},"그 다음 ",[18,79,80],{},"프로파일링/벤치마크로 상수항(현실 체감)을 확인",[41,82],{},[44,84,86],{"id":85},"핵심-개념","핵심 개념",[88,89,91],"h3",{"id":90},"시간-복잡도-vs-공간-복잡도","시간 복잡도 vs 공간 복잡도",[52,93,94,104],{},[55,95,96,99,100,103],{},[18,97,98],{},"시간 복잡도(Time Complexity)",": 입력 크기(n)에 따라 ",[18,101,102],{},"연산량이 얼마나 증가하는지","(성장률)",[55,105,106,99,109,103],{},[18,107,108],{},"공간 복잡도(Space Complexity)",[18,110,111],{},"추가로 필요한 메모리가 얼마나 증가하는지",[15,113,114,115,118],{},"여기서 “연산의 수를 정확히 센다”기보다는, ",[18,116,117],{},"불필요한 상세를 걷어내고 증가율만 남긴다","는 관점이 핵심입니다.",[120,121,126],"pre",{"className":122,"code":123,"language":124,"meta":125,"style":125},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  P[\"문제\u003Cbr/>요구사항\"] --> C[\"후보 알고리즘\u003Cbr/>여러 선택지\"]\n  C --> T[\"시간 복잡도\u003Cbr/>연산 증가율\"]\n  C --> S[\"공간 복잡도\u003Cbr/>메모리 증가율\"]\n  T --> D[\"선택/트레이드오프\u003Cbr/>캐시·정확도·지연\"]\n  S --> D\n  D --> V[\"검증\u003Cbr/>프로파일링/벤치\"]\n","mermaid","",[127,128,129,137,143,149,155,161,167],"code",{"__ignoreMap":125},[130,131,134],"span",{"class":132,"line":133},"line",1,[130,135,136],{},"flowchart LR\n",[130,138,140],{"class":132,"line":139},2,[130,141,142],{},"  P[\"문제\u003Cbr/>요구사항\"] --> C[\"후보 알고리즘\u003Cbr/>여러 선택지\"]\n",[130,144,146],{"class":132,"line":145},3,[130,147,148],{},"  C --> T[\"시간 복잡도\u003Cbr/>연산 증가율\"]\n",[130,150,152],{"class":132,"line":151},4,[130,153,154],{},"  C --> S[\"공간 복잡도\u003Cbr/>메모리 증가율\"]\n",[130,156,158],{"class":132,"line":157},5,[130,159,160],{},"  T --> D[\"선택/트레이드오프\u003Cbr/>캐시·정확도·지연\"]\n",[130,162,164],{"class":132,"line":163},6,[130,165,166],{},"  S --> D\n",[130,168,170],{"class":132,"line":169},7,[130,171,172],{},"  D --> V[\"검증\u003Cbr/>프로파일링/벤치\"]\n",[15,174,175],{},"→ 기대 결과/무엇이 달라졌는지: “감(측정값)”이 아니라 “증가율(복잡도)”로 먼저 방향을 잡고, 마지막에 실측으로 확인하는 흐름이 고정됩니다.",[41,177],{},[88,179,181],{"id":180},"big-o-표기법이-하는-일","Big-O 표기법이 하는 일",[15,183,184,187],{},[18,185,186],{},"Big-O(빅오) 표기법","은 복잡도를 표현하는 방식 중 하나로, **입력이 커질수록 지배적인 항(dominant term)**만 남겨 “대략 얼마나 커지는지”를 말합니다.",[52,189,190,200,208,214],{},[55,191,192,193,196,197],{},"상수항은 무시합니다. 예: ",[127,194,195],{},"O(n + 10)"," → ",[127,198,199],{},"O(n)",[55,201,202,203,196,206],{},"계수도 무시합니다. 예: ",[127,204,205],{},"O(5n)",[127,207,199],{},[55,209,210,211],{},"독립 입력이 있으면 더합니다. 예: ",[127,212,213],{},"O(n + m)",[55,215,216,217],{},"중첩 반복 등은 곱해집니다. 예: ",[127,218,219],{},"O(n^2)",[41,221],{},[44,223,225],{"id":224},"해결-접근","해결 접근",[15,227,228],{},"복잡도를 실무에 적용하는 방법은 간단합니다.",[68,230,231,244,257],{},[55,232,233,236],{},[18,234,235],{},"입력 크기(n)를 먼저 정의한다",[52,237,238,241],{},[55,239,240],{},"왜: “무엇이 커질 때 비용이 커지는지”가 고정돼야 비교가 됩니다.",[55,242,243],{},"기대 결과: 복잡도 표기가 의미 있는 기준이 됩니다.",[55,245,246,249],{},[18,247,248],{},"시간/공간을 함께 적는다",[52,250,251,254],{},[55,252,253],{},"왜: 캐시/메모이제이션은 시간을 줄이는 대신 공간을 더 씁니다.",[55,255,256],{},"기대 결과: “빠르지만 메모리 많이 씀” 같은 트레이드오프가 문서화됩니다.",[55,258,259,262],{},[18,260,261],{},"마지막에 벤치/프로파일링으로 체감 확인",[52,263,264,267],{},[55,265,266],{},"왜: Big-O가 같아도 상수항/데이터 분포에 따라 체감이 달라집니다.",[55,268,269],{},"기대 결과: 실제 환경에서의 병목이 드러납니다.",[41,271],{},[44,273,275],{"id":274},"구현코드","구현(코드)",[15,277,278,279,282],{},"아래 예시는 ",[18,280,281],{},"Big-O 감각을 빠르게 잡기 위한"," 자주 나오는 패턴입니다.",[88,284,286],{"id":285},"_1-한-번-도는-루프-on","1) 한 번 도는 루프: O(n)",[120,288,292],{"className":289,"code":290,"language":291,"meta":125,"style":125},"language-javascript shiki shiki-themes github-dark","function sum(arr) {\n  let total = 0;\n  for (let i = 0; i \u003C arr.length; i++) total += arr[i];\n  return total;\n}\n","javascript",[127,293,294,315,333,378,386],{"__ignoreMap":125},[130,295,296,300,304,308,312],{"class":132,"line":133},[130,297,299],{"class":298},"snl16","function",[130,301,303],{"class":302},"svObZ"," sum",[130,305,307],{"class":306},"s95oV","(",[130,309,311],{"class":310},"s9osk","arr",[130,313,314],{"class":306},") {\n",[130,316,317,320,323,326,330],{"class":132,"line":139},[130,318,319],{"class":298},"  let",[130,321,322],{"class":306}," total ",[130,324,325],{"class":298},"=",[130,327,329],{"class":328},"sDLfK"," 0",[130,331,332],{"class":306},";\n",[130,334,335,338,341,344,347,349,351,354,357,360,363,366,369,372,375],{"class":132,"line":145},[130,336,337],{"class":298},"  for",[130,339,340],{"class":306}," (",[130,342,343],{"class":298},"let",[130,345,346],{"class":306}," i ",[130,348,325],{"class":298},[130,350