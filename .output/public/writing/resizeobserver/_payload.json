onFrame(() => {\n        setSize((prev) =>\n          prev.width === next.width && prev.height === next.height ? prev : next\n        );\n      });\n    });\n\n    ro.observe(el); // 기본: content-box\n\n    return () => {\n      if (rafId != null) cancelAnimationFrame(rafId);\n      ro.disconnect();\n    };\n  }, []);\n\n  return { ref, size };\n}\n","typescript",[19,362,363,373,379,396,400,439,444,471,504,548,553,568,582,602,607,630,635,664,683,700,705,712,724,736,747,753,758,764,770,791,808,824,858,864,870,876,881,896,901,914,931,943,949,955,960,969],{"__ignoreMap":144},[148,364,365,369],{"class":150,"line":151},[148,366,368],{"class":367},"sU2Wk","\"use client\"",[148,370,372],{"class":371},"s95oV",";\n",[148,374,375],{"class":150,"line":157},[148,376,378],{"emptyLinePlaceholder":377},true,"\n",[148,380,381,385,388,391,394],{"class":150,"line":163},[148,382,384],{"class":383},"snl16","import",[148,386,387],{"class":371}," { useEffect, useRef, useState } ",[148,389,390],{"class":383},"from",[148,392,393],{"class":367}," \"react\"",[148,395,372],{"class":371},[148,397,398],{"class":150,"line":169},[148,399,378],{"emptyLinePlaceholder":377},[148,401,402,405,409,412,415,419,422,426,429,432,434,436],{"class":150,"line":175},[148,403,404],{"class":383},"type",[148,406,408],{"class":407},"svObZ"," Size",[148,410,411],{"class":383}," =",[148,413,414],{"class":371}," { ",[148,416,418],{"class":417},"s9osk","width",[148,420,421],{"class":383},":",[148,423,425],{"class":424},"sDLfK"," number",[148,427,428],{"class":371},"; ",[148,430,431],{"class":417},"height",[148,433,421],{"class":383},[148,435,425],{"class":424},[148,437,438],{"class":371}," };\n",[148,440,442],{"class":150,"line":441},6,[148,443,378],{"emptyLinePlaceholder":377},[148,445,447,450,453,456,459,462,465,468],{"class":150,"line":446},7,[148,448,449],{"class":383},"export",[148,451,452],{"class":383}," function",[148,454,455],{"class":407}," useResizeObserver",[148,457,458],{"class":371},"\u003C",[148,460,461]