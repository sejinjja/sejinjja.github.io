의 코드 실행","으로 이어질 수 있다. (",[45,108,50],{"href":47,"rel":109},[49],[79,111,112,113,115,116,51],{},"보안을 위해 CSP를 적용하면 ",[40,114,42],{},"이 차단될 수 있다. (",[45,117,50],{"href":47,"rel":118},[49],[65,120],{},[68,122,124],{"id":123},"핵심-개념","핵심 개념",[126,127,129],"h3",{"id":128},"_1-eval은-문자열을-코드로-실행한다","1) eval은 “문자열을 코드로 실행”한다",[131,132,137],"pre",{"className":133,"code":134,"language":135,"meta":136,"style":136},"language-javascript shiki shiki-themes github-dark","let value = eval('1 + 1')\nconsole.log(value) // 2\n\nlet x = 5\neval('x = 10')\nconsole.log(x) // 10\n\neval('let y = 10')\nconsole.log(y) // ReferenceError\n","javascript","",[40,138,139,147,153,160,166,172,178,183,189],{"__ignoreMap":136},[140,141,144],"span",{"class":142,"line":143},"line",1,[140,145,146],{},"let value = eval('1 + 1')\n",[140,148,150],{"class":142,"line":149},2,[140,151,152],{},"console.log(value) // 2\n",[140,154,156],{"class":142,"line":155},3,[140,157,159],{"emptyLinePlaceholder":158},true,"\n",[140,161,163],{"class":142,"line":162},4,[140,164,165],{},"let x = 5\n",[140,167,169],{"class":142,"line":168},5,[140,170,171],{},"eval('x = 10')\n",[140,173,175],{"class":142,"line":174},6,[140,176,177],{},"console.log(x) // 10\n",[140,179,181],{"class":142,"line":180},7,[140,182,159],{"emptyLinePlaceholder":158},[140,184,186],{"class":142,"line":185},8,[140,187,188],{},"eval('let y = 10')\n",[140,190,192],{"class":142,"line":191},9,[140,193,194],{},"console.log(y) // ReferenceError\n",[15,196,197,198,200],{},"→ 기대 결과/무엇이 달라졌는지: ",[40,199,42],{},"은 실행은 되지만, 스코프/선언 규칙이 직관적이지 않아 결과가 예상과 달라질 수 있다. (디버깅 난이도 상승)",[15,202,203,205,206,51],{},[40,204,42],{}," 자체가 “문자열을 파싱해서 실행”하는 구조라, 보안 관점에서 대표적인 위험 API로 분류된다. (",[45,207,50],{"href":47,"rel":208},[49],[65,210],{},[126,212,214],{"id":213},"_2-코드-전달을-명령-데이터-전달로-바꿔야-한다","2) “코드 전달”을 “명령 + 데이터 전달”로 바꿔야 한다",[15,216,217],{},"아래 다이어그램을 보면 차이가 빠르게 보인다.",[131,219,223],{"className":220,"code":221,"language":222,"meta":136,"style":136},"language-mermaid shiki shiki-t