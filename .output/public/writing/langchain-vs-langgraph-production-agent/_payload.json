[{"data":1,"prerenderedAt":1621},["ShallowReactive",2],{"writing:meta:/writing/langchain-vs-langgraph-production-agent":3},{"id":4,"title":5,"body":6,"date":1610,"description":21,"extension":1611,"meta":1612,"navigation":149,"notionPageId":1613,"path":1614,"seo":1615,"source":1616,"stem":1617,"tags":1618,"__hash__":1620},"content/writing/langchain-vs-langgraph-production-agent.md","LangChain vs LangGraph 에이전트 설계",{"type":7,"value":8,"toc":1585},"minimark",[9,14,22,25,38,53,56,61,66,74,81,84,186,193,195,199,203,255,262,266,274,285,287,291,303,311,827,840,848,1296,1311,1313,1317,1370,1372,1376,1380,1387,1391,1400,1404,1410,1414,1420,1422,1426,1464,1466,1469,1472,1477,1480,1483,1485,1489,1582],[10,11,13],"h1",{"id":12},"프로덕션을-막는-건-구조다-langchain-vs-langgraph-에이전트-설계","프로덕션을 막는 건 구조다: LangChain vs LangGraph 에이전트 설계",[15,16,17,18],"p",{},"한 문장 결론: ",[19,20,21],"strong",{},"“문자열로 유도하는 에이전트”는 금방 흔들리고, “도구 호출을 구조로 다루는 에이전트”는 운영 요구사항을 견딥니다.",[15,23,24],{},"에이전트가 프로덕션으로 못 가는 순간은 대부분 비슷합니다.",[26,27,28,32,35],"ul",{},[29,30,31],"li",{},"요청이 조금만 복잡해지면 프롬프트가 비대해지고, 형식이 무너집니다.",[29,33,34],{},"도구 호출이 한 번만 삐끗해도 파싱/재시도/에러 처리로 비용이 폭증합니다.",[29,36,37],{},"“지금 무슨 단계인지”가 코드에 드러나지 않아, 디버깅과 관측(Observability)이 난이도가 됩니다.",[15,39,40,41,44,45,52],{},"포인트는 “모델이 똑똑하냐”가 아니라 ",[19,42,43],{},"에이전트를 어떤 실행 구조로 감싸느냐","입니다. 그리고 그 구조 차이가 LangChain의 classic ReAct와 LangGraph(그래프 기반 런타임)에서 가장 선명하게 갈립니다. (",[46,47,51],"a",{"href":48,"rel":49},"https://reference.langchain.com/v0.3/python/langchain/agents/langchain.agents.react.agent.create_react_agent.html",[50],"nofollow","reference.langchain.com",")",[54,55],"hr",{},[57,58,60],"h2",{"id":59},"핵심-개념","핵심 개념",[62,63,65],"h3",{"id":64},"그래프-기반-런타임의-핵심-장점-상태와-도구-실행을-구조로-분리한다","그래프 기반 런타임의 핵심 장점: “상태와 도구 실행을 구조로 분리한다”",[15,67,68,69,52],{},"LangGraph는 에이전트 워크플로우를 그래프(노드/엣지)로 모델링하고, 상태(State)를 중심으로 실행 흐름을 제어합니다. (",[46,70,73],{"href":71,"rel":72},"https://docs.langchain.com/oss/python/langgraph/graph-api",[50],"docs.langchain.com",[15,75,76,77,52],{},"특히 ToolNode는 도구 실행(병렬 실행, 에러 처리, 상태 주입)을 런타임 구성 요소로 끌어올립니다. (",[46,78,73],{"href":79,"rel":80},"https://docs.langchain.com/oss/javascript/langchain/tools",[50],[15,82,83],{},"아래 다이어그램을 보면 “프로덕션에서 중요한 책임”이 어디에 놓이는지 바로 드러납니다.",[85,86,91],"pre",{"className":87,"code":88,"language":89,"meta":90,"style":90},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  subgraph LC[\"LangChain classic ReAct\u003Cbr/>문자열 유도 + 파싱\"]\n    A[\"Tools\u003Cbr/>문자열 렌더링\"] -->|\"prompt.partial()\"| B[\"완성형 Prompt\u003Cbr/>(tools/tool_names 치환)\"]\n    B -->|\"LLM 호출\u003Cbr/>(stop 시퀀스 등)\"| C[\"문자열 출력\"]\n    C -->|\"Output Parser\"| D[\"Action/Final 분기\"]\n    D -->|\"Tool 실행\"| E[\"Observation 문자열\"]\n    E -->|\"스크래치패드 누적\"| B\n  end\n\n  subgraph LG[\"LangGraph 기반 런타임\u003Cbr/>상태(State) + ToolNode\"]\n    F[\"Messages State\"] -->|\"Model Node\"| G[\"모델 응답\u003Cbr/>(tool_calls 포함 가능)\"]\n    G -->|\"toolsCondition\"| H[\"ToolNode 실행\"]\n    H -->|\"결과를 State에 주입\"| F\n    G -->|\"tool_calls 없음\"| I[\"종료\"]\n  end\n","mermaid","",[92,93,94,102,108,114,120,126,132,138,144,151,157,163,169,175,181],"code",{"__ignoreMap":90},[95,96,99],"span",{"class":97,"line":98},"line",1,[95,100,101],{},"flowchart LR\n",[95,103,105],{"class":97,"line":104},2,[95,106,107],{},"  subgraph LC[\"LangChain classic ReAct\u003Cbr/>문자열 유도 + 파싱\"]\n",[95,109,111],{"class":97,"line":110},3,[95,112,113],{},"    A[\"Tools\u003Cbr/>문자열 렌더링\"] -->|\"prompt.partial()\"| B[\"완성형 Prompt\u003Cbr/>(tools/tool_names 치환)\"]\n",[95,115,117],{"class":97,"line":116},4,[95,118,119],{},"    B -->|\"LLM 호출\u003Cbr/>(stop 시퀀스 등)\"| C[\"문자열 출력\"]\n",[95,121,123],{"class":97,"line":122},5,[95,124,125],{},"    C -->|\"Output Parser\"| D[\"Action/Final 분기\"]\n",[95,127,129],{"class":97,"line":128},6,[95,130,131],{},"    D -->|\"Tool 실행\"| E[\"Observation 문자열\"]\n",[95,133,135],{"class":97,"line":134},7,[95,136,137],{},"    E -->|\"스크래치패드 누적\"| B\n",[95,139,141],{"class":97,"line":140},8,[95,142,143],{},"  end\n",[95,145,147],{"class":97,"line":146},9,[95,148,150],{"emptyLinePlaceholder":149},true,"\n",[95,152,154],{"class":97,"line":153},10,[95,155,156],{},"  subgraph LG[\"LangGraph 기반 런타임\u003Cbr/>상태(State) + ToolNode\"]\n",[95,158,160],{"class":97,"line":159},11,[95,161,162],{},"    F[\"Messages State\"] -->|\"Model Node\"| G[\"모델 응답\u003Cbr/>(tool_calls 포함 가능)\"]\n",[95,164,166],{"class":97,"line":165},12,[95,167,168],{},"    G -->|\"toolsCondition\"| H[\"ToolNode 실행\"]\n",[95,170,172],{"class":97,"line":171},13,[95,173,174],{},"    H -->|\"결과를 State에 주입\"| F\n",[95,176,178],{"class":97,"line":177},14,[95,179,180],{},"    G -->|\"tool_calls 없음\"| I[\"종료\"]\n",[95,182,184],{"class":97,"line":183},15,[95,185,143],{},[15,187,188,189,192],{},"→ 기대 결과/무엇이 달라졌는지: ",[19,190,191],{},"도구/상태/분기가 ’문자열 규칙’이 아니라 ’실행 구조’로 분리됩니다."," 운영에서 가장 큰 차이는 디버깅과 실패 제어 비용입니다.",[54,194],{},[57,196,198],{"id":197},"해결-접근","해결 접근",[62,200,202],{"id":201},"선택-기준-도구-호출을-어디에-두는가","선택 기준: “도구 호출을 어디에 두는가?”",[26,204,205,226,244],{},[29,206,207,210,211,214,215,218,219,221,222,52],{},[19,208,209],{},"프로덕션에 가까운 선택",": 그래프 기반 에이전트 런타임(예: ",[92,212,213],{},"createAgent()"," / ",[92,216,217],{},"create_agent",")을 사용해 상태와 도구 실행을 구조로 분리합니다. ",[92,220,213],{},"는 LangGraph 기반 그래프 런타임으로 설명되며, 프로덕션 사용을 전제로 한 에이전트 구현으로 안내됩니다. (",[46,223,73],{"href":224,"rel":225},"https://docs.langchain.com/oss/javascript/langchain/agents",[50],[29,227,228,231,232,235,236,238,239,52],{},[19,229,230],{},"대안 1",": 모델 제공자의 Tool Calling(예: ",[92,233,234],{},"tools"," 파라미터)로 직접 루프를 구현합니다. OpenAI/Anthropic 모두 ",[92,237,234],{},"로 스키마를 전달하는 방식을 문서화합니다. (",[46,240,243],{"href":241,"rel":242},"https://platform.openai.com/docs/guides/function-calling?utm_source=chatgpt.com",[50],"platform.openai.com",[29,245,246,249,250,52],{},[19,247,248],{},"대안 2",": Next.js 친화적인 추상화가 필요하면 Vercel AI SDK처럼 “툴 라운드트립”을 라이브러리 레벨에서 제공하는 선택지도 있습니다. (",[46,251,254],{"href":252,"rel":253},"https://vercel.com/academy/ai-sdk/tool-use?utm_source=chatgpt.com",[50],"vercel.com",[15,256,257,258,261],{},"핵심은 하나입니다. ",[19,259,260],{},"도구를 “프롬프트 텍스트”로 다루지 말고, “스키마 + 실행 단계”로 다루는 쪽","이 운영에서 유리합니다.",[62,263,265],{"id":264},"mcp까지-고려한다면","MCP까지 고려한다면",[15,267,268,269,52],{},"MCP는 도구를 모델/클라이언트가 구조적으로 발견·호출할 수 있게 만드는 프로토콜입니다. (",[46,270,273],{"href":271,"rel":272},"https://modelcontextprotocol.io/specification/draft/server/tools?utm_source=chatgpt.com",[50],"modelcontextprotocol.io",[15,275,276,277,280,281,52],{},"MCP 서버에서 도구를 가져오려면, 멀티 서버 연결과 도구 로딩을 지원하는 MCP 클라이언트(예: ",[92,278,279],{},"MultiServerMCPClient",") 같은 구성으로 “도구 목록을 런타임에 주입”하는 그림이 자연스럽습니다. (",[46,282,51],{"href":283,"rel":284},"https://reference.langchain.com/python/langchain_mcp_adapters/",[50],[54,286],{},[57,288,290],{"id":289},"구현코드","구현(코드)",[15,292,293,294,297,298,52],{},"아래 예시는 ",[19,295,296],{},"Next.js Route Handler에서 에이전트를 실행","하는 형태입니다. 모델 키/도구 접근(내부 API, DB 등)은 서버에서만 처리하는 게 안전합니다. (",[46,299,302],{"href":300,"rel":301},"https://nextjs.org/docs/app/building-your-application/routing/route-handlers?utm_source=chatgpt.com",[50],"nextjs.org",[62,304,306,307,310],{"id":305},"_1-appapiagentroutejs-서버에서-에이전트-실행","1) ",[92,308,309],{},"/app/api/agent/route.js"," — 서버에서 에이전트 실행",[85,312,316],{"className":313,"code":314,"language":315,"meta":90,"style":90},"language-javascript shiki shiki-themes github-dark","// app/api/agent/route.js\nexport const runtime = \"nodejs\";\n\nimport { createAgent } from \"langchain\";\nimport { tool } from \"@langchain/core/tools\";\nimport * as z from \"zod\";\n\nconst searchFaq = tool(\n  async ({ query }) => {\n    // 실제 프로덕션에서는 내부 검색 API/DB를 호출하도록 교체하세요.\n    // 예: const res = await fetch(process.env.FAQ_API_URL, { ... })\n    if (query.toLowerCase().includes(\"refund\")) {\n      return \"환불은 결제 수단에 따라 처리 시간이 달라질 수 있습니다. 주문 번호로 조회 후 진행하세요.\";\n    }\n    return \"FAQ에서 관련 항목을 찾지 못했습니다. 구체 키워드를 추가해 주세요.\";\n  },\n  {\n    name: \"search_faq\",\n    description: \"서비스 FAQ에서 정책/가이드를 검색한다.\",\n    schema: z.object({\n      query: z.string().min(2),\n    }),\n  }\n);\n\nco