,[936],[938,949],{"disabled":499,"type":940}," 타입이 섞일 수 있는 입력이라면, 비교 전에 ",[31,952,953],{},"명시적 변환","(예: ",[15,956,957],{},"Number(x)",[15,959,960],{},"String(x)",")을 했는가?",[76,963,965,41,967,969,970,973,974,977],{"className":964},[936],[938,966],{"disabled":499,"type":940},[15,968,46],{}," 체크가 필요한 곳은 ",[15,971,972],{},"Object.is(x, NaN)"," 또는 ",[15,975,976],{},"Number.isNaN(x)","처럼 의도가 드러나는 방식인가?",[76,979,981,983],{"className":980},[936],[938,982],{"disabled":499,"type":940}," 객체/배열 비교에서 “구조 비교”가 필요하다면, 필드/키 기준 비교 함수를 별도로 두었는가?",[76,985,987,989,990,992,993,418,1000,1005,1011,1015],{"className":986},[936],[938,988],{"disabled":499,"type":940}," 린트 규칙으로 ",[15,991,17],{}," 사용을 관리하고(필요한 예외만 허용) 있는가? (",[994,995,999],"a",{"href":996,"rel":997},"https://nextjs.org/docs/app/api-reference/config/eslint",[998],"nofollow","Next.js ESLint 설정",[994,1001,1004],{"href":1002,"rel":1003},"https://eslint.org/docs/latest/rules/eqeqeq",[998],"ESLint ",[994,1006,1008],{"href":1002,"rel":1007},[998],[15,1009,1010],{},"eqeqeq",[994,1012,1014],{"href":1002,"rel":1013},[998]," 규칙",")",[62,1017],{},[65,1019,1021],{"id":1020},"흔한-실수faq","흔한 실수/FAQ",[124,1023,1025,1026,1028],{"id":1024},"q1-그럼-는-무조건-금지인가","Q1. “그럼 ",[15,1027,17],{},"는 무조건 금지인가?”",[27,1030,1031,1032,1034,1035,116],{},"팀 정책에 따라 다를 수 있습니다. 다만 ",[15,1033,17],{},"는 타입 변환이 끼어들기 때문에, “같다”의 의미가 코드 위치마다 달라지기 쉽습니다. 금지/허용보다 중요한 건 ",[31,1036,1037],{},"예외를 코드베이스에서 관리 가능한 수준으로 제한하는 것",[124,1039,1041,1042,1044],{"id":1040},"q2-objectis면-모든-비교가-해결되나","Q2. ",[15,1043,24],{},"면 모든 비교가 해결되나?",[27,1046,1047,1048,1051,1052,1055,1056,1059],{},"아닙니다. ",[15,1049,1050],{},"Object.is({a:1}, {a:1})","가 ",[15,1053,1054],{},"false","인 것처럼, ",[31,1057,1058],{},"구조적 동일성","을 판단해주진 않습니다. 구조 비교는 별도의 정책(필드 선택, 정렬, 깊이 제한 등)이 필요합니다.",[124,1061,1063,1064,1067],{"id":1062},"q3-new-string123-같은-래퍼-객체는-왜-피하나","Q3. ",[15,1065,1066],{},"new String('123')"," 같은 래퍼 객체는 왜 피하나?",[27,1069,1070,1071,1074],{},"원시 문자열과 다른 타입이라 비교 결과가 달라집니다. 문자열/숫자/불리언은 가능한 한 ",[31,1072,1073],{},"원시 값","으로만 다루는 편이 예측 가능성이 높습니다.",[62,1076],{},[65,1078,1080],{"id":1079},"요약35줄","요약(3~5줄)",[73,1082,1083,1088,1094,1104],{},[76,1084,1085,1087],{},[15,1086,17],{},"는 암묵적 타입 변환이 들어가서, 예상 못 한 결과를 만들기 쉽다.",[76,1089,1090,1091,1093],{},"기본 비교는 ",[15,1092,21],{},"로 고정하는 편이 유지보수에 유리하다.",[76,1095,1096,105,1098,1100,1101,1103],{},[15,1097,46],{},[15,1099,108],{},"까지 엄밀하게 다뤄야 할 때는 ",[15,1102,24],{},"가 해답이다.",[76,1105,1106],{},"객체/배열은 구조가 같아도 참조가 다르면 같지 않다. 구조 비교는 별도로 설계해야 한다.",[62,1108],{},[65,1110,1111],{"id":1111},"결론",[27,1113,1114,1115,1117,1118,1121],{},"“왜 ",[15,1116,17],{},"를 쓰지 말라”는 말의 본질은 ",[31,1119,1120],{},"타입 변환을 숨기지 말자","에 가깝습니다.",[27,1123,1124,1125,37,1127,1130,1131,418,1133,1135,1136,1141],{},"정리하면, **",[15,1126,21],{},[31,1128,1129],{},"를 기본으로",", 특별한 숫자 케이스(",[15,1132,46],{},[15,1134,54],{},")까지 의미가 중요한 지점에서만 ",[31,1137,1138,1140],{},[15,1139,24],{},"****를 선택","하는 게 가장 안전합니다.",[62,1143],{},[65,1145,1147],{"id":1146},"참고공식-문서-링크","참고(공식 문서 링크)",[73,1149,1150,1157,1164,1171,1178,1185,1192,1198],{},[76,1151,1152],{},[994,1153,1156],{"href":1154,"rel":1155},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Equality",[998],"MDN: Equality (==)",[76,1158,1159],{},[994,1160,1163],{"href":1161,"rel":1162},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Strict_equality",[998],"MDN: Strict equality (===)",[76,1165,1166],{},[994,1167,1170],{"href":1168,"rel":1169},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/is",[998],"MDN: Object.is()",[76,1172,1173],{},[994,1174,1177],{"href":1175,"rel":1176},"https://developer.mozilla.org/en-US/docs/Web/JavaScript/Guide/Equality_comparisons_and_sameness",[998],"MDN: Equality comparisons and sameness",[76,1179,1180],{},[994,1181,1184],{"href":1182,"rel":1183},"https://react.dev/reference/react/useState",[998],"React: useState",[76,1186,1187],{},[994,1188,1191],{"href":1189,"rel":1190},"https://react.dev/reference/react/useEffect",[9