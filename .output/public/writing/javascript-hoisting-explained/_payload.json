[{"data":1,"prerenderedAt":1211},["ShallowReactive",2],{"writing:meta:/writing/javascript-hoisting-explained":3},{"id":4,"title":5,"body":6,"date":1199,"description":1200,"extension":1201,"meta":1202,"navigation":613,"notionPageId":1203,"path":1204,"seo":1205,"source":1206,"stem":1207,"tags":1208,"__hash__":1210},"content/writing/javascript-hoisting-explained.md","선언은 위로, 값은 아래로: 자바스크립트 호이스팅의 실제 동작",{"type":7,"value":8,"toc":1174},"minimark",[9,13,22,34,37,43,46,51,54,115,125,127,131,134,150,153,175,178,189,204,240,253,265,276,307,318,327,345,350,354,357,407,410,413,459,468,470,474,481,536,539,578,580,584,588,595,872,888,919,921,925,969,971,975,979,986,993,1002,1009,1022,1033,1043,1050,1052,1056,1086,1088,1091,1094,1102,1104,1108,1170],[10,11,5],"h1",{"id":12},"선언은-위로-값은-아래로-자바스크립트-호이스팅의-실제-동작",[14,15,16,17,21],"p",{},"호이스팅(hoisting)은 코드가 “위로 이동”하는 현상이 아니라, ",[18,19,20],"strong",{},"실행 전에 선언 정보가 먼저 등록되는 동작","이다.",[14,23,24,25,29,30,33],{},"왜 중요한가 하면, 선언 순서를 잘못 이해하면 ",[26,27,28],"code",{},"undefined","가 튀어나오거나 ",[26,31,32],{},"ReferenceError","로 런타임이 깨진다.",[14,35,36],{},"특히 Next.js처럼 서버/클라이언트 실행 위치가 나뉘는 환경에서는 “어디서 실행되는 로그인지”까지 섞여 보이기 쉬워서, 호이스팅을 정확히 잡아두면 디버깅 속도가 확 올라간다.",[14,38,39,40],{},"포인트는 간단하다. ",[18,41,42],{},"선언 등록과 값 할당(초기화)은 타이밍이 다르다.",[44,45],"hr",{},[47,48,50],"h2",{"id":49},"배경문제","배경/문제",[14,52,53],{},"다음 코드는 왜 이렇게 동작할까?",[55,56,61],"pre",{"className":57,"code":58,"language":59,"meta":60,"style":60},"language-javascript shiki shiki-themes github-dark","console.log(myVar); // undefined\nvar myVar = 5;\nconsole.log(myVar); // 5\n","javascript","",[26,62,63,83,103],{"__ignoreMap":60},[64,65,68,72,76,79],"span",{"class":66,"line":67},"line",1,[64,69,71],{"class":70},"s95oV","console.",[64,73,75],{"class":74},"svObZ","log",[64,77,78],{"class":70},"(myVar); ",[64,80,82],{"class":81},"sAwPA","// undefined\n",[64,84,86,90,93,96,100],{"class":66,"line":85},2,[64,87,89],{"class":88},"snl16","var",[64,91,92],{"class":70}," myVar ",[64,94,95],{"class":88},"=",[64,97,99],{"class":98},"sDLfK"," 5",[64,101,102],{"class":70},";\n",[64,104,106,108,110,112],{"class":66,"line":105},3,[64,107,71],{"class":70},[64,109,75],{"class":74},[64,111,78],{"class":70},[64,113,114],{"class":81},"// 5\n",[14,116,117,118,120,121,124],{},"→ 기대 결과/무엇이 달라졌는지: 첫 번째 출력은 ",[26,119,28],{},", 두 번째 출력은 ",[26,122,123],{},"5","가 나온다. “선언은 먼저 잡히고, 값은 나중에 들어간다”는 힌트다.",[44,126],{},[47,128,130],{"id":129},"핵심-개념","핵심 개념",[14,132,133],{},"자바스크립트 엔진은 코드를 실행할 때, 대략 다음 흐름으로 움직인다.",[135,136,137,144],"ul",{},[138,139,140,143],"li",{},[18,141,142],{},"선언 수집",": 변수/함수/클래스 선언을 “이 스코프에 이런 이름이 있다” 수준으로 먼저 등록한다.",[138,145,146,149],{},[18,147,148],{},"실행",": 위에서 아래로 코드를 평가하면서 값 할당, 함수 호출 같은 실제 동작이 일어난다.",[14,151,152],{},"아래 다이어그램을 보면 “호이스팅”이 왜 가능해지는지 한 번에 정리된다.",[55,154,158],{"className":155,"code":156,"language":157,"meta":60,"style":60},"language-mermaid shiki shiki-themes github-dark","flowchart TD\n  A[\"코드 로드\u003Cbr/>파싱\"] -->|\"선언을 먼저 등록\"| B[\"실행 컨텍스트 생성\u003Cbr/>환경 레코드에 이름 등록\"]\n  B -->|\"위에서 아래로 평가\"| C[\"실행 단계\u003Cbr/>할당/호출/계산\"]\n","mermaid",[26,159,160,165,170],{"__ignoreMap":60},[64,161,162],{"class":66,"line":67},[64,163,164],{},"flowchart TD\n",[64,166,167],{"class":66,"line":85},[64,168,169],{},"  A[\"코드 로드\u003Cbr/>파싱\"] -->|\"선언을 먼저 등록\"| B[\"실행 컨텍스트 생성\u003Cbr/>환경 레코드에 이름 등록\"]\n",[64,171,172],{"class":66,"line":105},[64,173,174],{},"  B -->|\"위에서 아래로 평가\"| C[\"실행 단계\u003Cbr/>할당/호출/계산\"]\n",[14,176,177],{},"→ 기대 결과/무엇이 달라졌는지: “선언이 먼저 등록”되기 때문에, 선언문보다 위에서 이름을 참조하는 상황이 생긴다. 다만 “값까지 미리 올라가는 것”은 아니다.",[179,180,182,183,185,186,188],"h3",{"id":181},"_1var는-선언-등록-undefined초기화가-먼저-일어난다","1) ",[26,184,89],{},"는 “선언 등록 + ",[26,187,28],{}," 초기화”가 먼저 일어난다",[14,190,191,193,194,197,198,203],{},[26,192,89],{},"로 선언된 식별자(identifier)는 ",[18,195,196],{},"선언이 등록될 때 기본값이"," ",[18,199,200,202],{},[26,201,28],{},"****로 잡히는 동작","을 기대할 수 있다.",[55,205,206],{"className":57,"code":58,"language":59,"meta":60,"style":60},[26,207,208,218,230],{"__ignoreMap":60},[64,209,210,212,214,216],{"class":66,"line":67},[64,211,71],{"class":70},[64,213,75],{"class":74},[64,215,78],{"class":70},[64,217,82],{"class":81},[64,219,220,222,224,226,228],{"class":66,"line":85},[64,221,89],{"class":88},[64,223,92],{"class":70},[64,225,95],{"class":88},[64,227,99],{"class":98},[64,229,102],{"class":70},[64,231,232,234,236,238],{"class":66,"line":105},[64,233,71],{"class":70},[64,235,75],{"class":74},[64,237,78],{"class":70},[64,239,114],{"class":81},[14,241,242,243,246,247,249,250,252],{},"→ 기대 결과/무엇이 달라졌는지: ",[26,244,245],{},"var myVar","는 먼저 등록되고 ",[26,248,28],{},"로 시작한다. 실제 값 ",[26,251,123],{},"는 실행이 그 줄에 도달했을 때 들어간다.",[179,254,256,257,260,261,264],{"id":255},"_2letconst는-선언은-등록되지만-초기화-전-접근이-막힌다","2) ",[26,258,259],{},"let","/",[26,262,263],{},"const","는 “선언은 등록되지만, 초기화 전 접근이 막힌다”",[14,266,267,260,269,271,272,275],{},[26,268,259],{},[26,270,263],{},"는 선언이 등록되더라도, ",[18,273,274],{},"초기화 이전에는 접근이 차단","된다. 이 구간을 TDZ(Temporal Dead Zone, “일시적 사각지대”)라고 부른다.",[55,277,279],{"className":57,"code":278,"language":59,"meta":60,"style":60},"console.log(count); // ReferenceError\nlet count = 1;\n",[26,280,281,293],{"__ignoreMap":60},[64,282,283,285,287,290],{"class":66,"line":67},[64,284,71],{"class":70},[64,286,75],{"class":74},[64,288,289],{"class":70},"(count); ",[64,291,292],{"class":81},"// ReferenceError\n",[64,294,295,297,300,302,305],{"class":66,"line":85},[64,296,259],{"class":88},[64,298,299],{"class":70}," count ",[64,301,95],{"class":88},[64,303,304],{"class":98}," 1",[64,306,102],{"class":70},[14,308,242,309,311,312,314,315,317],{},[26,310,259],{},"도 선언 자체는 스코프에 잡히지만, 초기화 이전 접근은 에러로 막혀서 ",[26,313,89],{},"처럼 ",[26,316,28],{},"가 나오지 않는다.",[14,319,320,322,323,326],{},[26,321,263],{},"는 “재할당 금지”보다 먼저, ",[18,324,325],{},"선언과 동시에 초기화가 필요","하다는 점도 같이 따라온다.",[55,328,330],{"className":57,"code":329,"language":59,"meta":60,"style":60},"const x; // SyntaxError\n",[26,331,332],{"__ignoreMap":60},[64,333,334,336,339,342],{"class":66,"line":67},[64,335,263],{"class":88},[64,337,338],{"class":98}," x",[64,340,341],{"class":70},"; ",[64,343,344],{"class":81},"// SyntaxError\n",[14,346,242,347,349],{},[26,348,263],{},"는 선언만 단독으로 둘 수 없다. 선언 시점에 값이 필요하다.",[179,351,353],{"id":352},"_3-함수는-선언-방식에-따라-호이스팅-체감이-달라진다","3) 함수는 “선언 방식”에 따라 호이스팅 체감이 달라진다",[14,355,356],{},"함수 선언문(function declaration)은 호출 위치가 앞에 있어도 동작하는 경우가 많다.",[55,358,360],{"className":57,"code":359,"language":59,"meta":60,"style":60},"sayHi(); // \"hi\"\nfunction sayHi() {\n  console.log(\"hi\");\n}\n",[26,361,362,373,384,401],{"__ignoreMap":60},[64,363,364,367,370],{"class":66,"line":67},[64,365,366],{"class":74},"sayHi",[64,368,369],{"class":70},"(); ",[64,371,372],{"class":81},"// \"hi\"\n",[64,374,375,378,381],{"class":66,"line":85},[64,376,377],{"class":88},"function",[64,379,380],{"class":74}," sayHi",[64,382,383],{"class":70},"() {\n",[64,385,386,389,391,394,398],{"class":66,"line":105},[64,387,388],{"class":70},"  console.",[64,390,75],{"class":74},[64,392,393],{"class":70},"(",[64,395,397],{"class":396},"sU2Wk","\"hi\"",[64,399,400],{"class":70},");\n",[64,402,404],{"class":66,"line":403},4,[64,405,406],{"class":70},"}\n",[14,408,409],{},"→ 기대 결과/무엇이 달라졌는지: 함수 선언문은 “함수 자체”가 먼저 등록되는 쪽으로 동작해서, 선언 이전 호출이 가능해 보인다.",[14,411,412],{},"반면 함수 표현식(function expression)은 변수를 통해 함수를 담는 형태라서, 변수 초기화 타이밍의 영향을 그대로 받는다.",[55,414,416],{"className":57,"code":415,"language":59,"meta":60,"style":60},"sayHi(); // TypeError (또는 ReferenceError)\nvar sayHi = function () {\n  console.log(\"hi\");\n};\n",[26,417,418,427,442,454],{"__ignoreMap":60},[64,419,420,422,424],{"class":66,"line":67},[64,421,366],{"class":74},[64,423,369],{"class":70},[64,425,426],{"class":81},"// TypeError (또는 ReferenceError)\n",[64,428,429,431,433,436,439],{"class":66,"line":85},[64,430,89],{"class":88},[64,432,380],{"class":74},[64,434,435],{"class":88}," =",[64,437,438],{"class":88}," function",[64,440,441],{"class":70}," () {\n",[64,443,444,446,448,450,452],{"class":66,"line":105},[64,445,388],{"class":70},[64,447,75],{"c