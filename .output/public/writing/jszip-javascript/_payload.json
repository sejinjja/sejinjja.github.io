a.org/en-US/docs/Web/API/URL/revokeObjectURL_static",[54],"MDN: URL.revokeObjectURL",[58,468],{},[89,470,472],{"id":471},"_2-zip-생성-다운로드-csv-canvas-이미지","2) ZIP 생성 + 다운로드 (CSV + Canvas 이미지)",[189,474,476],{"className":232,"code":475,"language":234,"meta":194,"style":194},"// app/download-zip/DownloadZipClient.tsx\n\"use client\";\n\nimport { useEffect, useRef, useState } from \"react\";\nimport { downloadBlob } from \"./downloadBlob\";\n\nconst CSV_TEXT =\n  \"policyID,statecode,county\\n\" +\n  \"119736,FL,CLAY COUNTY\\n\" +\n  \"448094,FL,CLAY COUNTY\\n\";\n\nfunction canvasToBlob(canvas: HTMLCanvasElement, type: string, quality?: number) {\n  return new Promise\u003CBlob>((resolve, reject) => {\n    canvas.toBlob(\n      (blob) => (blob ? resolve(blob) : reject(new Error(\"canvas.toBlob() failed\"))),\n      type,\n      quality\n    );\n  });\n}\n\nexport default function DownloadZipClient() {\n  const canvasRef = useRef\u003CHTMLCanvasElement | null>(null);\n  const [downloading, setDownloading] = useState(false);\n\n  useEffect(() => {\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n\n    const ctx = canvas.getContext(\"2d\");\n    if (!ctx) return;\n\n    // 데모용 간단한 그림\n    ctx.fillStyle = \"#fff\";\n    ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n    ctx.fillStyle = \"red\";\n    ctx.font = \"24px sans-serif\";\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"middle\";\n    ctx.fillText(\"Hello World\", canvas.width / 2, canvas.height / 2);\n  }, []);\n\n  async function downloadAllAsZip() {\n    if (downloading) return;\n\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n\n    setDownloading(true);\n    try {\n      // 필요할 때만 로드(초기 번들 부담을 줄이기 위한 선택)\n      const JSZip = (await import(\"jszip\")).default;\n\n      const zip = new JSZip();\n\n      // 1) CSV: 문자열 → Blob\n      const csvBlob = new Blob([CSV_TEXT], { type: \"text/csv;charset=utf-8\" });\n      zip.file(\"test.csv\", csvBlob);\n\n      // 2) 이미지: canvas → Blob\n      const imageBlob = await canvasToBlob(canvas, \"image/jpeg\", 0.92);\n\n      const imgFolder = zip.folder(\"images\");\n      imgFolder?.file(\"resized.jpeg\", imageBlob);\n\n      // 3) ZIP 생성\n      const zipBlob = await zip.generateAsync({ type: \"blob\" });\n\n      // 4) 다운로드\n      downloadBlob(zipBlob, \"example.zip\");\n    } finally {\n      setDownloading(false);\n    }\n  }\n\n  return (\n    \u003Cdiv style={{ padding: 16 }}>\n      \u003Ch1>ZIP 다운로드 데모\u003C/h1>\n\n      \u003Ccanvas\n        ref={canvasRef}\n        width={600}\n        height={240}\n        style={{ border: \"1px solid #ccc\" }}\n      />\n\n      \u003Cdiv style={{ marginTop: 12 }}>\n        \u003Cbutton onClick={downloadAllAsZip} disabled={downloading}>\n          {downloading ? \"ZIP 만드는 중...\" : \"CSV + 이미지 ZIP으로 다운로드\"}\n        \u003C/button>\n      \u003C/div>\n    \u003C/div>\n  );\n}\n",[41,477,478,483,491,495,511,525,529,540,554,565,576,580,620,656,667,711,716,722,728,734,739,744,760,792,823,828,840,854,874,879,902,918,923,929,942,962,967,979,992,1005,1018,1049,1055,1060,1073,1085,1090,1101,1116,1121,1134,1142,1148,1175,1180,1196,1201,1207,1236,1253,1258,1264,1292,1297,1320,1336,1341,1347,1372,1377,1383,1397,1408,1420,1426,1432,1437,1445,1474,1498,1503,1511,1522,1538,1553,1574,1580,1585,1608,1629,1651,1662,1673,1683,1689],{"__ignoreMap":194},[198,479,480],{"class":200,"line":201},[198,481,482],{"class":241},"// app/download-zip/DownloadZipClient.tsx\n",[198,484,485,488],{"class":200,"line":245},[198,486,487],{"class":208},"\"use client\"",[198,489,490],{"class":258},";\n",[198,492,493],{"class":200,"line":286},[198,494,314],{"emptyLinePlaceholder":313},[198,496,497,500,503,506,509],{"class":200,"line":310},[198,498,499],{"class":248},"import",[198,501,502],{"class":258}," { useEffect, useRef, useState } ",[198,504,505],{"class":248},"from",[198,507,508],{"class":208}," \"react\"",[198,510,490],{"class":258},[198,512,513,515,518,520,523],{"class":200,"