],{},"은 왜 순서대로 나오나요?",[15,2055,2056,2059,2060,2063],{},[79,2057,2058],{},"Promise.all([p1, p2, p3])","은 완료 순서가 아니라 ",[25,2061,2062],{},"입력 배열의 인덱스"," 기준으로 결과 배열을 만든다.",[15,2065,953,2066,2069,2070,2073],{},[79,2067,2068],{},"p2","가 먼저 끝나도 결과는 ",[79,2071,2072],{},"[res1, res2, res3]"," 형태로 정렬된다.",[120,2075,2077,2078,2080],{"id":2076},"q3-promiseall을-쓰면-다-끝날-때까지-아무-것도-못-보나요","Q3. ",[79,2079,156],{},"을 쓰면 “다 끝날 때까지” 아무 것도 못 보나요?",[15,2082,2083,2085],{},[79,2084,156],{},"은 “모두 완료 후”를 전제로 한다.",[15,2087,2088,2089,2091],{},"중간 진행 상황을 보여주고 싶다면, 각 요청의 ",[79,2090,414],{},"에서 별도 로그를 남기거나, UI에 “진행 중” 상태를 업데이트하는 구조가 필요하다. (출력 순서가 중요하면 버퍼링이 필요할 수 있다.)",[120,2093,2095],{"id":2094},"q4-순차-실행이-너무-느린데-대안이-있나요","Q4. 순차 실행이 너무 느린데, 대안이 있나요?",[615,2097,2098,2101,2104],{},[15,2099,2100],{},"대안/비교 2) 동시성 제한(풀/큐)",[15,2102,2103],{},"요청은 어느 정도 병렬로 돌리되(예: 한 번에 N개), 과도한 동시 요청을 막는 방식이다.",[15,2105,2106],{},"환경(서버 제한/레이트 리밋/사용자 네트워크)에 따라 최적 값이 달라질 수 있다.",[30,2108],{},[33,2110,2112],{"id":2111},"요약35줄","요약(3~5줄)",[41,2114,2115,2118,2124,2132,2139],{},[44,2116,2117],{},"여러 요청 처리는 “동시성(언제 시작)”과 “출력 순서(언제/어떻게 표시)”를 분리해서 설계한다.",[44,2119,2120,2121,2123],{},"동시 실행 후 순서대로 출력하려면 ",[79,2122,156],{},"이 기본 선택지다.",[44,2125,2126,2127,1999,2129,2131],{},"요청 자체를 순차로 보내야 하면 ",[79,2128,822],{},[79,2130,818],{},"로 직렬 실행을 만든다.",[44,2133,2134,2135,2138],{},"실패 정책이 중요하면 ",[79,2136,2137],{},"Promise.allSettled()","로 결과를 모아서 처리한다.",[44,2140,2141],{},"Next.js에서는 실행 위치(서버/클라이언트)를 명확히 하고, 버튼/이벤트 기반으로 재현하면 안전하다.",[30,2143],{},[33,2145,2146],{"id":2146},"결론",[15,2148,2149],{},"“빠르다”는 건 실행 전략의 결과일 뿐, 목표가 아니다.",[15,2151,2152,2153,2156],{},"요구사항을 ",[25,2154,2155],{},"요청 순서 / 출력 순서 / 실패 정책","으로 나눠서 판단하면, Promise 기반 비동기 제어가 단순해진다.",[30,2158],{},[33,2160,2162],{"id":2161},"참고공식-문서-링크","참고(공식 문서 링크)",[41,2164,2165,2174,2181,2188,2195,2202,2209],{},[44,2166,2167],{},[2168,2169,2173],"a",{"href":2170,"rel":2171},"https://nextjs.org/docs",[2172],"nofollow","Next.js Docs",[44,2175,2176],{},[2168,2177,2180],{"href":2178,"rel":2179},"htt