[{"data":1,"prerenderedAt":773},["ShallowReactive",2],{"writing:meta:/writing/micrometer-actuator-metrics":3},{"id":4,"title":5,"body":6,"date":762,"description":763,"extension":764,"meta":765,"navigation":225,"notionPageId":766,"path":767,"seo":768,"source":769,"stem":770,"tags":771,"__hash__":772},"content/writing/micrometer-actuator-metrics.md","메트릭은 코드에 얇게 심고, 백엔드는 바꿔치기하라: Micrometer와 Actuator",{"type":7,"value":8,"toc":738},"minimark",[9,13,21,28,31,34,39,42,45,48,50,54,62,103,106,111,127,130,132,136,140,160,164,189,192,194,198,205,209,482,485,489,539,542,544,548,601,603,607,611,622,630,637,641,644,646,650,664,666,669,672,679,682,684,688,734],[10,11,5],"h1",{"id":12},"메트릭은-코드에-얇게-심고-백엔드는-바꿔치기하라-micrometer와-actuator",[14,15,16,17],"p",{},"한 문장 결론: ",[18,19,20],"strong",{},"Micrometer는 메트릭 수집 코드를 “한 번만” 작성해두고, 내보낼 모니터링 백엔드는 “나중에” 바꿀 수 있게 해주는 계측 파사드다.",[14,22,23,24,27],{},"운영 환경에서 “지금 서비스가 정상인가?”를 말로만 확인하기는 어렵습니다. 숫자가 필요해요. CPU/메모리 같은 시스템 지표부터 HTTP 지연 시간, 에러 비율, 비즈니스 이벤트(결제 성공/실패)까지 메트릭으로 남겨두면 ",[18,25,26],{},"문제 감지 → 원인 좁히기 → 개선 효과 검증","이 빨라집니다.",[14,29,30],{},"여기서 중요한 건, 메트릭을 붙이는 순간 모니터링 벤더에 종속되면 유지보수 비용이 급격히 올라간다는 점입니다.",[32,33],"hr",{},[35,36,38],"h2",{"id":37},"배경문제","배경/문제",[14,40,41],{},"모니터링 시스템은 Prometheus, Datadog, Graphite 등 선택지가 많습니다.",[14,43,44],{},"문제는 각 벤더의 SDK/API가 다르고, 메트릭 모델(이름 규칙, 태그/라벨, 히스토그램 지원 등)도 조금씩 달라서 **“벤더 SDK에 맞춰 코드가 오염되는 상황”**이 자주 생긴다는 겁니다.",[14,46,47],{},"Micrometer는 이 지점을 해결합니다.",[32,49],{},[35,51,53],{"id":52},"핵심-개념","핵심 개념",[14,55,56,57,61],{},"Micrometer를 한 문장으로 정리하면 **“관측(Observability)용 SLF4J 같은 역할”**입니다. 애플리케이션 코드는 ",[58,59,60],"code",{},"MeterRegistry","와 기본 Meter 타입(Counter/Timer/Gauge 등)만 바라보고, 실제 전송/노출 방식은 레지스트리 구현(백엔드)에 맡깁니다.",[63,64,69],"pre",{"className":65,"code":66,"language":67,"meta":68,"style":68},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  App[\"애플리케이션 코드\u003Cbr/>Counter/Timer/Gauge 기록\"] -->|\"표준 API\"| MR[\"MeterRegistry\u003Cbr/>메트릭 중앙 등록소\"]\n  MR -->|\"레지스트리 구현\"| Exporter[\"Prometheus/Datadog/...\u003Cbr/>내보내기(Export)\"]\n  Actuator[\"Actuator 엔드포인트\u003Cbr/>metrics/prometheus\"] -->|\"현재 값 노출\"| Exporter\n  App -->|\"기본 메트릭 자동 계측\"| Actuator\n","mermaid","",[58,70,71,79,85,91,97],{"__ignoreMap":68},[72,73,76],"span",{"class":74,"line":75},"line",1,[72,77,78],{},"flowchart LR\n",[72,80,82],{"class":74,"line":81},2,[72,83,84],{},"  App[\"애플리케이션 코드\u003Cbr/>Counter/Timer/Gauge 기록\"] -->|\"표준 API\"| MR[\"MeterRegistry\u003Cbr/>메트릭 중앙 등록소\"]\n",[72,86,88],{"class":74,"line":87},3,[72,89,90],{},"  MR -->|\"레지스트리 구현\"| Exporter[\"Prometheus/Datadog/...\u003Cbr/>내보내기(Export)\"]\n",[72,92,94],{"class":74,"line":93},4,[72,95,96],{},"  Actuator[\"Actuator 엔드포인트\u003Cbr/>metrics/prometheus\"] -->|\"현재 값 노출\"| Exporter\n",[72,98,100],{"class":74,"line":99},5,[72,101,102],{},"  App -->|\"기본 메트릭 자동 계측\"| Actuator\n",[14,104,105],{},"→ 기대 결과/무엇이 달라졌는지: 메트릭 계측 코드는 그대로 두고, 내보내는 대상(백엔드)만 교체할 수 있습니다. Actuator는 “노출 인터페이스”, Micrometer는 “계측/등록” 역할로 분리됩니다.",[107,108,110],"h3",{"id":109},"actuator와의-관계","Actuator와의 관계",[112,113,114,121],"ul",{},[115,116,117,120],"li",{},[18,118,119],{},"Actuator",": 운영 정보를 밖으로 꺼내는 관리 엔드포인트(헬스, 환경, 메트릭 등)",[115,122,123,126],{},[18,124,125],{},"Micrometer",": 그 아래에서 실제 메트릭을 만들고(계측) 레지스트리에 쌓는 계층",[14,128,129],{},"즉, “보여주는 창구”가 Actuator, “숫자를 만드는 엔진”이 Micrometer입니다.",[32,131],{},[35,133,135],{"id":134},"해결-접근","해결 접근",[107,137,139],{"id":138},"_1-micrometer를-쓰는-이유","1) Micrometer를 쓰는 이유",[112,141,142,148,154],{},[115,143,144,147],{},[18,145,146],{},"벤더 중립성",": 모니터링 백엔드가 바뀌어도 애플리케이션 계측 코드는 최소 변경",[115,149,150,153],{},[18,151,152],{},"일관된 모델",": Counter/Timer/Gauge 같은 공통 추상화로 지표를 표현",[115,155,156,159],{},[18,157,158],{},"운영 친화성",": Spring Boot Actuator와 결합 시 기본 메트릭 + 커스텀 메트릭을 같은 흐름으로 관리",[107,161,163],{"id":162},"_2-대안비교-최소-2개","2) 대안/비교 (최소 2개)",[112,165,166,178],{},[115,167,168,171,174,175,177],{},[18,169,170],{},"대안 A: 벤더 SDK 직접 사용",[172,173],"br",{},"장점: 기능을 가장 빠르게 활용 가능",[172,176],{},"단점: 코드가 벤더 모델에 묶여 이식/교체 비용이 커짐",[115,179,180,183,185,186,188],{},[18,181,182],{},"대안 B: OpenTelemetry 기반으로 통합",[172,184],{},"장점: 메트릭/트레이스/로그를 한 흐름으로 묶기 쉬움",[172,187],{},"단점: 도입 범위가 넓어 “지표만 빠르게” 붙이고 싶은 상황에서는 과해질 수 있음",[14,190,191],{},"Micrometer는 “메트릭 중심으로 빠르게 안정화”할 때 특히 깔끔합니다.",[32,193],{},[35,195,197],{"id":196},"구현코드","구현(코드)",[14,199,200,201,204],{},"아래 예제는 ",[18,202,203],{},"요청 건수(Counter), 요청 처리 시간(Timer), 현재 활성 세션 수(Gauge)"," 를 측정합니다.",[107,206,208],{"id":207},"_1-커스텀-메트릭-등록-업데이트","1) 커스텀 메트릭 등록 + 업데이트",[63,210,214],{"className":211,"code":212,"language":213,"meta":68,"style":68},"language-java shiki shiki-themes github-dark","package com.example.metrics;\n\nimport io.micrometer.core.instrument.Counter;\nimport io.micrometer.core.instrument.Gauge;\nimport io.micrometer.core.instrument.MeterRegistry;\nimport io.micrometer.core.instrument.Timer;\nimport org.springframework.stereotype.Service;\n\nimport java.util.concurrent.atomic.AtomicInteger;\n\n@Service\npublic class CustomMetricsService {\n\n    private final Counter requestCounter;\n    private final Timer requestTimer;\n    private final AtomicInteger activeSessions;\n\n    public CustomMetricsService(MeterRegistry meterRegistry) {\n        // 요청 총 건수\n        this.requestCounter = Counter.builder(\"custom.requests.total\")\n                .description(\"Total requests for a logical endpoint\")\n                .tag(\"endpoint\", \"api_test\") // 값 범위가 제한된 태그로 유지\n                .register(meterRegistry);\n\n        // 요청 처리 시간\n        this.requestTimer = Timer.builder(\"custom.request.duration\")\n                .description(\"Request duration for a logical endpoint\")\n                .tag(\"endpoint\", \"api_test\")\n                .register(meterRegistry);\n\n        // 활성 세션 수 (Gauge는 '현재 값'을 읽어가는 방식)\n        this.activeSessions = new AtomicInteger(0);\n        Gauge.builder(\"custom.active.sessions\", activeSessions, AtomicInteger::get)\n                .description(\"Number of active sessions\")\n                .tag(\"region\", \"us-east\")\n                .register(meterRegistry);\n    }\n\n    public void processRequest(Runnable requestLogic) {\n        requestCounter.increment();\n        requestTimer.record(requestLogic);\n    }\n\n    public void updateActiveSessions(int sessions) {\n        activeSessions.set(sessions);\n    }\n}\n","java",[58,215,216,221,227,232,237,242,248,254,259,265,270,276,282,287,293,299,305,310,316,322,328,334,340,346,351,357,363,369,375,380,385,391,397,403,409,415,420,426,431,437,443,449,454,459,465,471,476],{"__ignoreMap":68},[72,217,218],{"class":74,"line":75},[72,219,220],{},"package com.example.metrics;\n",[72,222,223],{"class":74,"line":81},[72,224,226],{"emptyLinePlaceholder":225},true,"\n",[72,228,229],{"class":74,"line":87},[72,230,231],{},"import io.micrometer.core.instrument.Counter;\n",[72,233,234],{"class":74,"line":93},[72,235,236],{},"import io.micrometer.core.instrument.Gauge;\n",[72,238,239],{"class":74,"line":99},[72,240,241],{},"import io.micrometer.core.instrument.MeterRegistry;\n",[72,243,245],{"class":74,"line":244},6,[72,246,247],{},"import io.micrometer.core.instrument.Timer;\n",[72,249,251],{"class":74,"line":250},7,[72,252,253],{},"import org.springframework.stereotype.Service;\n",[72,255,257],{"class":74,"line":256},8,[72,258,226],{"emptyLinePlaceholder":225},[72,260,262],{"class":74,"line":261},9,[72,263,264],{},"import java.util.concurrent.atomic.AtomicInteger;\n",[72,266,268],{"class":74,"line":267},10,[72,269,226],{"emptyLinePlaceholder":225},[72,271,273],{"class":74,"line":272},11,[72,274,275],{},"@Service\n",[72,277,279],{"class":74,"line":278},12,[72,280,281],{},"public class CustomMetricsService {\n",[72,283,285],{"class":74,"line":284},13,[72,286,226],{"emptyLinePlaceholder":225},[72,288,290],{"class":74,"line":289},14,[72,291,292],{},"    private final Counter requestCounter;\n",[72,294,296],{"class":74,"line":295},15,[72,297,298],{},"    private final Timer requestTimer;\n",[72,300,302],{"class":74,"line":301},16,[72,303,304],{},"    private final AtomicInteger activeSessions;\n",[72,306,308],{"class":74,"line":307},17,[72,309,226],{"emptyLinePlaceholder":225},[72,311,313],{"class":74,"line":312},18,[72,314,315],{},"    public CustomMetricsService(MeterRegistry meterRegistry) {\n",[72,317,319],{"class":74,"line":318},19,[72,320,321],{},"        // 요청 총 건수\n",[72,323,325],{"class":74,"line":324},20,[72,326,327],{},"        this.requestCounter = Counter.builder(\"custom.requests.total\")\n",[72,329,331],{"class":74,"line":330},21,[72,332,333],{},"                .description(\"Total requests for a logical endpoint\")\n",[72,335,337],{"class":74,"line":336},22,[72,338,339],{},"                .tag(\"endpoint\", \"api_test\") // 값 범위가 제한된 태그로 유지\n",[72,341,343],{"class":74,"line":342},23,[72,344,345],{},"                .register(meterRegistry);\n",[72,347,349],{"class":74,"line":348},24,[72,350,226],{"emptyLinePlaceholder":225},[72,352,354],{"class":74,"line":353},25,[72,355,356],{},"        // 요청 처리 시간\n",[72,358,360],{"class":74,"line":359},26,[72,361,362],{},"        this.requestTimer = Timer.builder(\"custom.request.duration\")\n",[72,364,366],{"class":74,"line":365},27,[72,367,368],{},"                .description(\"Request duration for a logical endpoint\")\n",[72,370,372],{"class":74,"line":371},28,[72,373,374],{},"                .tag(\"endpoint\", \"api_test\")\n",[72,376,378],{"class":74,"line":377},29,[72,379,345],{},[72,381,383],{"class":74,"line":382},30,[72,384,226],{"emptyLinePlaceholder":225},[72,386,388],{"class":74,"line":387},31,[72,389,390],{},"        // 활성 세션 수 (Gauge는 '현재 값'을 읽어가는 방식)\n",[72,392,394],{"class":74,"line":393},32,[72,395,396],{},"        this.activeSessions = new AtomicInteger(0);\n",[72,398,400],{"class":74,"line":399},33,[72,401,402],{},"        Gauge.builder(\"custom.active.sessions\", activeSessions, AtomicInteger::get)\n",[72,404,406],{"class":74,"line":405},34,[72,407,408],{},"                .description(\"Number of active sessions\")\n",[72,410,412],{"class":74,"line":411},35,[72,413,414],{},"                .tag(\"region\", \"us-east\")\n",[72,416,418],{"class":74,"line":417},36,[72,419,345],{},[72,421,423],{"class":74,"line":422},37,[72,424,425],{},"    }\n",[72,427,429],{"class":74,"line":428},38,[72,430,226],{"emptyLinePlaceholder":225},[72,432,434],{"class":74,"line":433},39,[72,435,436],{},"    public void processRequest(Runnable requestLogic) {\n",[72,438,440],{"class":74,"line":439},40,[72,441,442],{},"        requestCounter.increment();\n",[72,444,446],{"class":74,"line":445},41,[72,447,448],{},"        requestTimer.record(requestLogic);\n",[72,450,452],{"class":74,"line":451},42,[72,453,425],{},[72,455,457],{"class":74,"line":456},43,[72,458,226],{"emptyLinePlaceholder":225},[72,460,462],{"class":74,"line":461},44,[72,463,464],{},"    public void updateActiveSessions(int sessions) {\n",[72,466,468],{"class":74,"line":467},45,[72,469,470],{},"        activeSessions.set(sessions);\n",[72,472,474],{"class":74,"line":473},46,[72,475,425],{},[72,477,479],{"class":74,"line":478},47,[72,480,481],{},"}\n",[14,483,484],{},"→ 기대 결과/무엇이 달라졌는지: 요청이 처리될 때마다 카운트와 처리 시간이 누적되고, 활성 세션 수는 최신 값이 즉시 반영됩니다. 메트릭 이름/태그는 고정돼 운영에서 안정적으로 집계됩니다.",[107,486,488],{"id":487},"_2-actuator로-메트릭-확인-경로-준비","2) Actuator로 메트릭 확인 경로 준비",[63,490,494],{"className":491,"code":492,"language":493,"meta":68,"style":68},"language-yaml shiki shiki-themes github-dark","management:\n  endpoints:\n    web:\n      exposure:\n        include: \"health,info,metrics,prometheus\"\n","yaml",[58,495,496,506,513,520,527],{"__ignoreMap":68},[72,497,498,502],{"class":74,"line":75},[72,499,501],{"class":500},"s4JwU","management",[72,503,505],{"class":504},"s95oV",":\n",[72,507,508,511],{"class":74,"line":81},[72,509,510],{"class":500},"  endpoints",[72,512,505],{"class":504},[72,514,515,518],{"class":74,"line":87},[72,516,517],{"class":500},"    web",[72,519,505],{"class":504},[72,521,522,525],{"class":74,"line":93},[72,523,524],{"class":500},"      exposure",[72,526,505],{"class":504},[72,528,529,532,535],{"class":74,"line":99},[72,530,531],{"class":500},"        include",[72,533,534],{"class":504},": ",[72,536,538],{"class":537},"sU2Wk","\"health,info,metrics,prometheus\"\n",[14,540,541],{},"→ 기대 결과/무엇이 달라졌는지: 메트릭을 확인할 수 있는 엔드포인트가 노출됩니다. 실제 노출 범위는 보안 정책에 맞춰 최소화할 수 있습니다.",[32,543],{},[35,545,547],{"id":546},"검증-방법체크리스트","검증 방법(체크리스트)",[112,549,552,569,579,589,595],{"className":550},[551],"contains-task-list",[115,553,556,560,561,564,565,568],{"className":554},[555],"task-list-item",[557,558],"input",{"disabled":225,"type":559},"checkbox"," 요청을 몇 번 호출한 뒤, ",[58,562,563],{},"metrics"," 엔드포인트에서 ",[58,566,567],{},"custom.requests.total","가 증가하는지 확인한다.",[115,570,572,574,575,578],{"className":571},[555],[557,573],{"disabled":225,"type":559}," ",[58,576,577],{},"custom.request.duration","가 count/total time 등의 집계값을 갖는지 확인한다.",[115,580,582,584,585,588],{"className":581},[555],[557,583],{"disabled":225,"type":559}," 로그인/로그아웃(또는 세션 변화) 이벤트 후 ",[58,586,587],{},"custom.active.sessions"," 값이 즉시 바뀌는지 확인한다.",[115,590,592,594],{"className":591},[555],[557,593],{"disabled":225,"type":559}," 태그 값이 “제한된 집합”인지 점검한다(요청 URL 전체/사용자 ID 같은 값이 태그로 들어가면 위험).",[115,596,598,600],{"className":597},[555],[557,599],{"disabled":225,"type":559}," 운영 환경에서는 엔드포인트 접근 제어(인증/내부망/리버스 프록시 제한 등)를 적용한다.",[32,602],{},[35,604,606],{"id":605},"흔한-실수faq","흔한 실수/FAQ",[107,608,610],{"id":609},"q1-태그에-url-전체를-넣으면-안-되나요","Q1. 태그에 URL 전체를 넣으면 안 되나요?",[14,612,613,614,617,618,621],{},"태그 조합이 늘어날수록 시계열이 폭발합니다. ",[58,615,616],{},"/api/users/1",", ",[58,619,620],{},"/api/users/2","처럼 값이 무한히 늘어나는 태그는 피하고, 라우트 템플릿 수준의 “고정된 값”으로 설계하는 게 안전합니다.",[107,623,625,626,629],{"id":624},"q2-gauge는increment처럼-올리면-되나요","Q2. Gauge는 ",[58,627,628],{},"increment()","처럼 올리면 되나요?",[14,631,632,633,636],{},"Gauge는 “누적”이 아니라 “현재 값”을 읽습니다. 그래서 Gauge는 ",[18,634,635],{},"값 저장소(AtomicInteger 등)"," 를 두고 set으로 갱신하는 형태가 잘 맞습니다.",[107,638,640],{"id":639},"q3-이미-http-요청-메트릭이-있는데-커스텀-timer가-또-필요할까요","Q3. 이미 HTTP 요청 메트릭이 있는데 커스텀 Timer가 또 필요할까요?",[14,642,643],{},"기본 메트릭으로 충분한 경우가 많습니다. 다만 “특정 비즈니스 로직 구간”처럼 HTTP 요청 단위보다 더 좁은 범위를 재고 싶다면 커스텀이 유효합니다.",[32,645],{},[35,647,649],{"id":648},"요약-35줄","요약 (3~5줄)",[112,651,652,655,658,661],{},[115,653,654],{},"Micrometer는 메트릭 계측 코드를 벤더로부터 분리해주는 표준 API(파사드)입니다.",[115,656,657],{},"Actuator는 운영 정보를 노출하는 창구이고, Micrometer는 그 아래에서 숫자를 만들고 등록합니다.",[115,659,660],{},"Counter/Timer/Gauge로 “누적/지연/현재 상태”를 각각 표현할 수 있습니다.",[115,662,663],{},"태그는 반드시 값 범위를 제한해 시계열 폭발을 막는 게 핵심입니다.",[32,665],{},[35,667,668],{"id":668},"결론",[14,670,671],{},"Micrometer를 쓰면 메트릭을 “붙이는 비용”이 줄고, 모니터링 백엔드를 “교체하는 비용”도 줄어듭니다.",[14,673,674,675,678],{},"포인트는 두 가지입니다. ",[18,676,677],{},"(1) 태그 카디널리티를 통제하고 (2) 의미 있는 구간에만 측정기를 심기",".",[14,680,681],{},"이 두 가지만 지키면, 운영에서 메트릭은 디버깅 도구를 넘어 “제품 품질 지표”가 됩니다.",[32,683],{},[35,685,687],{"id":686},"참고공식-문서-링크","참고(공식 문서 링크)",[112,689,690,699,706,713,720,727],{},[115,691,692],{},[693,694,698],"a",{"href":695,"rel":696},"https://docs.micrometer.io/micrometer/reference/",[697],"nofollow","Micrometer Docs",[115,700,701],{},[693,702,705],{"href":703,"rel":704},"https://docs.micrometer.io/micrometer/reference/concepts/timers.html",[697],"Micrometer Timers",[115,707,708],{},[693,709,712],{"href":710,"rel":711},"https://docs.micrometer.io/micrometer/reference/implementations/prometheus.html",[697],"Micrometer Prometheus Registry",[115,714,715],{},[693,716,719],{"href":717,"rel":718},"https://docs.spring.io/spring-boot/reference/actuator/metrics.html",[697],"Spring Boot Actuator Metrics",[115,721,722],{},[693,723,726],{"href":724,"rel":725},"https://docs.spring.io/spring-boot/api/rest/actuator/prometheus.html",[697],"Spring Boot Actuator Prometheus Endpoint",[115,728,729],{},[693,730,733],{"href":731,"rel":732},"https://docs.spring.io/spring-boot/reference/actuator/observability.html",[697],"Spring Boot Observability",[735,736,737],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s4JwU, html code.shiki .s4JwU{--shiki-default:#85E89D}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}",{"title":68,"searchDepth":81,"depth":81,"links":739},[740,741,744,748,752,753,759,760,761],{"id":37,"depth":81,"text":38},{"id":52,"depth":81,"text":53,"children":742},[743],{"id":109,"depth":87,"text":110},{"id":134,"depth":81,"text":135,"children":745},[746,747],{"id":138,"depth":87,"text":139},{"id":162,"depth":87,"text":163},{"id":196,"depth":81,"text":197,"children":749},[750,751],{"id":207,"depth":87,"text":208},{"id":487,"depth":87,"text":488},{"id":546,"depth":81,"text":547},{"id":605,"depth":81,"text":606,"children":754},[755,756,758],{"id":609,"depth":87,"text":610},{"id":624,"depth":87,"text":757},"Q2. Gauge는 increment()처럼 올리면 되나요?",{"id":639,"depth":87,"text":640},{"id":648,"depth":81,"text":649},{"id":668,"depth":81,"text":668},{"id":686,"depth":81,"text":687},"2026-02-10","Micrometer는 메트릭 수집 코드를 \"한 번만\" 작성해두고, 내보낼 모니터링 백엔드는 \"나중에\" 바꿀 수 있게 해주는 계측 파사드입니다. Counter/Timer/Gauge로 누적/지연/현재 상태를 표현하며, Spring Boot Actuator와 결합하여 운영 메트릭을 안정적으로 관리할 수 있습니다.","md",{},"303c01ed-7f98-80b8-97f6-fbf9267ba007","/writing/micrometer-actuator-metrics",{"title":5,"description":763},"notion","writing/micrometer-actuator-metrics",[213],"W43su2exax2rxq08rRNEA8V1tyhXDwpcwIDwyA2faC8",1772644130757]