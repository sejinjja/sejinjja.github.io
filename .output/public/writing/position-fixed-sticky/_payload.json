| B[\"relative처럼 배치\"]\n",[159,331,332],{"class":161,"line":174},[159,333,334],{},"  B -->|\"임계점 도달(top 등)\"| C[\"고정 상태로 전환\"]\n",[159,336,337],{"class":161,"line":180},[159,338,339],{},"  C -->|\"스크롤 컨테이너 끝\"| D[\"컨테이너 경계에서 멈춤\"]\n",[35,341,192,342,344,345,348],{},[19,343,29],{},"가 “따라오다 멈추는 이유”가 ",[14,346,347],{},"컨테이너 경계"," 때문임을 구조로 이해할 수 있다.",[245,350,351],{},[35,352,249,353],{},[251,354,357],{"href":355,"rel":356},"https://developer.mozilla.org/docs/Web/CSS/position#sticky",[255],"MDN - position: sticky",[64,359],{},[67,361,363],{"id":362},"해결-접근","해결 접근",[72,365,367,368,370],{"id":366},"접근-1-fixed가-부모-기준처럼-보일-때의-해결","접근 1) ",[19,369,43],{},"가 부모 기준처럼 보일 때의 해결",[372,373,374,391],"ol",{},[80,375,376,379,380],{},[14,377,378],{},"조상에 기준을 바꾸는 속성(transform/filter/contain/will-change)이 있는지"," 확인한다.\n",[77,381,382,388],{},[80,383,384,385,387],{},"왜: 조상이 컨테이닝 블록이 되면 ",[19,386,43],{},"가 “그 안에서만” 고정된 것처럼 보인다.",[80,389,390],{},"기대 결과: “부모 기준으로 붙는 현상” 원인을 즉시 특정.",[80,392,393,394,397,398,403,404],{},"레이아웃 전체 래퍼(wrapper)에 ",[19,395,396],{},"transform: translateZ(0)"," 같은 최적화 트릭을 걸었다면, ",[14,399,400,402],{},[19,401,43],{},"****가 필요한 레이어만 분리","한다.\n",[77,405,406,412],{},[80,407,408,409,411],{},"대안 A: ",[19,410,43],{}," 요소를 래퍼 밖(문서 루트)에 배치",[80,413,414,415,418],{},"대안 B: **Portal(포탈)**로 ",[19,416,417],{},"document.body"," 아래로 렌더링",[72,420,422,423,425],{"id":421},"접근-2-sticky가-안-붙을-때의-해결","접근 2) ",[19,424,29],{},"가 안 붙을 때의 해결",[372,427,428,442],{},[80,429,430,433,434],{},[14,431,432],{},"스크롤이 어디에서 일어나는지","(문서 vs 특정 컨테이너) 먼저 확정한다.\n",[77,435,436,439],{},[80,437,438],{},"왜: sticky는 “스크롤 컨테이너”에 종속된다.",[80,440,441],{},"기대 결과: “왜 페이지에서는 되는데 모달/패널에서는 안 되는지”가 정리된다.",[80,443,444,446,447,450,451,454,455],{},[19,445,29],{},"에는 보통 ",[19,448,449],{},"top","(또는 ",[19,452,453],{},"bottom",")이 필요하다.\n",[77,456,457,460],{},[80,458,459],{},"왜: 임계점이 없으면 “언제부터 붙을지”를 결정할 수 없다.",[80,461,462],{},"기대 결과: sticky 전환 타이밍이 예측 가능해진다.",[72,464,466,467,469,470,469,472],{"id":465},"비교-fixed-vs-sticky-vs-absol