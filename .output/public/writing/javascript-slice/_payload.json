[{"data":1,"prerenderedAt":2466},["ShallowReactive",2],{"writing:meta:/writing/javascript-slice":3},{"id":4,"title":5,"body":6,"date":2455,"description":2456,"extension":2457,"meta":2458,"navigation":331,"notionPageId":2459,"path":2460,"seo":2461,"source":2462,"stem":2463,"tags":2464,"__hash__":2465},"content/writing/javascript-slice.md","필요한 만큼만 잘라라: slice의 비파괴 복사 규칙",{"type":7,"value":8,"toc":2420},"minimark",[9,19,39,44,47,52,55,68,75,77,81,88,129,143,145,149,155,163,179,187,192,226,228,232,239,265,275,452,462,476,481,483,490,518,525,646,649,651,660,678,685,697,704,883,891,893,902,926,933,1073,1076,1078,1086,1096,1103,1227,1233,1239,1244,1376,1379,1381,1385,1388,1396,1403,1604,1607,1610,1617,2141,2144,2146,2150,2229,2231,2235,2245,2252,2257,2265,2272,2282,2289,2298,2303,2310,2319,2327,2329,2333,2353,2355,2358,2363,2366,2369,2371,2375,2417],[10,11,13,14,18],"h1",{"id":12},"필요한-만큼만-잘라라-slice의-비파괴-복사-규칙","필요한 만큼만 잘라라: ",[15,16,17],"code",{},"slice","의 비파괴 복사 규칙",[20,21,22,23,25,26,30,31,34,35,38],"p",{},"한 문장 결론: ",[15,24,17],{},"는 ",[27,28,29],"strong",{},"원본을 유지한 채"," 필요한 구간만 ",[27,32,33],{},"새 값으로 잘라내는"," 도구다. 다만 ",[27,36,37],{},"Array / String / TypedArray / Buffer","는 \"새 값\"의 의미가 조금씩 다르다.",[20,40,41,43],{},[15,42,17],{},"를 제대로 이해하면 얻는 이점이 분명하다.불필요한 원본 변경을 줄여 디버깅이 쉬워지고, 렌더링/상태 관리에서 의도치 않은 사이드 이펙트를 막는다. 또한 \"복사 vs view(같은 메모리 공유)\"를 구분하면 대용량 데이터 처리에서 성능·메모리 문제를 피하기 좋아진다.",[45,46],"hr",{},[48,49,51],"h2",{"id":50},"배경문제","배경/문제",[20,53,54],{},"코드를 보다 보면 이런 상황이 자주 생긴다.",[56,57,58,62,65],"ul",{},[59,60,61],"li",{},"리스트에서 \"일부 구간만\" 뽑아 UI에 보여주고 싶다.",[59,63,64],{},"문자열에서 \"뒤쪽 확장자/접미사\"만 안전하게 떼고 싶다.",[59,66,67],{},"바이너리/버퍼 데이터를 \"헤더/페이로드\"로 나눠 처리하고 싶다.",[20,69,70,71,74],{},"여기서 핵심은 ",[27,72,73],{},"원본을 바꾸지 않는 것(비파괴)"," 이다. 원본이 바뀌면, 상태 관리/캐시/렌더링 흐름에서 예상하지 못한 문제가 생기기 쉽다.",[45,76],{},[48,78,80],{"id":79},"핵심-개념","핵심 개념",[82,83,85,87],"h3",{"id":84},"slice는-잘라서-새-값을-만든다-단-타입별로-새-값의-의미가-다르다",[15,86,17],{},"는 \"잘라서 새 값\"을 만든다 — 단, 타입별로 \"새 값\"의 의미가 다르다",[89,90,95],"pre",{"c