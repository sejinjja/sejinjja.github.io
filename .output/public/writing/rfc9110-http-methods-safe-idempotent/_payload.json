[{"data":1,"prerenderedAt":1500},["ShallowReactive",2],{"writing:meta:/writing/rfc9110-http-methods-safe-idempotent":3},{"id":4,"title":5,"body":6,"date":1488,"description":1489,"extension":1490,"meta":1491,"navigation":249,"notionPageId":1492,"path":1493,"seo":1494,"source":1495,"stem":1496,"tags":1497,"__hash__":1499},"content/writing/rfc9110-http-methods-safe-idempotent.md","HTTP 메서드 안전과 멱등성",{"type":7,"value":8,"toc":1452},"minimark",[9,14,35,46,49,69,76,79,84,89,132,134,138,142,149,165,169,176,183,187,198,203,205,209,292,295,297,301,305,397,399,403,455,457,461,465,499,510,514,526,537,539,543,546,558,562,748,751,753,757,874,877,879,883,979,982,984,988,1001,1013,1153,1156,1158,1162,1234,1236,1240,1244,1251,1259,1263,1266,1271,1275,1289,1294,1298,1301,1305,1316,1320,1323,1330,1332,1336,1369,1371,1374,1381,1384,1386,1390,1448],[10,11,13],"h1",{"id":12},"재시도-가능한-요청만-보내라-safeidempotent로-고르는-http-메서드","재시도 가능한 요청만 보내라: Safe·Idempotent로 고르는 HTTP 메서드",[15,16,17,21,22,26,27,30,31,34],"p",{},[18,19,20],"strong",{},"한 문장 결론:"," ",[23,24,25],"code",{},"safe(안전)","와 ",[23,28,29],{},"idempotent(멱등)","만 제대로 지켜도 ",[18,32,33],{},"재시도·캐시·프리패치","에서 터지는 사고의 대부분이 줄어든다.",[15,36,37,38,41,42,45],{},"웹 앱은 생각보다 “자동으로” 요청을 보냅니다. 브라우저·프록시·CDN·크롤러는 물론이고, Next.js에서도 ",[23,39,40],{},"\u003CLink />"," 프리패치처럼 ",[18,43,44],{},"사용자 클릭 이전에"," 요청이 발생할 수 있어요. 이때 메서드 선택이 느슨하면, “그냥 조회였는데 로그아웃이 됨”, “네트워크 끊겨서 재시도했더니 중복 생성됨” 같은 문제가 현실이 됩니다.",[15,47,48],{},"포인트는 간단합니다.",[50,51,52,58,63],"ul",{},[53,54,55,57],"li",{},[18,56,25],{},": 자동화가 마음 놓고 호출해도 “의도된 상태 변경”이 없는 읽기 성격",[53,59,60,62],{},[18,61,29],{},": 같은 요청을 여러 번 보내도 “의도된 효과”가 한 번과 같은 성격",[53,64,65,68],{},[18,66,67],{},"cacheable(캐시 가능)",": 캐시가 저장/재사용해도 되는 성격(환경/정책에 따라 달라질 수 있음)",[15,70,71,72,75],{},"아래는 이 세 가지를 기준으로 ",[18,73,74],{},"GET/POST/PUT/PATCH/DELETE","를 실무에서 어떻게 고르는지 정리합니다.",[77,78],"hr",{},[80,81,83],"h2",{"id":82},"배경문제","배경/문제",[85,86,88],"h3",{"id":87},"왜-메서드-의미semantics가-실무에서-중요한가","왜 “메서드 의미(semantics)”가 실무에서 중요한가",[90,91,92,105,120],"ol",{},[53,93,94,97,100,101,104],{},[18,95,96],{},"재시도(retry)",[98,99],"br",{},"네트워크는 끊깁니다. 클라이언트/프록시가 재시도를 고려할 때, ",[18,102,103],{},"멱등성","은 “한 번 더 보내도 괜찮다”의 근거가 됩니다.",[53,106,107,110,112,113,115,116,119],{},[18,108,109],{},"프리패치(prefetch)·크롤러·링크 미리보기",[98,111],{},"Next.js의 ",[23,114,40],{}," 프리패치나 크롤러는 링크를 “미리” 따라갑니다. 이때 ",[18,117,118],{},"안전(safe)"," 하지 않은 동작이 GET에 숨어 있으면, 클릭하지 않았는데도 상태가 바뀔 수 있어요.",[53,121,122,125,127,128,131],{},[18,123,124],{},"캐시(cache)",[98,126],{},"캐시는 대부분 ",[18,129,130],{},"GET/HEAD 중심","으로 설계됩니다. “조회인데 POST를 썼더니 캐시가 안 먹음” 같은 문제는 메서드 의미를 거슬렀을 때 자주 나옵니다.",[77,133],{},[80,135,137],{"id":136},"핵심-개념","핵심 개념",[85,139,141],{"id":140},"_1-safe안전-읽기-전용에-가까운-의미","1) safe(안전): “읽기 전용”에 가까운 의미",[15,143,144,145,148],{},"safe는 “부작용이 0”이 아니라, ",[18,146,147],{},"클라이언트가 상태 변경을 요청/기대하지 않는다","는 의미가 핵심입니다. 서버 로깅 같은 부수 효과는 있을 수 있어요.",[15,150,151,152,159,160],{},"→ 참고: ",[153,154,158],"a",{"href":155,"rel":156},"https://datatracker.ietf.org/doc/html/rfc9110",[157],"nofollow","HTTP Semantics (IETF)",", ",[153,161,164],{"href":162,"rel":163},"https://developer.mozilla.org/en-US/docs/Glossary/Safe/HTTP",[157],"MDN: Safe (HTTP Methods)",[85,166,168],{"id":167},"_2-idempotent멱등-의도된-효과가-한-번과-같음","2) idempotent(멱등): “의도된 효과”가 한 번과 같음",[15,170,171,172,175],{},"멱등은 “응답이 항상 같다”가 아닙니다. 같은 요청을 반복해도 ",[18,173,174],{},"의도된 효과가 동일","하면 멱등이고, 상황에 따라 상태코드/응답은 달라질 수 있어요.",[15,177,151,178],{},[153,179,182],{"href":180,"rel":181},"https://developer.mozilla.org/en-US/docs/Glossary/Idempotent",[157],"MDN: Idempotent",[85,184,186],{"id":185},"_3-cacheable캐시-가능-캐시가-재사용해도-되는가","3) cacheable(캐시 가능): “캐시가 재사용해도 되는가”",[15,188,189,190,193,194,197],{},"명세는 캐싱 의미를 정의하지만, 실제 동작은 ",[18,191,192],{},"캐시 구현/정책","(브라우저/프록시/CDN/프레임워크)에 따라 달라집니다. 다만 실무에서 캐시는 대체로 ",[18,195,196],{},"GET/HEAD 위주","로 동작하는 편입니다.",[15,199,151,200],{},[153,201,158],{"href":155,"rel":202},[157],[77,204],{},[85,206,208],{"id":207},"구조로-먼저-보기-자동화프리패치재시도캐시와-메서드의-관계","구조로 먼저 보기: 자동화(프리패치/재시도/캐시)와 메서드의 관계",[210,211,216],"pre",{"className":212,"code":213,"language":214,"meta":215,"style":215},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  A[\"요청 발생\u003Cbr/>사용자 클릭/자동화\"] -->|\"메서드 선택\"| B{\"safe인가?\"}\n  B -->|\"Yes\"| C[\"프리패치/크롤러\u003Cbr/>호출 가능\"]\n  B -->|\"No\"| D[\"자동 호출 위험\u003Cbr/>의도치 않은 변경 가능\"]\n\n  A --> E{\"idempotent인가?\"}\n  E -->|\"Yes\"| F[\"통신 실패 시\u003Cbr/>재시도 설계 가능\"]\n  E -->|\"No\"| G[\"자동 재시도 주의\u003Cbr/>중복 처리 위험\"]\n\n  A --> H{\"cacheable인가?\"}\n  H -->|\"Yes\"| I[\"캐시 최적화\u003Cbr/>성능/비용 이점\"]\n  H -->|\"No\"| J[\"캐시 기대 낮음\u003Cbr/>정책/설계 필요\"]\n","mermaid","",[23,217,218,226,232,238,244,251,257,263,269,274,280,286],{"__ignoreMap":215},[219,220,223],"span",{"class":221,"line":222},"line",1,[219,224,225],{},"flowchart LR\n",[219,227,229],{"class":221,"line":228},2,[219,230,231],{},"  A[\"요청 발생\u003Cbr/>사용자 클릭/자동화\"] -->|\"메서드 선택\"| B{\"safe인가?\"}\n",[219,233,235],{"class":221,"line":234},3,[219,236,237],{},"  B -->|\"Yes\"| C[\"프리패치/크롤러\u003Cbr/>호출 가능\"]\n",[219,239,241],{"class":221,"line":240},4,[219,242,243],{},"  B -->|\"No\"| D[\"자동 호출 위험\u003Cbr/>의도치 않은 변경 가능\"]\n",[219,245,247],{"class":221,"line":246},5,[219,248,250],{"emptyLinePlaceholder":249},true,"\n",[219,252,254],{"class":221,"line":253},6,[219,255,256],{},"  A --> E{\"idempotent인가?\"}\n",[219,258,260],{"class":221,"line":259},7,[219,261,262],{},"  E -->|\"Yes\"| F[\"통신 실패 시\u003Cbr/>재시도 설계 가능\"]\n",[219,264,266],{"class":221,"line":265},8,[219,267,268],{},"  E -->|\"No\"| G[\"자동 재시도 주의\u003Cbr/>중복 처리 위험\"]\n",[219,270,272],{"class":221,"line":271},9,[219,273,250],{"emptyLinePlaceholder":249},[219,275,277],{"class":221,"line":276},10,[219,278,279],{},"  A --> H{\"cacheable인가?\"}\n",[219,281,283],{"class":221,"line":282},11,[219,284,285],{},"  H -->|\"Yes\"| I[\"캐시 최적화\u003Cbr/>성능/비용 이점\"]\n",[219,287,289],{"class":221,"line":288},12,[219,290,291],{},"  H -->|\"No\"| J[\"캐시 기대 낮음\u003Cbr/>정책/설계 필요\"]\n",[15,293,294],{},"→ 기대 결과/무엇이 달라졌는지: “왜 GET에 상태 변경을 숨기면 안 되는지”, “왜 POST 자동 재시도가 위험한지”가 한 번에 연결됩니다.",[77,296],{},[80,298,300],{"id":299},"해결-접근","해결 접근",[80,302,304],{"id":303},"메서드별-safe-idempotent-한눈에-보기","메서드별 safe / idempotent 한눈에 보기",[306,307,308,327],"table",{},[309,310,311],"thead",{},[312,313,314,318,321,324],"tr",{},[315,316,317],"th",{},"Method",[315,319,320],{},"Safe",[315,322,323],{},"Idempotent",[315,325,326],{},"실무 감각",[328,329,330,344,360,372,385],"tbody",{},[312,331,332,336,339,341],{},[333,334,335],"td",{},"GET",[333,337,338],{},"✅",[333,340,338],{},[333,342,343],{},"조회(읽기)",[312,345,346,349,352,354],{},[333,347,348],{},"PUT",[333,350,351],{},"❌",[333,353,338],{},[333,355,356,359],{},[18,357,358],{},"같은 리소스를 특정 상태로 “맞춤”","(덮어쓰기/생성)",[312,361,362,365,367,369],{},[333,363,364],{},"DELETE",[333,366,351],{},[333,368,338],{},[333,370,371],{},"삭제(의도된 효과 기준)",[312,373,374,377,379,382],{},[333,375,376],{},"POST",[333,378,351],{},[333,380,381],{},"보장 ❌",[333,383,384],{},"생성/처리/작업(반복 시 중복 위험이 커지기 쉬움)",[312,386,387,390,392,394],{},[333,388,389],{},"PATCH",[333,391,351],{},[333,393,381],{},[333,395,396],{},"부분 수정(설계로 멱등처럼 만들 수는 있음)",[77,398],{},[85,400,402],{"id":401},"선택-규칙실무용","선택 규칙(실무용)",[50,404,405,415,425,435,445],{},[53,406,407,409,410,412,414],{},[18,408,343],{}," → ",[23,411,335],{},[98,413],{},"캐시·링크 공유·프리패치 같은 “웹 최적화 레일”을 그대로 탑니다.",[53,416,417,409,420,422,424],{},[18,418,419],{},"동일 URI 리소스를 “이 상태로 맞춰라”",[23,421,348],{},[98,423],{},"멱등이기 때문에 재시도 설계가 상대적으로 수월합니다.",[53,426,427,409,430,432,434],{},[18,428,429],{},"삭제",[23,431,364],{},[98,433],{},"반복 호출되어도 “삭제 상태로 만든다”는 의도는 동일하게 유지됩니다(응답은 달라질 수 있음).",[53,436,437,409,440,442,444],{},[18,438,439],{},"서버에서 작업을 수행/새 리소스를 생성",[23,441,376],{},[98,443],{},"기본적으로 비멱등으로 보고, 중복 처리/재시도 정책을 별도로 고민합니다.",[53,446,447,409,450,452,454],{},[18,448,449],{},"부분 수정",[23,451,389],{},[98,453],{},"“무엇을 얼마나 바꿀지” 표현 방식에 따라 멱등이 될 수도/아닐 수도 있습니다.",[77,456],{},[85,458,460],{"id":459},"대안비교-자주-헷갈리는-지점-2개","대안/비교 (자주 헷갈리는 지점 2개)",[85,462,464],{"id":463},"비교-1-복잡한-조회-조건을-get으로-보낼까-post로-보낼까","비교 1) “복잡한 조회 조건”을 GET으로 보낼까, POST로 보낼까?",[50,466,467,481],{},[53,468,469,470,473],{},"✅ ",[18,471,472],{},"추천(기본): GET + Query String",[50,474,475,478],{},[53,476,477],{},"장점: 캐시/공유/프리패치/관측(로그)까지 자연스럽게 맞물림",[53,479,480],{},"단점: 조건이 너무 크거나 민감한 경우 설계가 까다로움",[53,482,469,483,21,486,491],{},[18,484,485],{},"대안: POST",[18,487,488],{},[23,489,490],{},"/search",[50,492,493,496],{},[53,494,495],{},"장점: 큰 조건/복잡한 필터를 body로 전달 가능",[53,497,498],{},"단점: 기본적으로 비멱등·캐시 기대가 낮아짐(정책/키 설계 필요)",[500,501,502,505],"blockquote",{},[15,503,504],{},"참고로, GET 요청의 body는 “일반적으로 정의된 의미가 없다”는 점이 명세에서 강조됩니다.",[15,506,151,507],{},[153,508,158],{"href":155,"rel":509},[157],[85,511,513],{"id":512},"비교-2-put-vs-patch-교체replace냐-부분-수정partial이냐","비교 2) PUT vs PATCH: “교체(replace)”냐 “부분 수정(partial)”이냐",[50,515,516,521],{},[53,517,518,520],{},[23,519,348],{},": 전체를 “이 상태로 맞춘다” (멱등)",[53,522,523,525],{},[23,524,389],{},": 일부만 바꾼다 (기본 보장은 비멱등)",[15,527,528,529,532,533,536],{},"예를 들어 ",[18,530,531],{},"수량을 +1 하는 PATCH","는 반복 호출 시 결과가 누적되기 쉬워서 멱등과 거리가 멉니다. 반대로 ",[18,534,535],{},"수량을 3으로 설정","하는 형태는 멱등에 가깝게 설계할 수 있어요.",[77,538],{},[80,540,542],{"id":541},"구현코드","구현(코드)",[15,544,545],{},"아래 예시는 Next.js의 Route Handler로 메서드 의미를 “코드 레벨에서” 고정하는 방식입니다.",[15,547,151,548,159,553],{},[153,549,552],{"href":550,"rel":551},"https://nextjs.org/docs/app/api-reference/file-conventions/route",[157],"Next.js route.js",[153,554,557],{"href":555,"rel":556},"https://nextjs.org/docs/app/getting-started/route-handlers",[157],"Next.js Route Handlers",[85,559,561],{"id":560},"_1-조회는-get-프리패치캐시-친화적으로-열어두기","1) 조회는 GET: 프리패치/캐시 친화적으로 열어두기",[210,563,567],{"className":564,"code":565,"language":566,"meta":215,"style":215},"language-javascript shiki shiki-themes github-dark","// app/api/products/route.js\nexport async function GET(request) {\n  const { searchParams } = new URL(request.url)\n  const q = searchParams.get('q') ?? ''\n\n  // 조회 로직 (DB/외부 API 등)\n  const data = await fetch(`https://example.com/products?q=${encodeURIComponent(q)}`).then(r => r.json())\n\n  r