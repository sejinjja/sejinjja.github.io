9,940],"input",{"disabled":834,"type":941},"checkbox"," ",[18,944,945],{},"입력 크기(n)"," 를 명확히 적었다(예: 배열 길이, 요청 수, DOM 노드 수).",[55,948,950,952,953,956],{"className":949},[937],[939,951],{"disabled":834,"type":941}," 시간 복잡도와 공간 복잡도를 ",[18,954,955],{},"함께"," 적었다.",[55,958,960,962],{"className":959},[937],[939,961],{"disabled":834,"type":941}," 지배 항(가장 큰 항) 기준으로 Big-O를 정리했다.",[55,964,966,968],{"className":965},[937],[939,967],{"disabled":834,"type":941}," 실제 데이터 분포(중복 많음/정렬됨/랜덤 등)에서 병목이 달라질 수 있음을 고려했다.",[55,970,972,974],{"className":971},[937],[939,973],{"disabled":834,"type":941}," 마지막으로 프로파일링/벤치마크로 “체감”을 확인했다.",[41,976],{},[44,978,980],{"id":979},"흔한-실수faq","흔한 실수/FAQ",[88,982,984],{"id":983},"q1-big-o면-실행-시간이-정확히-결정되나요","Q1. Big-O면 실행 시간이 “정확히” 결정되나요?",[15,986,987,988,991,992,994],{},"아닙니다. Big-O는 ",[18,989,990],{},"증가율","을 말합니다. 같은 ",[127,993,199],{},"이어도 상수항, 런타임 최적화, 캐시 히트율에 따라 체감은 달라질 수 있습니다.",[88,996,998],{"id":997},"q2-시간-복잡도만-보면-되지-않나요","Q2. “시간 복잡도만” 보면 되지 않나요?",[15,1000,1001,1002,1005],{},"캐시/메모이제이션/인덱싱은 대부분 ",[18,1003,1004],{},"공간을 더 써서 시간을 줄이는"," 전략입니다. 특히 서버 환경이나 장시간 실행 프로세스에서는 공간을 같이 봐야 안정적입니다.",[88,1007,1009],{"id":1008},"q3-입력이-작으면-복잡도-분석이-의미-없나요","Q3. 입력이 작으면 복잡도 분석이 의미 없나요?",[15,1011,1012],{},"작을수록 상수항이 지배적일 수 있습니다. 그래도 복잡도는 “커졌을 때 무너질 지점”을 미리 보여주는 안전장치 역할을 합니다.",[41,1014],{},[44,1016,1018],{"id":1017},"요약35줄","요약(3~5줄)",[52,1020,1021,1032,1038,1041],{},[55,1022,1023,1024,1027,1028,1031],{},"시간 복잡도는 ",[18,1025,1026],{},"연산 증가율",", 공간 복잡도는 ",[18,1029,1030],{},"메모리 증가율","을 봅니다.",[55,1033,1034,1035,39],{},"Big-O는 불필요한 상세를 걷어내고 ",[18,1036,1037],{},"지배 항만 남기는 표기법",[55,1039,1040],{},"선택은 보통 “복잡도 분석으로 방향 결정 → 실측으로 체감 확인” 순서가 안전합니다.",[55,1042,1043,1044,1047],{},"캐시 같은 최적화는 대개 ",[18,1045,1046],{},"시간↓ 공간↑"," 트레이드오프를 동반합니다.",[41,1049],{},[44,1051,1052],{"id":1052},"결론",[15,1054,1055],{},"실행 시간은 흔들리지만, 복잡도는 흔들리지 않습니다.",[15,1057,1058,1059,1062],{},"그래서 알고리즘 선택의 출발점은 ",[18,1060,1061],{},"시간/공간 복잡도로 증가율을 고정하는 것","입니다. 그 다음에야 비로소 프로파일링으로 “현실에서 얼마나 빠른지”를 확인하면 됩니다.",[41,1064],{},[44,1066,1068],{"id":1067},"참고공식-문서-링크","참고(공식 문서 링크)",[52,1070,1071,1079,1086,1093,1100,1107],{},[55,1072,1073],{},[516,1074,1078],{"href":1075,"rel":1076},"https://nextjs.org/docs",[1077],"nofollow","Next.js Docs",[55,1080,1081],{},[516,1082,1085],{"href":1083,"rel":1084},"https://react.dev/",[1077],"React Docs",[55,1087,1088],{},[516,1089,1092],{"href":1090,"rel":1091},"https://developer.mozilla.org/",[1077],"MDN Web Docs",[55,1094,1095],{},[516,1096,1099],{"href":1097,"rel":1098},"https://web.dev/",[1077],"web.dev",[55,1101,1102],{},[516,1103,1106],{"href":1104,"rel":1105},"https://nodejs.org/api/perf_hooks.html",[1077],"Node.js Performance Hooks",[55,1108,1109],{},[516,1110,1113],{"href":1111,"rel":1112},"https://en.wikipedia.org/wiki/Big_O_notation",[1077],"Big O notation (Wikipedia)",[1115,1116,1117],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .s9osk, html code.shiki .s9osk{--shiki-default:#FFAB70}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}",{"title":125,"searchDepth":139,"depth":139,"links":1119},[1120,1121,1125,1126,1134,1135,1140,1141,1142],{"id":46,"depth":139,"text":47},{"id":85,"depth":139,"text":86,"children":1122},[1123,1124],{"id":90,"depth":145,"text":91},{"id":180,"depth":145,"text":181},{"id":224,"depth":139,"text":225},{"id":274,"depth":139,"text":275,"children":1127},[1128,1129,1130,1131,1132,1133],{"id":285,"depth":145,"text":286},{"id":398,"depth":145,"text":399},{"id":498,"depth":145,"text":499},{"id":619,"depth":145,"text":620},{"id":721,"depth":145,"text":722},{"id":805,"depth":145,"text":806},{"id":928,"depth":139,"text":929},{"id":979,"depth":139,"text":980,"children":1136},[1137,1138,1139],{"id":983,"depth":145,"text":984},{"id":997,"depth":145,"text":998},{"id":1008,"depth":145,"text":1009},{"id":1017,"depth":139,"text":1018},{"id":1052,"depth":139,"text":1052},{"id":1067,"depth":139,"text":1068},"2026-02-10","알고리즘 비교는 실행 시간 측정보다, 입력 크기에 따라 얼마나 빨리 커지는지(시간/공간 복잡도)를 먼저 고정하는 게 안정적입니다. Big-O는 불필요한 상세를 걷어내고 지배 항만 남기는 표기법으로, 복잡도 분석으로 방향을 결정한 후 실측으로 체감을 확인하는 순서가 안전합니다.","md",{},"303c01ed-7f98-8087-92ab-c60f628973ef","/writing/time-space-complexity-big-o",{"title":5,"description":1144},"notion","writing/time-space-complexity-big-o",[291],"vJv2fweazbtODajlmZmSpYcitQFjHTwhqCZY4UCsOgg",1772640985916]