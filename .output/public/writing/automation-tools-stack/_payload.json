[{"data":1,"prerenderedAt":1330},["ShallowReactive",2],{"writing:meta:/writing/automation-tools-stack":3},{"id":4,"title":5,"body":6,"date":1319,"description":20,"extension":1320,"meta":1321,"navigation":214,"notionPageId":1322,"path":1323,"seo":1324,"source":1325,"stem":1326,"tags":1327,"__hash__":1329},"content/writing/automation-tools-stack.md","반복을 스크립트로 바꿔라: 게으른 개발자의 자동화 툴 스택",{"type":7,"value":8,"toc":1297},"minimark",[9,13,21,24,46,49,54,57,74,80,82,86,89,96,150,153,155,159,166,171,178,183,292,308,315,318,341,343,347,350,355,378,381,383,402,404,408,411,416,440,443,445,453,455,459,462,467,503,510,512,517,519,523,526,531,590,593,595,615,617,621,624,633,735,738,741,762,764,769,771,775,778,783,847,850,852,860,862,866,869,889,892,894,898,901,924,927,929,934,936,940,943,961,964,966,970,973,988,1065,1072,1074,1078,1118,1120,1124,1129,1132,1137,1140,1145,1162,1164,1168,1188,1190,1193,1196,1202,1205,1207,1211,1293],[10,11,5],"h1",{"id":12},"반복을-스크립트로-바꿔라-게으른-개발자의-자동화-툴-스택",[14,15,16,17],"p",{},"한 문장 결론: ",[18,19,20],"strong",{},"반복되는 작업을 \"명령어 → 자동화 → 검증\" 흐름으로 고정하면, 개발 속도는 유지하고 실수는 줄일 수 있습니다.",[14,22,23],{},"자동화가 중요한 이유는 단순히 \"편해서\"가 아닙니다.",[25,26,27,34,40],"ul",{},[28,29,30,33],"li",{},[18,31,32],{},"UX/품질",": 테스트·린트·포맷이 자동으로 돌아가면, 릴리즈 품질이 일정해집니다.",[28,35,36,39],{},[18,37,38],{},"성능/안정성",": 빌드·번들·의존성 업데이트를 규칙화하면, 갑작스러운 실패가 줄어듭니다.",[28,41,42,45],{},[18,43,44],{},"유지보수",": \"누가/언제/어떻게\" 실행했는지 코드로 남아 팀 합의가 쉬워집니다.",[47,48],"hr",{},[50,51,53],"h2",{"id":52},"배경문제","배경/문제",[14,55,56],{},"개발하다 보면 이런 순간이 반복됩니다.",[25,58,59,62,65,68,71],{},[28,60,61],{},"매번 같은 긴 명령어를 복사/붙여넣기 한다.",[28,63,64],{},"저장할 때마다 테스트/빌드를 까먹는다.",[28,66,67],{},"커밋 뒤에야 포맷/린트/시크릿 이슈를 발견한다.",[28,69,70],{},"의존성 업데이트가 밀려서 갑자기 깨진다.",[28,72,73],{},"터미널 세션 구성이 매일 리셋된다.",[14,75,76,77],{},"포인트는 하나입니다. ",[18,78,79],{},"사람이 반복하면 언젠가 실수합니다. 반복은 도구로 넘기는 게 맞습니다.",[47,81],{},[50,83,85],{"id":84},"핵심-개념","핵심 개념",[14,87,88],{},"자동화를 \"한 방에 해결\"하려고 하면 오히려 복잡해집니다.",[14,90,91,92,95],{},"대신 아래처럼 ",[18,93,94],{},"레이어(층)"," 로 나눠두면 유지보수가 쉬워집니다.",[97,98,103],"pre",{"className":99,"code":100,"language":101,"meta":102,"style":102},"language-mermaid shiki shiki-themes github-dark","flowchart TB\n  A[\"로컬 반복 작업\u003Cbr/>명령어/세션/이동\"] -->|\"표준화\"| B[\"프로젝트 자동화\u003Cbr/>Task runner\"]\n  B -->|\"검증 강제\"| C[\"커밋 전 자동 검수\u003Cbr/>hooks\"]\n  B -->|\"변경 감지\"| D[\"파일 변경 트리거\u003Cbr/>watcher\"]\n  C -->|\"원격 실행\"| E[\"CI/CD\u003Cbr/>워크플로우\"]\n  E -->|\"업데이트 자동화\"| F[\"의존성 PR 자동 생성\u003Cbr/>Renovate\"]\n  E -->|\"운영 자동화\"| G[\"서버/작업 스케줄링\u003Cbr/>Ansible·Cron\"]\n","mermaid","",[104,105,106,114,120,126,132,138,144],"code",{"__ignoreMap":102},[107,108,111],"span",{"class":109,"line":110},"line",1,[107,112,113],{},"flowchart TB\n",[107,115,117],{"class":109,"line":116},2,[107,118,119],{},"  A[\"로컬 반복 작업\u003Cbr/>명령어/세션/이동\"] -->|\"표준화\"| B[\"프로젝트 자동화\u003Cbr/>Task runner\"]\n",[107,121,123],{"class":109,"line":122},3,[107,124,125],{},"  B -->|\"검증 강제\"| C[\"커밋 전 자동 검수\u003Cbr/>hooks\"]\n",[107,127,129],{"class":109,"line":128},4,[107,130,131],{},"  B -->|\"변경 감지\"| D[\"파일 변경 트리거\u003Cbr/>watcher\"]\n",[107,133,135],{"class":109,"line":134},5,[107,136,137],{},"  C -->|\"원격 실행\"| E[\"CI/CD\u003Cbr/>워크플로우\"]\n",[107,139,141],{"class":109,"line":140},6,[107,142,143],{},"  E -->|\"업데이트 자동화\"| F[\"의존성 PR 자동 생성\u003Cbr/>Renovate\"]\n",[107,145,147],{"class":109,"line":146},7,[107,148,149],{},"  E -->|\"운영 자동화\"| G[\"서버/작업 스케줄링\u003Cbr/>Ansible·Cron\"]\n",[14,151,152],{},"→ 기대 결과/무엇이 달라졌는지: 자동화 포인트가 겹치지 않고 역할이 분리됩니다. 로컬/커밋/CI/운영 단계가 한눈에 정리돼 \"어디서 무엇을 돌리는지\"가 명확해집니다.",[47,154],{},[50,156,158],{"id":157},"해결-접근","해결 접근",[14,160,161,162,165],{},"아래 10가지는 \"게으름\"이 아니라 ",[18,163,164],{},"반복을 시스템으로 바꾸는 장치","입니다.",[167,168,170],"h3",{"id":169},"_1-taskfile-프로젝트-명령어를-한-곳에-모으기","1) Taskfile — 프로젝트 명령어를 한 곳에 모으기",[14,172,173,174,177],{},"Makefile 대체재로 많이 쓰이는 task runner입니다. 프로젝트에서 자주 쓰는 명령을 ",[18,175,176],{},"짧은 별칭으로 고정","합니다.",[25,179,180],{},[28,181,182],{},"기대 효과: 긴 커맨드를 외우지 않아도 되고, 팀이 동일한 실행 경로를 갖습니다.",[97,184,188],{"className":185,"code":186,"language":187,"meta":102,"style":102},"language-yaml shiki shiki-themes github-dark","# Taskfile.yml\nversion: \"3\"\n\ntasks:\n  dev:\n    cmds:\n      - npm run dev\n  build:\n    cmds:\n      - npm run build\n  lint:\n    cmds:\n      - npm run lint\n","yaml",[104,189,190,196,210,216,224,231,238,246,254,261,269,277,284],{"__ignoreMap":102},[107,191,192],{"class":109,"line":110},[107,193,195],{"class":194},"sAwPA","# Taskfile.yml\n",[107,197,198,202,206],{"class":109,"line":116},[107,199,201],{"class":200},"s4JwU","version",[107,203,205],{"class":204},"s95oV",": ",[107,207,209],{"class":208},"sU2Wk","\"3\"\n",[107,211,212],{"class":109,"line":122},[107,213,215],{"emptyLinePlaceholder":214},true,"\n",[107,217,218,221],{"class":109,"line":128},[107,219,220],{"class":200},"tasks",[107,222,223],{"class":204},":\n",[107,225,226,229],{"class":109,"line":134},[107,227,228],{"class":200},"  dev",[107,230,223],{"class":204},[107,232,233,236],{"class":109,"line":140},[107,234,235],{"class":200},"    cmds",[107,237,223],{"class":204},[107,239,240,243],{"class":109,"line":146},[107,241,242],{"class":204},"      - ",[107,244,245],{"class":208},"npm run dev\n",[107,247,249,252],{"class":109,"line":248},8,[107,250,251],{"class":200},"  build",[107,253,223],{"class":204},[107,255,257,259],{"class":109,"line":256},9,[107,258,235],{"class":200},[107,260,223],{"class":204},[107,262,264,266],{"class":109,"line":263},10,[107,265,242],{"class":204},[107,267,268],{"class":208},"npm run build\n",[107,270,272,275],{"class":109,"line":271},11,[107,273,274],{"class":200},"  lint",[107,276,223],{"class":204},[107,278,280,282],{"class":109,"line":279},12,[107,281,235],{"class":200},[107,283,223],{"class":204},[107,285,287,289],{"class":109,"line":286},13,[107,288,242],{"class":204},[107,290,291],{"class":208},"npm run lint\n",[97,293,297],{"className":294,"code":295,"language":296,"meta":102,"style":102},"language-bash shiki shiki-themes github-dark","task dev\n","bash",[104,298,299],{"__ignoreMap":102},[107,300,301,305],{"class":109,"line":110},[107,302,304],{"class":303},"svObZ","task",[107,306,307],{"class":208}," dev\n",[14,309,310,311,314],{},"→ 기대 결과/무엇이 달라졌는지: ",[104,312,313],{},"npm run ..."," 조합이 흩어지지 않고 Taskfile로 수렴합니다. \"실행 방법\"이 문서가 아니라 코드가 됩니다.",[14,316,317],{},"대안/비교:",[25,319,320,334],{},[28,321,322,325,326,329,330,333],{},[104,323,324],{},"package.json","의 ",[104,327,328],{},"scripts","만으로도 가능하지만, ",[18,331,332],{},"복잡한 흐름(조건/의존 작업/공통 변수)"," 이 생기면 Taskfile이 더 읽기 쉬울 수 있습니다.",[28,335,336,337,340],{},"Makefile은 강력하지만, 팀이 크로스 플랫폼을 타면 ",[18,338,339],{},"셸/환경 차이","가 발목을 잡을 수 있습니다(환경에 따라 다름).",[47,342],{},[167,344,346],{"id":345},"_2-watchman-파일-변경을-트리거로-테스트빌드-돌리기","2) Watchman — 파일 변경을 트리거로 테스트/빌드 돌리기",[14,348,349],{},"저장할 때마다 특정 명령을 실행해주는 watcher입니다.",[25,351,352],{},[28,353,354],{},"기대 효과: \"테스트 돌렸나?\"를 머리로 기억하지 않게 됩니다.",[97,356,358],{"className":294,"code":357,"language":296,"meta":102,"style":102},"watchman-make -p \"*.js\" --run \"npm test\"\n",[104,359,360],{"__ignoreMap":102},[107,361,362,365,369,372,375],{"class":109,"line":110},[107,363,364],{"class":303},"watchman-make",[107,366,368],{"class":367},"sDLfK"," -p",[107,370,371],{"class":208}," \"*.js\"",[107,373,374],{"class":367}," --run",[107,376,377],{"class":208}," \"npm test\"\n",[14,379,380],{},"→ 기대 결과/무엇이 달라졌는지: 파일 저장/변경이 곧 자동 실행으로 연결됩니다. 반복 클릭/수동 실행이 줄어듭니다.",[14,382,317],{},[25,384,385,399],{},[28,386,387,388,390,391,394,395,398],{},"간단한 경우는 ",[104,389,324],{},"에 watcher 스크립트를 두고 ",[104,392,393],{},"nodemon",", ",[104,396,397],{},"tsx --watch"," 같은 도구를 쓰는 쪽이 더 가벼울 수 있습니다(환경에 따라 다름).",[28,400,401],{},"Next.js 개발 서버 자체도 변경 감지를 포함하지만, \"테스트/특정 검증\"까지 자동화하려면 별도 트리거가 유용합니다.",[47,403],{},[167,405,407],{"id":406},"_3-tmux-터미널-세션을-재현-가능한-상태로-만들기","3) tmux — 터미널 세션을 \"재현 가능한 상태\"로 만들기",[14,409,410],{},"터미널 탭/분할/세션을 구성해두고 재개하는 도구입니다.",[25,412,413],{},[28,414,415],{},"기대 효과: 매일 \"백엔드/프런트/로그/DB\" 같은 세팅을 다시 만들지 않습니다.",[97,417,419],{"className":294,"code":418,"language":296,"meta":102,"style":102},"# 예: 세션 생성 후 분할/커맨드 실행은 개인 워크플로우에 맞게 구성\ntmux new -s app\n",[104,420,421,426],{"__ignoreMap":102},[107,422,423],{"class":109,"line":110},[107,424,425],{"class":194},"# 예: 세션 생성 후 분할/커맨드 실행은 개인 워크플로우에 맞게 구성\n",[107,427,428,431,434,437],{"class":109,"line":116},[107,429,430],{"class":303},"tmux",[107,432,433],{"class":208}," new",[107,435,436],{"class":367}," -s",[107,438,439],{"class":208}," app\n",[14,441,442],{},"→ 기대 결과/무엇이 달라졌는지: 터미널 작업이 \"그날의 감\"이 아니라 \"저장 가능한 구성\"이 됩니다.",[14,444,317],{},[25,446,447,450],{},[28,448,449],{},"GUI 터미널의 워크스페이스 기능을 쓰는 방법도 있습니다.",[28,451,452],{},"SSH 중심 업무라면 tmux가 특히 강합니다(환경에 따라 다름).",[47,454],{},[167,456,458],{"id":457},"_4-renovate-의존성-업데이트를-pr로-자동-생성","4) Renovate — 의존성 업데이트를 PR로 자동 생성",[14,460,461],{},"의존성 업데이트를 사람이 수동으로 올리면 결국 밀립니다. Renovate는 업데이트 PR을 자동으로 만들고, 변경 내용을 한 눈에 보이게 합니다.",[25,463,464],{},[28,465,466],{},"기대 효과: \"언젠가 올려야지\"가 \"PR로 도착\"합니다.",[97,468,472],{"className":469,"code":470,"language":471,"meta":102,"style":102},"language-json shiki shiki-themes github-dark","// renovate.json\n{\n  \"extends\": [\"config:base\"]\n}\n","json",[104,473,474,479,484,498],{"__ignoreMap":102},[107,475,476],{"class":109,"line":110},[107,477,478],{"class":194},"// renovate.json\n",[107,480,481],{"class":109,"line":116},[107,482,483],{"class":204},"{\n",[107,485,486,489,492,495],{"class":109,"line":122},[107,487,488],{"class":367},"  \"extends\"",[107,490,491],{"class":204},": [",[107,493,494],{"class":208},"\"config:base\"",[107,496,497],{"class":204},"]\n",[107,499,500],{"class":109,"line":128},[107,501,502],{"class":204},"}\n",[14,504,505,506,509],{},"→ 기대 결과/무엇이 달라졌는지: 의존성 업데이트가 이슈가 아니라 ",[18,507,508],{},"리뷰 가능한 PR 단위","로 관리됩니다.",[14,511,317],{},[25,513,514],{},[28,515,516],{},"GitHub의 Dependabot도 선택지입니다. 팀 운영 방식(스케줄/규칙/세분화)에 따라 Renovate가 더 세밀할 수 있습니다(환경에 따라 다름).",[47,518],{},[167,520,522],{"id":521},"_5-pre-commit-커밋-전에-자동-사전-검수-강제","5) pre-commit — 커밋 전에 \"자동 사전 검수\" 강제",[14,524,525],{},"커밋 훅으로 린트/포맷/시크릿 탐지/테스트 등을 자동화합니다.",[25,527,528],{},[28,529,530],{},"기대 효과: 깨지는 커밋이 원격 저장소에 올라가기 전에 막힙니다.",[97,532,534],{"className":185,"code":533,"language":187,"meta":102,"style":102},"# .pre-commit-config.yaml\nrepos:\n  - repo: https://github.com/psf/black\n    rev: 23.9b0\n    hooks:\n      - id: black\n",[104,535,536,541,548,561,571,578],{"__ignoreMap":102},[107,537,538],{"class":109,"line":110},[107,539,540],{"class":194},"# .pre-commit-config.yaml\n",[107,542,543,546],{"class":109,"line":116},[107,544,545],{"class":200},"repos",[107,547,223],{"class":204},[107,549,550,553,556,558],{"class":109,"line":122},[107,551,552],{"class":204},"  - ",[107,554,555],{"class":200},"repo",[107,557,205],{"class":204},[107,559,560],{"class":208},"https://github.com/psf/black\n",[107,562,563,566,568],{"class":109,"line":128},[107,564,565],{"class":200},"    rev",[107,567,205],{"class":204},[107,569,570],{"class":208},"23.9b0\n",[107,572,573,576],{"class":109,"line":134},[107,574,575],{"class":200},"    hooks",[107,577,223],{"class":204},[107,579,580,582,585,587],{"class":109,"line":140},[107,581,242],{"class":204},[107,583,584],{"class":200},"id",[107,586,205],{"class":204},[107,588,589],{"class":208},"black\n",[14,591,592],{},"→ 기대 결과/무엇이 달라졌는지: \"커밋 후에 고치는 흐름\"이 줄어들고, 커밋 자체가 더 신뢰 가능한 단위가 됩니다.",[14,594,317],{},[25,596,597,608],{},[28,598,599,600,603,604,607],{},"JavaScript/Next.js 중심이면 ",[104,601,602],{},"lint-staged + husky"," 조합이나, ",[104,605,606],{},"lefthook"," 같은 도구로 동일한 목적을 달성할 수 있습니다(환경에 따라 다름).",[28,609,610,611,614],{},"어떤 방식을 쓰든 핵심은 ",[18,612,613],{},"\"커밋 전에 자동으로 실패시키는 경계\""," 를 만드는 것입니다.",[47,616],{},[167,618,620],{"id":619},"_6-github-actions-cicd를-리포지토리-안으로-가져오기","6) GitHub Actions — CI/CD를 리포지토리 안으로 가져오기",[14,622,623],{},"테스트/빌드/배포를 커밋 이벤트에 연결합니다.",[25,625,626],{},[28,627,628,629,632],{},"기대 효과: 개인 PC가 아니라 ",[18,630,631],{},"클라우드에서 동일한 절차","로 검증됩니다.",[97,634,636],{"className":185,"code":635,"language":187,"meta":102,"style":102},"# .github/workflows/ci.yml\nname: CI\non: [push]\n\njobs:\n  test:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: npm ci\n      - run: npm test\n",[104,637,638,643,653,665,669,676,683,693,700,712,724],{"__ignoreMap":102},[107,639,640],{"class":109,"line":110},[107,641,642],{"class":194},"# .github/workflows/ci.yml\n",[107,644,645,648,650],{"class":109,"line":116},[107,646,647],{"class":200},"name",[107,649,205],{"class":204},[107,651,652],{"class":208},"CI\n",[107,654,655,658,660,663],{"class":109,"line":122},[107,656,657],{"class":367},"on",[107,659,491],{"class":204},[107,661,662],{"class":208},"push",[107,664,497],{"class":204},[107,666,667],{"class":109,"line":128},[107,668,215],{"emptyLinePlaceholder":214},[107,670,671,674],{"class":109,"line":134},[107,672,673],{"class":200},"jobs",[107,675,223],{"class":204},[107,677,678,681],{"class":109,"line":140},[107,679,680],{"class":200},"  test",[107,682,223],{"class":204},[107,684,685,688,690],{"class":109,"line":146},[107,686,687],{"class":200},"    runs-on",[107,689,205],{"class":204},[107,691,692],{"class":208},"ubuntu-latest\n",[107,694,695,698],{"class":109,"line":248},[107,696,697],{"class":200},"    steps",[107,699,223],{"class":204},[107,701,702,704,707,709],{"class":109,"line":256},[107,703,242],{"class":204},[107,705,706],{"class":200},"uses",[107,708,205],{"class":204},[107,710,711],{"class":208},"actions/checkout@v4\n",[107,713,714,716,719,721],{"class":109,"line":263},[107,715,242],{"class":204},[107,717,718],{"class":200},"run",[107,720,205],{"class":204},[107,722,723],{"class":208},"npm ci\n",[107,725,726,728,730,732],{"class":109,"line":271},[107,727,242],{"class":204},[107,729,718],{"class":200},[107,731,205],{"class":204},[107,733,734],{"class":208},"npm test\n",[14,736,737],{},"→ 기대 결과/무엇이 달라졌는지: \"내 컴퓨터에서는 되는데…\" 상황이 줄어듭니다. PR/푸시 단위로 일관된 검증이 가능합니다.",[14,739,740],{},"Next.js 문맥 보강:",[25,742,743],{},[28,744,745,746,749,750,753,754,761],{},"Next.js 프로젝트라면 ",[104,747,748],{},"npm run build","를 CI에 포함해 ",[18,751,752],{},"빌드 단계에서 터지는 문제","를 일찍 잡는 흐름이 흔합니다. (공식 가이드는 ",[755,756,760],"a",{"href":757,"rel":758},"https://nextjs.org/docs",[759],"nofollow","Next.js Docs"," 참고)",[14,763,317],{},[25,765,766],{},[28,767,768],{},"GitLab CI, CircleCI 등도 동일한 목적을 수행합니다. 조직/권한/비용/운영 방식에 따라 선택이 달라집니다(환경에 따라 다름).",[47,770],{},[167,772,774],{"id":773},"_7-ansible-서버-설정을-명령어-묶음이-아니라-선언으로-관리","7) Ansible — 서버 설정을 \"명령어 묶음\"이 아니라 \"선언\"으로 관리",[14,776,777],{},"서버에 손으로 접속해 설정을 바꾸는 순간, 기록과 재현성이 무너집니다. Ansible은 이를 플레이북으로 고정합니다.",[25,779,780],{},[28,781,782],{},"기대 효과: 서버 변경이 사람의 손이 아니라 코드로 남습니다.",[97,784,786],{"className":185,"code":785,"language":187,"meta":102,"style":102},"- hosts: server\n  tasks:\n    - name: Install nginx\n      apt:\n        name: nginx\n        state: present\n",[104,787,788,801,808,820,827,837],{"__ignoreMap":102},[107,789,790,793,796,798],{"class":109,"line":110},[107,791,792],{"class":204},"- ",[107,794,795],{"class":200},"hosts",[107,797,205],{"class":204},[107,799,800],{"class":208},"server\n",[107,802,803,806],{"class":109,"line":116},[107,804,805],{"class":200},"  tasks",[107,807,223],{"class":204},[107,809,810,813,815,817],{"class":109,"line":122},[107,811,812],{"class":204},"    - ",[107,814,647],{"class":200},[107,816,205],{"class":204},[107,818,819],{"class":208},"Install nginx\n",[107,821,822,825],{"class":109,"line":128},[107,823,824],{"class":200},"      apt",[107,826,223],{"class":204},[107,828,829,832,834],{"class":109,"line":134},[107,830,831],{"class":200},"        name",[107,833,205],{"class":204},[107,835,836],{"class":208},"nginx\n",[107,838,839,842,844],{"class":109,"line":140},[107,840,841],{"class":200},"        state",[107,843,205],{"class":204},[107,845,846],{"class":208},"present\n",[14,848,849],{},"→ 기대 결과/무엇이 달라졌는지: 서버 설정이 문서가 아니라 코드로 재현됩니다. 새 서버에도 같은 구성을 빠르게 적용할 수 있습니다.",[14,851,317],{},[25,853,854,857],{},[28,855,856],{},"Terraform 같은 IaC 도구는 \"인프라 생성\"에 강하고, Ansible은 \"구성 관리\"에 강한 편입니다(환경에 따라 다름).",[28,858,859],{},"Next.js를 서버리스/플랫폼 배포로 운영한다면 Ansible의 필요도가 낮아질 수 있습니다(환경에 따라 다름).",[47,861],{},[167,863,865],{"id":864},"_8-zoxide-자주-가는-폴더를-학습하는-cd-대체재","8) Zoxide — \"자주 가는 폴더\"를 학습하는 cd 대체재",[14,867,868],{},"긴 경로를 직접 입력하는 시간은 생각보다 큽니다. Zoxide는 방문 기록을 학습해 빠르게 이동합니다.",[97,870,872],{"className":294,"code":871,"language":296,"meta":102,"style":102},"z projects\nz repo-name\n",[104,873,874,882],{"__ignoreMap":102},[107,875,876,879],{"class":109,"line":110},[107,877,878],{"class":303},"z",[107,880,881],{"class":208}," projects\n",[107,883,884,886],{"class":109,"line":116},[107,885,878],{"class":303},[107,887,888],{"class":208}," repo-name\n",[14,890,891],{},"→ 기대 결과/무엇이 달라졌는지: 경로 입력량이 줄고, 이동이 빨라집니다. \"어디였지?\" 탐색 시간이 줄어듭니다.",[47,893],{},[167,895,897],{"id":896},"_9-cron-bash-정해진-시간에-작업을-자동-실행","9) Cron + Bash — 정해진 시간에 작업을 자동 실행",[14,899,900],{},"운영에서 주기적으로 해야 하는 작업(백업/정리/알림)을 스케줄링합니다.",[97,902,904],{"className":294,"code":903,"language":296,"meta":102,"style":102},"0 2 * * * /home/user/backup.sh\n",[104,905,906],{"__ignoreMap":102},[107,907,908,911,914,917,919,921],{"class":109,"line":110},[107,909,910],{"class":303},"0",[107,912,913],{"class":367}," 2",[107,915,916],{"class":367}," *",[107,918,916],{"class":367},[107,920,916],{"class":367},[107,922,923],{"class":208}," /home/user/backup.sh\n",[14,925,926],{},"→ 기대 결과/무엇이 달라졌는지: \"기억해서 실행\"이 아니라 \"시간이 실행\"합니다. 사람이 잠든 시간에도 작업이 진행됩니다.",[14,928,740],{},[25,930,931],{},[28,932,933],{},"서버리스/플랫폼 배포라면 Cron은 플랫폼 스케줄러로 대체될 수 있습니다(환경에 따라 달라질 수 있습니다). 핵심은 \"정기 작업을 코드로 관리\"하는 것입니다.",[47,935],{},[167,937,939],{"id":938},"_10-espanso-반복-입력을-트리거로-치환하는-텍스트-확장기","10) Espanso — 반복 입력을 트리거로 치환하는 텍스트 확장기",[14,941,942],{},"반복되는 서명/템플릿/UUID 같은 입력을 단축 트리거로 바꿉니다.",[97,944,949],{"className":945,"code":946,"language":947,"meta":948,"style":102},"language-plain shiki shiki-themes github-dark","/sig  ->  Kind regards, ...\n/uuid ->  (UUID 자동 생성)\n","plain","text",[104,950,951,956],{"__ignoreMap":102},[107,952,953],{"class":109,"line":110},[107,954,955],{},"/sig  ->  Kind regards, ...\n",[107,957,958],{"class":109,"line":116},[107,959,960],{},"/uuid ->  (UUID 자동 생성)\n",[14,962,963],{},"→ 기대 결과/무엇이 달라졌는지: 반복 입력이 줄고, 템플릿 품질이 일정해집니다. 같은 문장을 여러 번 쓰는 피로가 감소합니다.",[47,965],{},[50,967,969],{"id":968},"구현코드","구현(코드)",[14,971,972],{},"Next.js 프로젝트 기준으로 \"최소 세트\"를 잡으면 아래 조합이 실무에서 자주 먹힙니다.",[974,975,976,979,982,985],"ol",{},[28,977,978],{},"Taskfile로 로컬 명령 통합",[28,980,981],{},"pre-commit(또는 대체 도구)로 커밋 전 검증",[28,983,984],{},"GitHub Actions로 원격 CI 고정",[28,986,987],{},"Renovate로 의존성 PR 자동 생성",[97,989,991],{"className":185,"code":990,"language":187,"meta":102,"style":102},"# Taskfile.yml (예시)\nversion: \"3\"\n\ntasks:\n  dev:\n    cmds:\n      - npm run dev\n  verify:\n    cmds:\n      - npm run lint\n      - npm test\n      - npm run build\n",[104,992,993,998,1006,1010,1016,1022,1028,1034,1041,1047,1053,1059],{"__ignoreMap":102},[107,994,995],{"class":109,"line":110},[107,996,997],{"class":194},"# Taskfile.yml (예시)\n",[107,999,1000,1002,1004],{"class":109,"line":116},[107,1001,201],{"class":200},[107,1003,205],{"class":204},[107,1005,209],{"class":208},[107,1007,1008],{"class":109,"line":122},[107,1009,215],{"emptyLinePlaceholder":214},[107,1011,1012,1014],{"class":109,"line":128},[107,1013,220],{"class":200},[107,1015,223],{"class":204},[107,1017,1018,1020],{"class":109,"line":134},[107,1019,228],{"class":200},[107,1021,223],{"class":204},[107,1023,1024,1026],{"class":109,"line":140},[107,1025,235],{"class":200},[107,1027,223],{"class":204},[107,1029,1030,1032],{"class":109,"line":146},[107,1031,242],{"class":204},[107,1033,245],{"class":208},[107,1035,1036,1039],{"class":109,"line":248},[107,1037,1038],{"class":200},"  verify",[107,1040,223],{"class":204},[107,1042,1043,1045],{"class":109,"line":256},[107,1044,235],{"class":200},[107,1046,223],{"class":204},[107,1048,1049,1051],{"class":109,"line":263},[107,1050,242],{"class":204},[107,1052,291],{"class":208},[107,1054,1055,1057],{"class":109,"line":271},[107,1056,242],{"class":204},[107,1058,734],{"class":208},[107,1060,1061,1063],{"class":109,"line":279},[107,1062,242],{"class":204},[107,1064,268],{"class":208},[14,1066,1067,1068,1071],{},"→ 기대 결과/무엇이 달라졌는지: 로컬에서 ",[104,1069,1070],{},"task verify"," 하나로 품질 게이트가 고정됩니다. 팀원마다 다른 실행 순서가 줄어듭니다.",[47,1073],{},[50,1075,1077],{"id":1076},"검증-방법체크리스트","검증 방법(체크리스트)",[25,1079,1082,1094,1100,1106,1112],{"className":1080},[1081],"contains-task-list",[28,1083,1086,1090,1091,1093],{"className":1084},[1085],"task-list-item",[1087,1088],"input",{"disabled":214,"type":1089},"checkbox"," ",[104,1092,1070],{},"가 로컬에서 한 번에 통과한다.",[28,1095,1097,1099],{"className":1096},[1085],[1087,1098],{"disabled":214,"type":1089}," 커밋 시 포맷/린트/테스트 중 하나라도 실패하면 커밋이 막힌다.",[28,1101,1103,1105],{"className":1102},[1085],[1087,1104],{"disabled":214,"type":1089}," PR을 올리면 CI가 자동으로 돌아가고, 실패 로그가 남는다.",[28,1107,1109,1111],{"className":1108},[1085],[1087,1110],{"disabled":214,"type":1089}," 의존성 업데이트가 PR로 주기적으로 생성되고, 머지가 가능한 형태로 쪼개져 있다.",[28,1113,1115,1117],{"className":1114},[1085],[1087,1116],{"disabled":214,"type":1089}," (선택) 저장/변경 트리거로 테스트가 자동 실행되어 \"수동 실행\"이 줄었다.",[47,1119],{},[50,1121,1123],{"id":1122},"흔한-실수faq","흔한 실수/FAQ",[14,1125,1126],{},[18,1127,1128],{},"Q. 자동화가 너무 많아져서 오히려 느려졌어요.",[14,1130,1131],{},"A. 로컬 훅은 \"빠른 검증\" 위주로 두고, 무거운 검증(전체 테스트/빌드)은 CI로 넘기는 방식이 흔합니다. 팀/레포 규모에 따라 달라질 수 있습니다.",[14,1133,1134],{},[18,1135,1136],{},"Q. 커밋 훅이 팀원마다 다르게 동작해요.",[14,1138,1139],{},"A. 훅 도구 선택보다 중요한 건 \"설치/실행 경로를 코드로 고정\"하는 것입니다. Taskfile로 통일하거나, 리포지토리 내 스크립트로 실행 경로를 맞추는 편이 안정적입니다.",[14,1141,1142],{},[18,1143,1144],{},"Q. Next.js에서 서버/클라이언트 경계 때문에 자동화가 복잡해져요.",[14,1146,1147,1148,1151,1152,1155,1156,1161],{},"A. 자동화는 런타임 경계와 직접 충돌하지 않습니다. 다만 CI에 ",[104,1149,1150],{},"build","를 포함해두면 서버/클라이언트 관련 오류를 조기에 발견하기 좋습니다. 자세한 구조는 ",[755,1153,760],{"href":757,"rel":1154},[759],"와 ",[755,1157,1160],{"href":1158,"rel":1159},"https://react.dev/",[759],"React Docs","를 참고하세요.",[47,1163],{},[50,1165,1167],{"id":1166},"요약35줄","요약(3~5줄)",[25,1169,1170,1176,1179,1182],{},[28,1171,1172,1173,165],{},"자동화는 \"게으름\"이 아니라 ",[18,1174,1175],{},"반복을 시스템으로 바꾸는 설계",[28,1177,1178],{},"Taskfile로 로컬 실행을 통합하고, 커밋 훅으로 품질을 강제하고, CI로 원격 검증을 고정합니다.",[28,1180,1181],{},"Renovate 같은 도구로 의존성 업데이트를 PR로 전환하면 운영 부담이 줄어듭니다.",[28,1183,1184,1185,165],{},"중요한 건 도구 자체가 아니라 ",[18,1186,1187],{},"단계별 책임 분리",[47,1189],{},[50,1191,1192],{"id":1192},"결론",[14,1194,1195],{},"생산성은 더 오래 일한다고 올라가지 않습니다.",[14,1197,1198,1199],{},"반복되는 작업을 자동화 흐름으로 고정하면, ",[18,1200,1201],{},"생각해야 하는 문제에 더 많은 시간을 쓸 수 있습니다.",[14,1203,1204],{},"\"손으로 하는 일\"을 줄이고, \"코드로 남는 일\"을 늘리는 쪽이 결국 유지보수와 안정성까지 같이 가져갑니다.",[47,1206],{},[50,1208,1210],{"id":1209},"참고공식-문서-링크","참고(공식 문서 링크)",[25,1212,1213,1220,1227,1234,1241,1248,1255,1262,1269,1276,1283,1288],{},[28,1214,1215],{},[755,1216,1219],{"href":1217,"rel":1218},"https://github.com/go-task/task",[759],"Task (go-task) GitHub",[28,1221,1222],{},[755,1223,1226],{"href":1224,"rel":1225},"https://github.com/facebook/watchman",[759],"Watchman GitHub",[28,1228,1229],{},[755,1230,1233],{"href":1231,"rel":1232},"https://github.com/tmux/tmux",[759],"tmux GitHub",[28,1235,1236],{},[755,1237,1240],{"href":1238,"rel":1239},"https://github.com/renovatebot/renovate",[759],"Renovate GitHub",[28,1242,1243],{},[755,1244,1247],{"href":1245,"rel":1246},"https://github.com/pre-commit/pre-commit",[759],"pre-commit GitHub",[28,1249,1250],{},[755,1251,1254],{"href":1252,"rel":1253},"https://github.com/features/actions",[759],"GitHub Actions",[28,1256,1257],{},[755,1258,1261],{"href":1259,"rel":1260},"https://github.com/ansible/ansible",[759],"Ansible GitHub",[28,1263,1264],{},[755,1265,1268],{"href":1266,"rel":1267},"https://github.com/ajeetdsouza/zoxide",[759],"Zoxide GitHub",[28,1270,1271],{},[755,1272,1275],{"href":1273,"rel":1274},"http://crontab.guru/",[759],"crontab.guru",[28,1277,1278],{},[755,1279,1282],{"href":1280,"rel":1281},"https://github.com/espanso/espanso",[759],"Espanso GitHub",[28,1284,1285],{},[755,1286,760],{"href":757,"rel":1287},[759],[28,1289,1290],{},[755,1291,1