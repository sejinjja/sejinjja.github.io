e=\"button\">\n          Reset\n        \u003C/button>\n      \u003C/section>\n\n      {/* 버튼/체크박스와 sibling selector로 연결하기 위해 controls 뒤에 배치 */}\n      \u003Csection className={styles.dial} aria-label=\"Timer face\">\n        \u003Cdiv className={styles.hand} aria-hidden=\"true\" />\n        \u003Cdiv className={styles.centerDot} aria-hidden=\"true\" />\n        \u003Cp className={styles.hint}>\n          Play/Pause는 토글, Reset은 누르는 동안 0으로 되감습니다.\n        \u003C/p>\n      \u003C/section>\n    \u003C/main>\n  );\n}\n","typescript",[19,287,288,294,314,318,336,344,361,391,395,406,431,440,450,460,470,475,480,499,530,540,545,556,576,582,592,603,608,618,641,667,689,704,721,730,739,750,756],{"__ignoreMap":83},[87,289,290],{"class":89,"line":90},[87,291,293],{"class":292},"sAwPA","// app/css-timer/page.tsx\n",[87,295,296,300,304,307,311],{"class":89,"line":96},[87,297,299],{"class":298},"snl16","import",[87,301,303],{"class":302},"s95oV"," styles ",[87,305,306],{"class":298},"from",[87,308,310],{"class":309},"sU2Wk"," \"./Timer.module.css\"",[87,312,313],{"class":302},";\n",[87,315,316],{"class":89,"line":102},[87,317,124],{"emptyLinePlaceholder":123},[87,319,320,323,326,329,333],{"class":89,"line":108},[87,321,322],{"class":298},"export",[87,324,325],{"class":298}," default",[87,327,328],{"class":298}," function",[87,330,332],{"class":331},"svObZ"," CssTimerPage",[87,334,335],{"class":302},"() {\n",[87,337,338,341],{"class":89,"line":114},[87,339,340],{"class":298},"  return",[87,342,343],{"class":302}," (\n",[87,345,346,349,352,355,358],{"class":89,"line":120},[87,347,348],{"class":298},"    \u003C",[87,350,351],{"class":302},"main className",[87,353,354],{"class":298},"=",[87,356,357],{"class":302},"{styles.wrap}",[87,359,360],{"class":298},">\n",[87,362,363,366,369,371,374,377,381,384,387,389],{"class":89,"line":127},[87,364,365],{"class":298},"      \u003C",[87,367,368],{"class":302},"h1 className",[87,370,354],{"class":298},[87,372,373],{"class":302},"{styles.title}",[