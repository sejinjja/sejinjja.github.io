54,1482],{"__ignoreMap":135},[139,1449,1450,1452],{"class":141,"line":142},[139,1451,1290],{"class":385},[139,1453,712],{"class":296},[139,1455,1456,1458,1460,1463,1465,1467,1469,1472,1475,1477,1480],{"class":141,"line":148},[139,1457,932],{"class":321},[139,1459,720],{"class":296},[139,1461,1462],{"class":303},"\"[\"",[139,1464,940],{"class":321},[139,1466,943],{"class":296},[139,1468,1307],{"class":481},[139,1470,1471],{"class":296},", ",[139,1473,1474],{"class":321},"upper-roman",[139,1476,497],{"class":296},[139,1478,1479],{"class":303},"\"] \"",[139,1481,307],{"class":296},[139,1483,1484],{"class":141,"line":154},[139,1485,456],{"class":296},[15,1487,1488],{},"→ 기대 결과/무엇이 달라졌는지: 1, 2, 3 대신 I, II, III 형태로 번호 표현이 바뀐다.",[48,1490],{},[51,1492,1494],{"id":1493},"검증-방법체크리스트","검증 방법(체크리스트)",[69,1496,1499,1511,1517,1529],{"className":1497},[1498],"contains-task-list",[72,1500,1503,1506,1507,1510],{"className":1501},[1502],"task-list-item",[208,1504],{"disabled":312,"type":1505},"checkbox"," 체크박스를 여러 개 토글했을 때 ",[40,1508,1509],{},"Checked: X / Y","가 즉시 갱신된다.",[72,1512,1514,1516],{"className":1513},[1502],[208,1515],{"disabled":312,"type":1505}," 목록 상단에 요약이 보이지만, DOM에서는 요약이 목록 뒤에 위치한다. (Counter 누적 순서 보장)",[72,1518,1520,249,1522,1524,1525,1528],{"className":1519},[1502],[208,1521],{"disabled":312,"type":1505},[40,1523,208],{},"을 ",[40,1526,1527],{},"display:none","으로 숨기지 않고, 시각적으로만 숨겼다.",[72,1530,1532,1534],{"className":1531},[1502],[208,1533],{"disabled":312,"type":1505}," CSS Modules로 클래스 충돌 없이 적용된다.",[48,1536],{},[51,1538,1540],{"id":1539},"흔한-실수faq","흔한 실수/FAQ",[180,1542,1544],{"id":1543},"q-요약을-dom에서도-위에-두면-왜-숫자가-0으로-나오나요","Q. 요약을 DOM에서도 위에 두면 왜 숫자가 0으로 나오나요?",[15,1546,1547,1548,1551],{},"Counter는 ",[18,1549,1550],{},"문서 흐름대로 누적","된다. 요약이 먼저 나오면 아직 증가가 일어나지 않아 초기값만 출력된다.",[15,1553,1554,1555,1561],{},"대신 이 글처럼 **DOM은 아래, 화면은 위(",[18,1556,1557],{},[18,1558,1559],{},[40,1560,227],{},")**로 정렬하면 “최종 값”을 위에 보여줄 수 있다.",[180,1563,1565,1566,1568],{"id":1564},"q-counter-reset을-안-써도-되나요","Q. ",[40,1567,99],{},"을 안 써도 되나요?",[15,1570,1571],{},"초기값이 0이라면 동작은 할 수 있다.",[15,1573,1574,1575,1577],{},"하지만 “이 컨테이너에서 카운트를 쓴다”는 의도를 남기려면 ",[40,1576,99],{},"으로 스코프를 여는 편이 유지보수에 유리하다.",[180,1579,1581],{"id":1580},"q-카운트-숫자를-접근성seo의-핵심-정보로-써도-되나요","Q. 카운트 숫자를 접근성/SEO의 핵심 정보로 써도 되나요?",[15,1583,1584,1586,1587],{},[40,1585,42],{},"로 넣은 생성 콘텐츠(Generated content, 생성 콘텐츠)는 ",[18,1588,1589],{},"환경에 따라 보조기술이 읽는 방식이 달라질 수 있다.",[15,1591,1592],{},"그래서 “표시용 뱃지/번호” 같은 용도에 특히 잘 맞는다. 핵심 정보라면 HTML 텍스트로도 제공하는 쪽이 안전하다.",[48,1594],{},[51,1596,1598],{"id":1597},"요약35줄","요약(3~5줄)",[15,1600,1601,1602,1604,1605,1604,1607,1609],{},"CSS Counter는 ",[40,1603,99],{}," → ",[40,1606,108],{},[40,1608,117],{}," 흐름으로 동작한다.",[15,1611,1612,1613,1615],{},"체크박스 같은 상태 기반 카운트도 ",[40,1614,204],{},"와 조합하면 JS 없이 표시할 수 있다.",[15,1617,1618],{},"Counter는 소스 순서에 영향을 받으므로 “요약 출력은 뒤, 화면 배치는 위” 전략이 유효하다.",[15,1620,1621],{},"Next.js에서는 CSS Modules로 범위를 깔끔하게 고정하면 재사용과 충돌 방지가 쉽다.",[48,1623],{},[51,1625,1626],{"id":1626},"결론",[15,1628,1629],{},"JS 없이도 “세는 UI”는 충분히 만들 수 있다.",[15,1631,1632,1633,1636],{},"CSS Counter는 특히 ",[18,1634,1635],{},"단순 표시용 숫자","(번호, 배지, 진행 수량)에 잘 맞고, 코드량을 줄이면서도 UI의 의도를 또렷하게 만든다.",[15,1638,1639],{},"다만 생성 콘텐츠는 환경에 따라 해석이 달라질 수 있으니, 중요한 정보는 HTML 텍스트로도 제공하는 습관을 같이 가져가면 안정적이다.",[48,1641],{},[51,1643,1645],{"id":1644},"참고공식-문서-링크","참고(공식 문서 링크)",[69,1647,1648,1657,1664,1671,1678,1685,1692,1701,1708,1715,1722],{},[72,1649,1650],{},[1651,1652,1656],"a",{"href":1653,"rel":1654},"https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/counter",[1655],"nofollow","MDN - counter()",[72,1658,1659],{},[1651,1660,1663],{"href":1661,"rel":1662},"https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Values/counters",[1655],"MDN - counters()",[72,1665,1666],{},[1651,1667,1670],{"href":1668,"rel":1669},"https://developer.mozilla.org/en-US/docs/Web/CSS/Reference/Properties/counter-reset",[1655],"MDN - counter-reset",[72,1672,1673],{},[1651,1674,1677],{"href":1675,"rel":1676},"https://develop