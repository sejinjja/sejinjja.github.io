[{"data":1,"prerenderedAt":1538},["ShallowReactive",2],{"writing:meta:/writing/get-post-safe-idempotent":3},{"id":4,"title":5,"body":6,"date":1526,"description":19,"extension":1527,"meta":1528,"navigation":204,"notionPageId":1529,"path":1530,"seo":1531,"source":1532,"stem":1533,"tags":1534,"__hash__":1537},"content/writing/get-post-safe-idempotent.md","의미를 지켜라: GET·POST를 안전·멱등성으로 설계하기",{"type":7,"value":8,"toc":1498},"minimark",[9,13,20,25,28,41,52,55,95,99,104,110,113,123,145,257,264,268,278,282,336,340,350,354,364,368,382,386,643,646,650,874,880,884,1067,1073,1077,1089,1288,1291,1295,1358,1362,1366,1372,1376,1382,1386,1392,1396,1402,1405,1431,1434,1444,1447,1494],[10,11,5],"h1",{"id":12},"의미를-지켜라-getpost를-안전멱등성으로-설계하기",[14,15,16],"blockquote",{},[17,18,19],"p",{},"GET은 “URL에 싣는 방식”이 아니라 “읽기 전용 의미”다. 이 의미를 지키면 캐시·프리패치·재시도가 안전해지고, API가 예측 가능해진다. (RFC 9110)",[21,22,24],"h2",{"id":23},"배경과-문제","배경과 문제",[17,26,27],{},"HTTP를 처음 배울 때 흔히 이렇게 외운다.",[29,30,31,35,38],"ul",{},[32,33,34],"li",{},"GET은 URL에 파라미터를 붙인다",[32,36,37],{},"POST는 Body에 데이터를 실어 보낸다",[32,39,40],{},"GET은 길이 제한이 있고 주소창에 보여서 “보안상 위험하다”",[17,42,43,44,51],{},"하지만 이건 **전송 “모양”**에 가까운 이야기다. GET·POST가 진짜로 갈리는 지점은 **서버가 기대하는 의미(semantics)**다. (",[45,46,50],"a",{"href":47,"rel":48},"https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Methods",[49],"nofollow","MDN: HTTP request methods",")",[17,53,54],{},"이 의미가 깨지면 이런 문제가 생긴다.",[29,56,57,77,87],{},[32,58,59,60,64,65,64,68,71,72,51],{},"GET 요청이 ",[61,62,63],"strong",{},"자동 수집(크롤러)",", ",[61,66,67],{},"프리패치",[61,69,70],{},"캐시 최적화"," 과정에서 의도치 않게 실행되어 서버 상태를 바꿔버린다. (",[45,73,76],{"href":74,"rel":75},"https://www.rfc-editor.org/rfc/rfc9110.html",[49],"RFC 9110",[32,78,79,80,83,84,51],{},"네트워크 실패 시 클라이언트/중간 장치가 ",[61,81,82],{},"재시도","를 하면서 “같은 요청을 여러 번 보냈을 때의 최종 상태”가 흔들린다. (",[45,85,76],{"href":74,"rel":86},[49],[32,88,89,90,51],{},"Next.js에서는 GET Route Handler가 캐시/정적화 경로에 올라갈 수 있는데, GET이 변경을 일으키면 최적화가 곧 사고가 된다. (",[45,91,94],{"href":92,"rel":93},"https://nextjs.org/docs/app/getting-started/route-handlers",[49],"Next.js Route Handlers",[21,96,98],{"id":97},"핵심-개념","핵심 개념",[100,101,103],"h3",{"id":102},"안전한-메서드","안전한 메서드",[17,105,106,107,51],{},"**안전(safe)**은 “서버 상태를 바꾸지 않는 읽기 전용 의미”를 말한다. (GET/HEAD/OPTIONS/TRACE가 안전으로 정의된다.) (",[45,108,76],{"href":74,"rel":109},[49],[100,111,112],{"id":112},"멱등성",[17,114,115,116,119,120,51],{},"**멱등(idempotent)**은 “같은 요청을 여러 번 보내도 ",[61,117,118],{},"의도된 최종 효과가 한 번 보낸 것과 같다","”는 성질이다. (",[45,121,76],{"href":74,"rel":122},[49],[29,124,125,133],{},[32,126,127,128,51],{},"안전한 메서드는 모두 멱등이다. (",[45,129,132],{"href":130,"rel":131},"https://developer.mozilla.org/en-US/docs/Glossary/Safe/HTTP",[49],"MDN: Safe HTTP methods",[32,134,135,136,139,140,51],{},"하지만 ",[61,137,138],{},"멱등 = 안전","은 아니다. 예를 들어 DELETE는 서버 상태를 바꾸므로 안전하지 않지만, 같은 삭제를 여러 번 호출해도 “해당 리소스가 없다”라는 최종 상태로 수렴할 수 있어 멱등으로 분류된다. (",[45,141,144],{"href":142,"rel":143},"https://developer.mozilla.org/en-US/docs/Glossary/Idempotent",[49],"MDN: Idempotent",[146,147,152],"pre",{"className":148,"code":149,"language":150,"meta":151,"style":151},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  subgraph S[\"Safe\u003Cbr/>읽기 전용 의미\"]\n    GET[\"GET\"]\n    HEAD[\"HEAD\"]\n    OPTIONS[\"OPTIONS\"]\n    TRACE[\"TRACE\"]\n  end\n\n  subgraph IU[\"Unsafe but Idempotent\u003Cbr/>최종 상태는 동일\"]\n    PUT[\"PUT\"]\n    DELETE[\"DELETE\"]\n  end\n\n  subgraph U[\"Unsafe & Not guaranteed\u003Cbr/>idempotent\"]\n    POST[\"POST\"]\n    PATCH[\"PATCH\"]\n  end\n","mermaid","",[153,154,155,163,169,175,181,187,193,199,206,212,218,224,229,234,240,246,252],"code",{"__ignoreMap":151},[156,157,160],"span",{"class":158,"line":159},"line",1,[156,161,162],{},"flowchart LR\n",[156,164,166],{"class":158,"line":165},2,[156,167,168],{},"  subgraph S[\"Safe\u003Cbr/>읽기 전용 의미\"]\n",[156,170,172],{"class":158,"line":171},3,[156,173,174],{},"    GET[\"GET\"]\n",[156,176,178],{"class":158,"line":177},4,[156,179,180],{},"    HEAD[\"HEAD\"]\n",[156,182,184],{"class":158,"line":183},5,[156,185,186],{},"    OPTIONS[\"OPTIONS\"]\n",[156,188,190],{"class":158,"line":189},6,[156,191,192],{},"    TRACE[\"TRACE\"]\n",[156,194,196],{"class":158,"line":195},7,[156,197,198],{},"  end\n",[156,200,202],{"class":158,"line":201},8,[156,203,205],{"emptyLinePlaceholder":204},true,"\n",[156,207,209],{"class":158,"line":208},9,[156,210,211],{},"  subgraph IU[\"Unsafe but Idempotent\u003Cbr/>최종 상태는 동일\"]\n",[156,213,215],{"class":158,"line":214},10,[156,216,217],{},"    PUT[\"PUT\"]\n",[156,219,221],{"class":158,"line":220},11,[156,222,223],{},"    DELETE[\"DELETE\"]\n",[156,225,227],{"class":158,"line":226},12,[156,228,198],{},[156,230,232],{"class":158,"line":231},13,[156,233,205],{"emptyLinePlaceholder":204},[156,235,237],{"class":158,"line":236},14,[156,238,239],{},"  subgraph U[\"Unsafe & Not guaranteed\u003Cbr/>idempotent\"]\n",[156,241,243],{"class":158,"line":242},15,[156,244,245],{},"    POST[\"POST\"]\n",[156,247,249],{"class":158,"line":248},16,[156,250,251],{},"    PATCH[\"PATCH\"]\n",[156,253,255],{"class":158,"line":254},17,[156,256,198],{},[17,258,259,260,263],{},"→ 기대 결과/무엇이 달라졌는지: “GET=URL, POST=Body” 같은 모양이 아니라, ",[61,261,262],{},"안전/멱등"," 기준으로 메서드 역할이 정리된다.",[21,265,267],{"id":266},"해결-접근","해결 접근",[17,269,270,271,274,275,51],{},"포인트는 단순하다. ",[61,272,273],{},"메서드가 기대하는 의미를 코드로 지키는 것."," (",[45,276,76],{"href":74,"rel":277},[49],[100,279,281],{"id":280},"_1-조회는-get-변경은-postputpatchdelete","1) 조회는 GET, 변경은 POST/PUT/PATCH/DELETE",[29,283,284,293,302,327],{},[32,285,286,289,290,51],{},[61,287,288],{},"GET",": 조회. 읽기 전용(안전) 의미를 지킨다. (",[45,291,76],{"href":74,"rel":292},[49],[32,294,295,298,299,51],{},[61,296,297],{},"POST",": “무언가를 수행해 결과를 만든다”에 가깝다. 기본적으로 멱등이 보장되지 않는다. (",[45,300,144],{"href":142,"rel":301},[49],[32,303,304,307],{},[61,305,306],{},"PUT vs PATCH 비교",[29,308,309,318],{},[32,310,311,314,315,51],{},[61,312,313],{},"PUT",": “해당 리소스를 이 내용으로 맞춘다(대체/업서트 성격)”로 설계하면 멱등에 잘 맞는다. (",[45,316,76],{"href":74,"rel":317},[49],[32,319,320,323,324,51],{},[61,321,322],{},"PATCH",": “부분 수정”에 쓰지만 멱등이 자동으로 보장되지는 않는다. (",[45,325,144],{"href":142,"rel":326},[49],[32,328,329,332,333,51],{},[61,330,331],{},"DELETE",": 삭제. 안전하진 않지만 멱등으로 설계할 수 있다. (",[45,334,76],{"href":74,"rel":335},[49],[100,337,339],{"id":338},"_2-get은-보안에-취약이-아니라-get은-노출캐시-경로에-잘-탄다","2) “GET은 보안에 취약”이 아니라 “GET은 노출/캐시 경로에 잘 탄다”",[17,341,342,343,346,347,51],{},"GET은 링크/로그/히스토리/캐시 같은 경로를 더 쉽게 탄다. 그래서 ",[61,344,345],{},"민감 데이터는 어떤 메서드든 전송 위치(쿼리/바디)에 상관없이"," 다루는 정책이 필요하다. 안전/멱등은 “보안 기능”이 아니라 “의미 규약”에 가깝다. (",[45,348,76],{"href":74,"rel":349},[49],[100,351,353],{"id":352},"_3-큰-페이로드가-필요하면-get-바디가-아니라-설계를-바꾼다","3) 큰 페이로드가 필요하면 “GET 바디”가 아니라 설계를 바꾼다",[17,355,356,357,360,361,51],{},"GET 요청에 Body를 붙이는 건 구현체에 따라 거부되거나 의미가 통일되지 않을 수 있다. 복잡한 검색 조건처럼 URL로 표현하기 어려운 조회는 ",[61,358,359],{},"POST로 조회 엔드포인트를 만드는 방식","도 실무에서 쓰인다(캐시/프리패치 기대는 낮아진다). (",[45,362,76],{"href":74,"rel":363},[49],[21,365,367],{"id":366},"구현-코드","구현 코드",[17,369,370,371,374,375,378,379,51],{},"아래 예시는 Next.js Route Handler로 메서드 의미를 고정하는 패턴이다. Route Handler는 ",[153,372,373],{},"app"," 디렉터리의 ",[153,376,377],{},"route.js"," 파일에서 HTTP 메서드 이름으로 함수를 export한다. (",[45,380,94],{"href":92,"rel":381},[49],[100,383,385],{"id":384},"조회는-get","조회는 GET",[146,387,391],{"className":388,"code":389,"language":390,"meta":151,"style":151},"language-javascript shiki shiki-themes github-dark","// app/api/todos/route.js\nimport { NextResponse } from \"next/server\";\n\nconst todos = [\n  { id: \"1\", title: \"read docs\" },\n  { id: \"2\", title: \"ship it\" },\n];\n\nexport async function GET(request) {\n  const url = new URL(request.url);\n  const q = url.searchParams.get(\"q\") ?? \"\";\n\n  const filtered = q\n    ? todos.filter((t) => t.title.toLowerCase().includes(q.toLowerCase()))\n    : todos;\n\n  return NextResponse.json({ todos: filtered });\n}\n","javascript",[153,392,393,399,419,423,438,455,469,474,478,503,522,553,557,569,611,619,623,637],{"__ignoreMap":151},[156,394,395],{"class":158,"line":159},[156,396,398],{"class":397},"sAwPA","// app/api/todos/route.js\n",[156,400,401,405,409,412,416],{"class":158,"line":165},[156,402,404],{"class":403},"snl16","import",[156,406,408],{"class":407},"s95oV"," { NextResponse } ",[156,410,411],{"class":403},"from",[156,413,415],{"class":414},"sU2Wk"," \"next/server\"",[156,417,418],{"class":407},";\n",[156,420,421],{"class":158,"line":171},[156,422,205],{"emptyLinePlaceholder":204},[156,424,425,428,432,435],{"class":158,"line":177},[156,426,427],{"class":403},"const",[156,429,431],{"class":430},"sDLfK"," todos",[156,433,434],{"class":403}," =",[156,436,437],{"class":407}," [\n",[156,439,440,443,446,449,452],{"class":158,"line":183},[156,441,442],{"class":407},"  { id: ",[156,444,445],{"class":414},"\"1\"",[156,447,448],{"class":407},", title: ",[156,450,451],{"class":414},"\"read docs\"",[156,453,454],{"class":407}," },\n",[156,456,457,459,462,464,467],{"class":158,"line":189},[156,458,442],{"class":407},[156,460,461],{"class":414},"\"2\"",[156,463,448],{"class":407},[156,465,466],{"class":414},"\"ship it\"",[156,468,454],{"class":407},[156,470,471],{"class":158,"line":195},[156,472,473],{"class":407},"];\n",[156,475,476],{"class":158,"line":201},[156,477,205],{"emptyLinePlaceholder":204},[156,479,480,483,486,489,493,496,500],{"class":158,"line":208},[156,481,482],{"class":403},"export",[156,484,485],{"class":403}," async",[156,487,488],{"class":403}," function",[156,490,492],{"class":491},"svObZ"," GET",[156,494,495],{"class":407},"(",[156,497,499],{"class":498},"s9osk","request",[156,501,502],{"class":407},") {\n",[156,504,505,508,511,513,516,519],{"class":158,"line":214},[156,506,507],{"class":403},"  const",[156,509,510],{"class":430}," url",[156,512,434],{"class":403},[156,514,515],{"class":403}," new",[156,517,518],{"class":491}," URL",[156,520,521],{"class":407},"(request.url);\n",[156,523,524,526,529,531,534,537,539,542,545,548,551],{"class":158,"line":220},[156,525,507],{"class":403},[156,527,528],{"class":430},