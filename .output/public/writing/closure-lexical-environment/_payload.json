[{"data":1,"prerenderedAt":1371},["ShallowReactive",2],{"writing:meta:/writing/closure-lexical-environment":3},{"id":4,"title":5,"body":6,"date":1359,"description":1360,"extension":1361,"meta":1362,"navigation":178,"notionPageId":1363,"path":1364,"seo":1365,"source":1366,"stem":1367,"tags":1368,"__hash__":1370},"content/writing/closure-lexical-environment.md","렉시컬 환경으로 이해하는 클로저",{"type":7,"value":8,"toc":1328},"minimark",[9,14,22,25,30,34,60,62,66,69,80,83,96,99,101,105,110,113,126,129,132,214,217,219,223,230,236,292,311,313,317,320,342,345,372,374,378,382,425,436,438,442,504,511,513,517,524,543,556,559,618,624,626,633,651,661,663,667,703,712,714,718,746,752,754,758,763,1106,1115,1121,1123,1127,1184,1186,1190,1194,1204,1212,1219,1223,1230,1233,1235,1238,1241,1244,1246,1250,1324],[10,11,13],"h1",{"id":12},"스코프는-선언에서-결정된다-렉시컬-환경으로-이해하는-클로저","스코프는 선언에서 결정된다: 렉시컬 환경으로 이해하는 클로저",[15,16,17,21],"p",{},[18,19,20],"strong",{},"한 문장 결론:"," 클로저는 “함수 + 선언 당시 렉시컬 환경(lexical environment)”이어서, _무엇을 캡처했는지_만 알면 비동기/이벤트 기반 버그를 빠르게 정리할 수 있다.",[23,24],"hr",{},[26,27,29],"h2",{"id":28},"_1-게시용-최종-글","1) 게시용 최종 글",[26,31,33],{"id":32},"요약-35줄","요약 (3~5줄)",[35,36,37,41,44,51,57],"ul",{},[38,39,40],"li",{},"렉시컬 환경은 “식별자(변수/함수 이름)와 값의 연결”을 담는 실행 맥락의 저장소다.",[38,42,43],{},"자바스크립트는 함수가 만들어질 때, 자신이 선언된 렉시컬 환경을 함께 기억한다(= 클로저).",[38,45,46,50],{},[47,48,49],"code",{},"var"," + 비동기 콜백에서 흔히 겪는 “루프가 끝난 값만 찍힘” 문제는 같은 바인딩을 공유해서 생긴다.",[38,52,53,56],{},[47,54,55],{},"let","(블록 스코프) 또는 “값을 파라미터로 넘겨 고정”하는 패턴으로 해결한다.",[38,58,59],{},"Next.js에서는 브라우저 API/이벤트 핸들러가 필요한 코드를 Client Component로 분리하면 재현과 디버깅이 쉬워진다.",[23,61],{},[26,63,65],{"id":64},"배경문제","배경/문제",[15,67,68],{},"클로저를 설명할 때 흔히 “함수와 렉시컬 환경의 조합”이라고 말한다.",[15,70,71,72,75,76,79],{},"그런데 “렉시컬 환경”이 감이 안 잡히면, 클로저가 왜 값을 “계속 기억하는지”, 왜 ",[47,73,74],{},"for"," 루프와 ",[47,77,78],{},"setTimeout","에서 기대와 다른 결과가 나오는지 연결이 끊긴다.",[15,81,82],{},"여기서 중요한 건 두 가지다.",[84,85,86,91],"ol",{},[38,87,88],{},[18,89,90],{},"스코프(식별자 탐색 규칙)는 코드가 ’어디에 선언됐는지’로 결정된다.",[38,92,93],{},[18,94,95],{},"비동기 콜백은 ’나중에 실행’되기 때문에, 그 사이에 바뀐 값을 참조할 수 있다.",[15,97,98],{},"이걸 렉시컬 환경으로 잡아두면, React/Next.js에서 흔한 “stale closure(오래된 캡처)” 류의 문제도 같은 원리로 정리된다.",[23,100],{},[26,102,104],{"id":103},"핵심-개념","핵심 개념",[106,107,109],"h3",{"id":108},"렉시컬-환경이란","렉시컬 환경이란?",[15,111,112],{},"렉시컬 환경(lexical environment)은 간단히 말해:",[35,114,115,120],{},[38,116,117],{},[18,118,119],{},"현재 코드가 참조할 수 있는 식별자(변수/함수/매개변수)와 그 값의 연결",[38,121,122,123],{},"그리고 ",[18,124,125],{},"바깥 렉시컬 환경으로 이어지는 링크(외부 참조)",[15,127,128],{},"로 구성된 “스코프를 구현하는 내부 저장소”다.",[15,130,131],{},"아래 다이어그램을 보면 “안쪽에서 바깥으로” 식별자를 찾는 흐름이 한 번에 잡힌다.",[133,134,139],"pre",{"className":135,"code":136,"language":137,"meta":138,"style":138},"language-mermaid shiki shiki-themes github-dark","flowchart TB\n  subgraph F[\"foo() 실행\u003Cbr/>렉시컬 환경\"]\n    T[\"test = 'test'\"]\n    B[\"bar() 선언\u003Cbr/>bar는 foo의 환경을 참조\"]\n  end\n\n  subgraph G[\"전역 렉시컬 환경\"]\n    C[\"console\"]\n  end\n\n  B -->|\"식별자 탐색\"| T\n  B -->|\"없으면 바깥으로\"| G\n","mermaid","",[47,140,141,149,155,161,167,173,180,186,192,197,202,208],{"__ignoreMap":138},[142,143,146],"span",{"class":144,"line":145},"line",1,[142,147,148],{},"flowchart TB\n",[142,150,152],{"class":144,"line":151},2,[142,153,154],{},"  subgraph F[\"foo() 실행\u003Cbr/>렉시컬 환경\"]\n",[142,156,158],{"class":144,"line":157},3,[142,159,160],{},"    T[\"test = 'test'\"]\n",[142,162,164],{"class":144,"line":163},4,[142,165,166],{},"    B[\"bar() 선언\u003Cbr/>bar는 foo의 환경을 참조\"]\n",[142,168,170],{"class":144,"line":169},5,[142,171,172],{},"  end\n",[142,174,176],{"class":144,"line":175},6,[142,177,179],{"emptyLinePlaceholder":178},true,"\n",[142,181,183],{"class":144,"line":182},7,[142,184,185],{},"  subgraph G[\"전역 렉시컬 환경\"]\n",[142,187,189],{"class":144,"line":188},8,[142,190,191],{},"    C[\"console\"]\n",[142,193,195],{"class":144,"line":194},9,[142,196,172],{},[142,198,200],{"class":144,"line":199},10,[142,201,179],{"emptyLinePlaceholder":178},[142,203,205],{"class":144,"line":204},11,[142,206,207],{},"  B -->|\"식별자 탐색\"| T\n",[142,209,211],{"class":144,"line":210},12,[142,212,213],{},"  B -->|\"없으면 바깥으로\"| G\n",[15,215,216],{},"→ 기대 결과/무엇이 달라졌는지: “변수는 함수 안에 있어도”, 중첩 함수가 선언된 위치 기준으로 바깥 환경을 따라 올라가며 찾는다는 구조가 고정된다.",[23,218],{},[106,220,222],{"id":221},"클로저란","클로저란?",[15,224,225,226,229],{},"클로저(closure)는 ",[18,227,228],{},"함수 + 그 함수가 선언될 당시의 렉시컬 환경 참조","다.",[15,231,232,233],{},"그래서 바깥 함수 실행이 끝나도, 반환된 함수가 그 환경을 계속 참조하면 ",[18,234,235],{},"캡처된 값(정확히는 바인딩)이 살아있는 것처럼 보인다.",[133,237,241],{"className":238,"code":239,"language":240,"meta":138,"style":138},"language-javascript shiki shiki-themes github-dark","function foo() {\n  const test = 'test';\n  function bar() {\n    console.log(test);\n  }\n  return bar;\n}\n\nconst fooOfBar = foo();\nfooOfBar();\n","javascript",[47,242,243,248,253,258,263,268,273,278,282,287],{"__ignoreMap":138},[142,244,245],{"class":144,"line":145},[142,246,247],{},"function foo() {\n",[142,249,250],{"class":144,"line":151},[142,251,252],{},"  const test = 'test';\n",[142,254,255],{"class":144,"line":157},[142,256,257],{},"  function bar() {\n",[142,259,260],{"class":144,"line":163},[142,261,262],{},"    console.log(test);\n",[142,264,265],{"class":144,"line":169},[142,266,267],{},"  }\n",[142,269,270],{"class":144,"line":175},[142,271,272],{},"  return bar;\n",[142,274,275],{"class":144,"line":182},[142,276,277],{},"}\n",[142,279,280],{"class":144,"line":188},[142,281,179],{"emptyLinePlaceholder":178},[142,283,284],{"class":144,"line":194},[142,285,286],{},"const fooOfBar = foo();\n",[142,288,289],{"class":144,"line":199},[142,290,291],{},"fooOfBar();\n",[15,293,294,295,298,299,302,303,306,307,310],{},"→ 기대 결과/무엇이 달라졌는지: ",[47,296,297],{},"foo()","가 끝난 뒤에도 ",[47,300,301],{},"bar()","는 ",[47,304,305],{},"test"," 바인딩을 참조하고 있어 ",[47,308,309],{},"\"test\"","가 출력된다.",[23,312],{},[26,314,316],{"id":315},"해결-접근","해결 접근",[15,318,319],{},"클로저를 “마법”처럼 외우기보다, 아래 2단계로 사고하면 실무에서 훨씬 강해진다.",[84,321,322,332],{},[38,323,324,327],{},[18,325,326],{},"이 콜백(함수)은 어떤 변수를 캡처했나?",[35,328,329],{},[38,330,331],{},"값 자체를 복사한 게 아니라, _어떤 바인딩을 참조하는지_가 핵심이다.",[38,333,334,337],{},[18,335,336],{},"그 바인딩은 언제/어디서 바뀌나?",[35,338,339],{},[38,340,341],{},"루프, 상태 업데이트, 비동기 콜백, 이벤트 핸들러가 대표적인 변경 지점이다.",[15,343,344],{},"여기에 “대안”을 붙이면 선택이 빨라진다.",[35,346,347,360,366],{},[38,348,349,350],{},"대안 A: ",[18,351,352,353,359],{},"블록 스코프(",[18,354,355],{},[18,356,357],{},[47,358,55],{},")로 루프마다 바인딩을 분리",[38,361,362,363],{},"대안 B: ",[18,364,365],{},"파라미터로 값을 넘겨서 ’값을 고정’한 함수를 생성",[38,367,368,369],{},"대안 C: ",[18,370,371],{},"즉시 실행 함수(IIFE)로 스코프를 한 겹 더 만들어 고정",[23,373],{},[26,375,377],{"id":376},"구현코드","구현(코드)",[106,379,381],{"id":380},"_1-렉시컬-스코핑-선언-위치가-스코프를-결정한다","1) 렉시컬 스코핑: 선언 위치가 스코프를 결정한다",[133,383,385],{"className":238,"code":384,"language":240,"meta":138,"style":138},"function foo() {\n  const test = 'test';\n  function bar() {\n    console.log(test);\n  }\n  bar();\n}\n\nfoo();\n",[47,386,387,391,395,399,403,407,412,416,420],{"__ignoreMap":138},[142,388,389],{"class":144,"line":145},[142,390,247],{},[142,392,393],{"class":144,"line":151},[142,394,252],{},[142,396,397],{"class":144,"line":157},[142,398,257],{},[142,400,401],{"class":144,"line":163},[142,402,262],{},[142,404,405],{"class":144,"line":169},[142,406,267],{},[142,408,409],{"class":144,"line":175},[142,410,411],{},"  bar();\n",[142,413,414],{"class":144,"line":182},[142,415,277],{},[142,417,418],{"class":144,"line":188},[142,419,179],{"emptyLinePlaceholder":178},[142,421,422],{"class":144,"line":194},[142,423,424],{},"foo();\n",[15,426,294,427,429,430,432,433,435],{},[47,428,301],{},"는 자신이 선언된 위치 기준으로 ",[47,431,305],{},"를 찾아 ",[47,434,309],{},"를 출력한다.",[23,437],{},[106,439,441],{"id":440},"_2-함수-공장factory-makeadder로-값이-고정된-함수-만들기","2) 함수 공장(factory): makeAdder로 “값이 고정된 함수” 만들기",[133,443,445],{"className":238,"code":444,"language":240,"meta":138,"style":138},"function makeAdder(x) {\n  return function (y) {\n    return x + y;\n  };\n}\n\nconst add5 = makeAdder(5);\nconst add10 = makeAdder(10);\n\nconsol