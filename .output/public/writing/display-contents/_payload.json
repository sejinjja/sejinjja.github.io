,{},"아래 다이어그램을 보면, “DOM은 그대로인데 레이아웃에서만 래퍼가 사라지는” 느낌이 바로 들어옵니다.",[105,106,111],"pre",{"className":107,"code":108,"language":109,"meta":110,"style":110},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  subgraph DOM[\"DOM 트리\"]\n    G[\"Grid 컨테이너\u003Cbr/>display: grid\"] --> A[\"자식 A\"]\n    G --> B[\"자식 B\"]\n    G --> UL[\"UL 래퍼\u003Cbr/>의미를 위한 태그\"]\n    UL --> LI1[\"LI 1\"]\n    UL --> LI2[\"LI 2\"]\n  end\n\n  subgraph BOX[\"박스 트리(레이아웃)\"]\n    G2[\"Grid 컨테이너 박스\"] --> A2[\"Grid item: A\"]\n    G2 --> B2[\"Grid item: B\"]\n    G2 --> UL2[\"Grid item: UL\"]\n    UL2 --> LI1b[\"UL 내부: LI 1\"]\n    UL2 --> LI2b[\"UL 내부: LI 2\"]\n  end\n\n  subgraph BOX2[\"박스 트리(UL에 display: contents 적용)\"]\n    G3[\"Grid 컨테이너 박스\"] --> A3[\"Grid item: A\"]\n    G3 --> B3[\"Grid item: B\"]\n    G3 --> LI13[\"Grid item: LI 1\"]\n    G3 --> LI23[\"Grid item: LI 2\"]\n  end\n","mermaid","",[24,112,113,121,127,133,139,145,151,157,163,170,176,182,188,194,200,206,211,216,222,228,234,240,246],{"__ignoreMap":110},[114,115,118],"span",{"class":116,"line":117},"line",1,[114,119,120],{},"flowchart LR\n",[114,122,124],{"class":116,"line":123},2,[114,125,126],{},"  subgraph DOM[\"DOM 트리\"]\n",[114,128,130],{"class":116,"line":129},3,[114,131,132],{},"    G[\"Grid 컨테이너\u003Cbr/>display: grid\"] --> A[\"자식 A\"]\n",[114,134,136],{"class":116,"line":135},4,[114,137,138],{},"    G --> B[\"자식 B\"]\n",[114,140,142],{"class":116,"line":141},5,[114,143,144],{},"    G --> UL[\"UL 래퍼\u003Cbr/>의미를 위한 태그\"]\n",[114,146,148],{"class":116,"line":147},6,[114,149,150],{},"    UL --> LI1[\"LI 1\"]\n",[114,152,154],{"class":116,"line":153},7,[114,155,156],{},"    UL --> LI2[\"LI 2\"]\n",[114,158,160],{"class":116,"line":159},8,[114,161,162],{},"  end\n",[114,164,166],{"class":116,"line":165},9,[114,167,169],{"emptyLinePlaceholder":168},true,"\n",[114,171,173],{"class":116,"line":172},10,[114,174,175],{},"  subgraph BOX[\"박스 트리(레이아웃)\"]\n",[114,177,179],{"class":116,"line":178},11,[114,180,181],{},