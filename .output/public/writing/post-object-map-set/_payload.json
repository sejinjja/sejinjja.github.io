 프로퍼티를 가진 “레코드/설정”에 강함. JSON과의 호환이 자연스럽습니다.",[51,98,99,102,103,106],{},[18,100,101],{},"Map",": “키-값 저장소”라는 목적이 API로 드러남(",[29,104,105],{},"get/set/has/delete/size","). 인덱스/캐시에 강합니다.",[51,108,109,112],{},[18,110,111],{},"Set",": “중복 없는 값의 집합”. 포함 여부가 핵심인 상태(선택/방문/처리됨)에 강합니다.",[14,114,115],{},"아래 다이어그램을 보면, 선택 기준이 한 번에 정리됩니다.",[117,118,123],"pre",{"className":119,"code":120,"language":121,"meta":122,"style":122},"language-mermaid shiki shiki-themes github-dark","flowchart TD\n  A[\"데이터를 저장한다\u003Cbr/>Object·Map·Set 중 선택\"] -->|\"직렬화(JSON) 경계를 넘나든다\"| B[\"Object/Array 중심\u003Cbr/>Map/Set은 변환 규칙 필요\"]\n  A -->|\"직렬화 경계가 없다\"| C{\"중복이 핵심인가?\"}\n  C -->|\"예\"| D[\"Set\u003Cbr/>has/add/delete로 의도 고정\"]\n  C -->|\"아니오\"| E{\"키가 문자열/심볼만인가?\"}\n  E -->|\"예\"| F[\"Object\u003Cbr/>레코드/옵션에 자연스러움\"]\n  E -->|\"아니오\"| G[\"Map\u003Cbr/>키 타입 자유 + size + 명확한 API\"]\n","mermaid","",[29,124,125,133,139,145,151,157,163],{"__ignoreMap":122},[126,127,130],"span",{"class":128,"line":129},"line",1,[126,131,132],{},"flowchart TD\n",[126,134,136],{"class":128,"line":135},2,[126,137,138],{},"  A[\"데이터를 저장한다\u003Cbr/>Object·Map·Set 중 선택\"] -->|\"직렬화(JSON) 경계를 넘나든다\"| B[\"Object/Array 중심\u003Cbr/>Map/Set은 변환 규칙 필요\"]\n",[126,140,142],{"class":128,"line":141},3,[126,143,144],{},"  A -->|\"직렬화 경계가 없다\"| C{\"중복이 핵심인가?\"}\n",[126,146,148],{"class":128,"line":147},4,[126,149,150],{},"  C -->|\"예\"| D[\"Set\u003Cbr/>has/add/delete로 의도 고정\"]\n",[126,152,154],{"class":128,"line":153},5,[126,155,156],{},"  C -->|\"아니오\"| E{\"키가 문자열/심볼만인가?\"}\n",[126,158,160],{"class":128,"line":159},6,[126,161,162],{},"  E -->|\"예\"| F[\"Object\u003Cbr/>레코드/옵션에 자연스러움\"]\n",[126,164,166],{"class":128,"line":165},7,[126,167,168],{},"  E -->|\"아니오\"| G[\"Map\u003Cbr/>키 타입 자유 + size + 명확한 API\"]\n",[14,170,171],{},"→ 기대 결과/무엇이 달라졌는지: “지금 요구사항이 어떤 형태인지”만 잡으면 컬렉션 선택이 취향 논쟁이 아니라 설계 결정으로 정리됩니다.",[34,173],{},[37,175,177],{"id":176},"해결-접근","해결 접근",[85,179,181],{"id":180},"_1-먼저-경계직렬화를-본다","1) 먼저 “경계(직렬화)”를 본다",[14,183,184],{},"Next.js에서는 서버/클라이언트 사이를 오가거나, 저장소(localStorage 등)에 넣거나, 네트워크로 보내야 하는 순간이 많습니다.",[14,186,187,188,191,192,195],{},"이 경계를 지나야 한다면 ",[18,189,190],{},"Object/Array가 기본 선택","이고, Map/Set을 쓰더라도 ",[18,193,194],{},"경계에서 변환 규칙을 고정","하는 편이 안전합니다.",[48,197,198,208],{},[51,199,200,201,204,205],{},"Map → ",[29,202,203],{},"Array.from(map.entries())"," 또는 ",[29,206,207],{},"Object.fromEntries(map)",[51,209,210,211],{},"Set → ",[29,212,213],{},"[...set]",[85,215,217],{"id":216},"_2-다음은-핵심-연산을-본다","2) 다음은 “핵심 연산”을 본다",[48,219,220,230,236],{},[51,221,222,225,226,229],{},[29,223,224],{},"id","로 ",[18,227,228],{},"자주 조회","한다 → Map 인덱스가 코드가 짧고 의도가 분명해집니다.",[51,231,232,235],{},[18,233,234],{},"포함 여부","가 로직의 중심이다(선택/방문/중복) → Set이 가장 자연스럽습니다.",[51,237,238,239,242],{},"폼 값/설정/레코드처럼 ",[18,240,241],{},"구조 자체가 데이터","다 → Object가 가장 읽기 쉽습니다.",[85,244,246],{"id":245},"_3-대안비교를-최소-2개는-놓고-결정한다","3) 대안/비교를 최소 2개는 놓고 결정한다",[48,248,249,256,267],{},[51,250,251,252,255],{},"(대안 A) ",[18,253,254],{},"Array + find",": 단순하지만 조회가 반복되면 호출부가 금방 늘어납니다.",[51,257,258,259,262,263,266],{},"(대안 B) ",[18,260,261],{},"Object를 딕셔너리처럼 사용",": 문자열 키만 필요하고 직렬화가 중요하면 좋습니다. 다만 키 충돌/프로토타입 영향이 신경 쓰이면 ",[29,264,265],{},"Object.create(null)"," 또는 Map으로 전환합니다.",[51,268,269,270,273],{},"(대안 C) ",[18,271,272],{},"Set 대신 Array + includes/filter",": 가능한데 “포함 여부”가 커지면 의도가 흐려집니다.",[34,275],{},[37,277,279],{"id":278},"구현코드","구현(코드)",[85,281,283],{"id":282},"_1-object를-사전처럼-쓸-때-프로토타입-영향-피하기","1) Object를 “사전”처럼 쓸 때: 프로토타입 영향 피하기",[117,285,289],{"className":286,"code":287,"language":288,"meta":122,"style":122},"language-javascript shiki shiki-themes github-dark","const dict = { a: 1 };\n\n// in은 프로토타입 체인까지 확인합니다.\nconsole.log(\"toString\" in dict); // true\n\n// 내 프로퍼티인지 확인하려면 Object.hasOwn을 사용합니다.\nconsole.log(Object.hasOwn(dict, \"toString\")); // false\nconsole.log(Object.hasOwn(dict, \"a\"));        // true\n","javascript",[29,290,291,314,320,326,351,355,360,383],{"__ignoreMap":122},[126,292,293,297,301,304,308,311],{"class":128,"line":