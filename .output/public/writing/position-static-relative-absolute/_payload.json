per.mozilla.org/en-US/docs/Web/CSS/transform",[132],"MDN: transform",[98,1370,1372],{"id":1371},"q5-오버레이헤더는-absolute로-끝내면-안-되나","Q5. 오버레이/헤더는 absolute로 끝내면 안 되나?",[15,1374,1375,1376,1378,1379,1382],{},"A. 스크롤/뷰포트 고정이 목적이면 ",[23,1377,1071],{},"가 더 명확한 선택이고, 스크롤 컨테이너 내부에서 붙어야 하면 ",[23,1380,1381],{},"sticky","가 대안이 된다.",[15,1384,295,1385],{},[128,1386,300],{"href":298,"rel":1387},[132],[53,1389],{},[56,1391,1393],{"id":1392},"요약35줄","요약(3~5줄)",[64,1395,1396,1401,1415,1420],{},[67,1397,1398,1400],{},[23,1399,25],{}," 문제는 “컨테이닝 블록”과 “쌓임 맥락”을 분리해 보면 빨리 풀린다.",[67,1402,1403,242,1405,1408,1409,1075,1411,1414],{},[23,1404,193],{},[18,1406,1407],{},"선택된 기준점","을 기준으로 붙고, 기준점은 ",[23,1410,25],{},[23,1412,1413],{},"transform/filter/contain"," 등에서도 생길 수 있다.",[67,1416,1417,1419],{},[23,1418,305],{},"는 자리를 유지한 채 “보이기만 이동”한다.",[67,1421,1422,1424,1425,1428],{},[23,1423,43],{},"는 같은 쌓임 맥락에서만 의미가 있으니, 숫자보다 ",[18,1426,1427],{},"맥락 구조","를 먼저 점검한다.",[53,1430],{},[56,1432,1433],{"id":1433},"결론",[15,1435,1436,1439,1440,1443],{},[23,1437,1438],{},"static / relative / absolute","를 외우는 것보다, ",[18,1441,1442],{},"기준점(컨테이닝 블록)과 겹침(쌓임 맥락)을 먼저 고정하는 습관","이 더 강력하다.",[15,1445,1446,1447,1449,1450,1452],{},"부모에 ",[23,1448,340],{},"를 주는 패턴은 여전히 유효하지만, 중간 조상의 ",[23,1451,1413],{}," 같은 “숨은 기준점”까지 함께 점검하면 배치 버그가 훨씬 덜 반복된다.",[53,1454],{},[56,1456,1458],{"id":1457},"참고공식-문서-링크","참고(공식 문서 링크)",[64,1460,1461,1466,1471,1476,1481,1486,1491],{},[67,1462,1463],{},[128,1464,379],{"href":377,"rel":1465},[132],[67,1467,1468],{},[128,1469,300],{"href":298,"rel":1470},[132],[67,1472,1473],{},[128,1474,133],{"href":130,"rel":1475},[132],[67,1477,1478],{},[128,1479,258],{"href":256,"rel":1480},[132],[67,1482,1483],{},[128,1484,265],{"href":263,"rel":1485},[132],[67,1487,1488],{},[128,1489,1368],{"href":1366,"rel":1490},[132],[67,1492,1493],{},[128,1494,1497],{"href":1495,"rel":1496},"https://mermaid.js.org/",[132],"Mermaid Docs",[1499,1500,1501],"style",{},"html .default .shiki span {color: var(--shiki-default);background: v