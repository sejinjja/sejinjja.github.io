[{"data":1,"prerenderedAt":1514},["ShallowReactive",2],{"writing:meta:/writing/ssr-hydration-optimization":3},{"id":4,"title":5,"body":6,"date":1503,"description":15,"extension":1504,"meta":1505,"navigation":320,"notionPageId":1506,"path":1507,"seo":1508,"source":1509,"stem":1510,"tags":1511,"__hash__":1513},"content/writing/ssr-hydration-optimization.md","필요한 만큼만 Hydrate하라: SSR과 Hydration의 진짜 비용",{"type":7,"value":8,"toc":1473},"minimark",[9,16,23,29,32,39,46,49,77,79,84,89,108,112,128,130,134,137,146,150,175,177,181,184,212,214,218,221,247,250,252,256,259,271,275,622,948,958,960,964,971,975,1141,1149,1276,1289,1291,1295,1298,1301,1320,1322,1326,1329,1333,1359,1363,1385,1387,1391,1402,1405,1425,1427,1431,1458,1460,1464,1469],[10,11,12],"blockquote",{},[13,14,15],"p",{},"SSR이 빠르다고 느껴지는 이유와, Hydration이 실제로 어디에서 병목이 되는지. Next.js/Nuxt에서 바로 적용 가능한 전략까지.",[13,17,18,22],{},[19,20,21],"strong",{},"태그:"," SSR, Hydration, Next.js, Nuxt, Web Performance, SEO",[13,24,25,28],{},[19,26,27],{},"작성일:"," 2026-02-10",[30,31],"hr",{},[13,33,34,35,38],{},"SSR(Server Side Rendering)을 도입하면 ",[19,36,37],{},"초기 화면이 빨라지고 SEO가 좋아진다","는 이야기는 익숙합니다. 그런데 실무에서 \"SSR 했는데도 체감이 느려요\", \"초기 화면은 뜨는데 클릭이 안 먹어요\" 같은 상황이 자주 발생합니다.",[13,40,41,42,45],{},"대부분의 원인은 ",[19,43,44],{},"Hydration 비용을 과소평가","했기 때문입니다.",[13,47,48],{},"이 글은 다음 흐름으로 정리합니다.",[50,51,52,64,70],"ol",{},[53,54,55,56,60,61,63],"li",{},"SSR이 ",[57,58,59],"em",{},"무엇을"," 해결하고 ",[57,62,59],{}," 해결하지 못하는지",[53,65,66,67],{},"Hydration이 _어떤 작업_을 하고 ",[57,68,69],{},"왜 무거운지",[53,71,72,73,76],{},"Next.js / Nuxt에서 ",[19,74,75],{},"'필요한 만큼만' Hydrate","하는 실전 전략",[30,78],{},[80,81,83],"h2",{"id":82},"_1-ssr이-해결하는-것-vs-해결하지-못하는-것","1. SSR이 해결하는 것 vs 해결하지 못하는 것",[85,86,88],"h3",{"id":87},"ssr이-해결하는-것","SSR이 해결하는 것",[90,91,92,98,105],"ul",{},[53,93,94,97],{},[19,95,96],{},"초기 HTML이 이미 완성되어 내려옴"," → 브라우저가 빠르게 페인트 가능",[53,99,100,101,104],{},"크롤러가 ",[19,102,103],{},"즉시 콘텐츠를 읽을 수 있음"," → SEO에 유리",[53,106,107],{},"느린 네트워크/저사양에서도 \"일단 보인다\"를 달성하기 쉬움",[85,109,111],{"id":110},"ssr이-해결하지-못하는-것","SSR이 해결하지 못하는 것",[90,113,114,125],{},[53,115,116,117,120,121,124],{},"SSR HTML은 ",[19,118,119],{},"정적 상태","입니다. 즉, 버튼 클릭/입력/드롭다운 같은 상호작용은 ",[19,122,123],{},"JS가 붙기 전까지는 불가능","합니다.",[53,126,127],{},"따라서 SSR만으로는 **TTI(Time To Interactive)**를 보장하지 못합니다. (눈에는 보이는데, 손이 안 닿는 화면)",[30,129],{},[80,131,133],{"id":132},"_2-hydration이-실제로-하는-일","2. Hydration이 실제로 하는 일",[13,135,136],{},"Hydration은 간단히 말하면:",[10,138,139],{},[13,140,141,142,145],{},"\"서버가 만든 HTML\" 위에\n\"클라이언트 JS가 가진 가상 DOM/렌더 결과\"를 맞춰보고,\n이벤트 핸들러를 연결해 ",[19,143,144],{},"상호작용 가능한 앱 상태","로 바꾸는 과정",[85,147,149],{"id":148},"hydration-중에-비용이-커지는-지점","Hydration 중에 비용이 커지는 지점",[90,151,152,158,163,169],{},[53,153,154,157],{},[19,155,156],{},"컴포넌트 트리 전부 실행"," (렌더 함수/템플릿 평가, 훅 실행, 계산 속성/워처 초기화 등)",[53,159,160],{},[19,161,162],{},"이벤트 리스너 부착",[53,164,165,168],{},[19,166,167],{},"DOM 매칭/검증"," 서버 HTML과 클라이언트 렌더 결과가 다르면 \"Hydration mismatch\"가 발생하며 추가 비용/경고/재렌더가 생김",[53,170,171,174],{},[19,172,173],{},"추가 데이터 패칭이 겹침"," 서버에서도 데이터 요청, 클라이언트에서도 다시 요청 → 낭비 + 지연",[30,176],{},[80,178,180],{"id":179},"_3-증상으로-빠르게-원인-찾기-체크리스트","3. 증상으로 빠르게 원인 찾기 (체크리스트)",[13,182,183],{},"아래 중 하나라도 자주 보이면 Hydration 병목일 가능성이 큽니다.",[90,185,186,192,199,202,209],{},[53,187,188,189],{},"초기 화면은 빨리 보이는데, ",[19,190,191],{},"스크롤/클릭이 1~2초 먹통",[53,193,194,195,198],{},"Lighthouse에서 ",[19,196,197],{},"TBT/INP","가 나쁨",[53,200,201],{},"\"Hydration mismatch\" 경고가 간헐적으로 뜸",[53,203,204,205,208],{},"리스트/카드/차트처럼 ",[19,206,207],{},"DOM이 많은 구간","에서 초기 인터랙션이 느림",[53,210,211],{},"3rd-party 스크립트(analytics, chat widget)가 초기 로딩에 붙어있음",[30,213],{},[80,215,217],{"id":216},"_4-전략-필요한-만큼만-hydrate하기","4. 전략: \"필요한 만큼만\" Hydrate하기",[13,219,220],{},"핵심은 단순합니다.",[90,222,223,233,240],{},[53,224,225,228,229,232],{},[19,226,227],{},"보이는 것","과 ",[19,230,231],{},"상호작용하는 것","을 분리한다.",[53,234,235,236,239],{},"상호작용이 필요한 영역만 ",[19,237,238],{},"클라이언트 컴포넌트","로 두고, 나머지는 **서버 렌더(또는 정적)**로 유지한다.",[53,241,242,243,246],{},"사용자 행동(스크롤/클릭/뷰포트 진입)에 맞춰 ",[19,244,245],{},"점진적으로"," Hydrate한다.",[13,248,249],{},"아래는 실무에서 바로 적용 가능한 패턴들입니다.",[30,251],{},[80,253,255],{"id":254},"_5-패턴-a-인터랙션-껍데기만-클라이언트로","5. 패턴 A: 인터랙션 \"껍데기\"만 클라이언트로",[85,257,258],{"id":258},"아이디어",[90,260,261,264],{},[53,262,263],{},"카드 목록 UI는 SSR로 빠르게 보여준다.",[53,265,266,267,270],{},"\"좋아요 버튼\", \"장바구니 담기\" 같은 ",[19,268,269],{},"작은 상호작용만"," 클라이언트로 감싼다.",[85,272,274],{"id":273},"nextjsapp-router-예시","Next.js(App Router) 예시",[276,277,282],"pre",{"className":278,"code":279,"language":280,"meta":281,"style":281},"language-typescript shiki shiki-themes github-dark","// app/products/page.tsx (Server Component)\nimport LikeButton from \"./LikeButton\";\n\nexport default async function ProductsPage() {\n  const products = await fetch(\"https://example.com/api/products\", { cache: \"no-store\" })\n    .then(r => r.json());\n\n  return (\n    \u003Cmain>\n      \u003Ch1>Products\u003C/h1>\n      \u003Cul>\n        {products.map((p: any) => (\n          \u003Cli key={p.id}>\n            \u003Cstrong>{p.name}\u003C/strong>\n            \u003Cspan> · {p.price}\u003C/span>\n            \u003CLikeButton productId={p.id} initialLiked={p.liked} />\n          \u003C/li>\n        ))}\n      \u003C/ul>\n    \u003C/main>\n  );\n}\n","typescript","",[283,284,285,294,315,322,344,378,405,410,419,431,450,459,493,510,527,553,574,584,590,600,610,616],"code",{"__ignoreMap":281},[286,287,290],"span",{"class":288,"line":289},"line",1,[286,291,293],{"class":292},"sAwPA","// app/products/page.tsx (Server Component)\n",[286,295,297,301,305,308,312],{"class":288,"line":296},2,[286,298,300],{"class":299},"snl16","import",[286,302,304],{"class":303},"s95oV"," LikeButton ",[286,306,307],{"class":299},"from",[286,309,311],{"class":310},"sU2Wk"," \"./LikeButton\"",[286,313,314],{"class":303},";\n",[286,316,318],{"class":288,"line":317},3,[286,319,321],{"emptyLinePlaceholder":320},true,"\n",[286,323,325,328,331,334,337,341],{"class":288,"line":324},4,[286,326,327],{"class":299},"export",[286,329,330],{"class"