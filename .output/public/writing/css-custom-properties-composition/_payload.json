107,110],{},"CSS 커스텀 프로퍼티(CSS Custom Properties)는 ",[26,104,105],{},"--token"," 형태로 선언하고, ",[26,108,109],{},"var()","로 꺼내 쓴다.",[15,112,113,114,117],{},"이 값은 **캐스케이드(cascade)**와 ",[19,115,116],{},"상속(inheritance)"," 규칙을 따라 “가까운 선언”이 우선한다.",[15,119,120],{},"아래 다이어그램을 보면, “어디에 변수를 선언하느냐”가 곧 “적용 범위”가 된다.",[122,123,128],"pre",{"className":124,"code":125,"language":126,"meta":127,"style":127},"language-mermaid shiki shiki-themes github-dark","flowchart TD\n  subgraph Color[\"색상 변수의 해석 흐름\"]\n    R[\":root\u003Cbr/>--text-color: red\"] -->|\"기본값 제공\"| S[\"하위 요소로 상속\"]\n    T[\".title\u003Cbr/>--text-color: green\"] -->|\"더 가까운 선언이 우선\"| S\n    S -->|\"color: var(--text-color)\"| C[\"실제 텍스트 색상 결정\"]\n  end\n\n  subgraph Transform[\"transform 조립 흐름\"]\n    B[\".btn\u003Cbr/>transform: scale(var(--big, 1))\u003Cbr/>skew(var(--skew, 0deg))\"] -->|\"기본 형태 고정\"| K[\"필요한 값만 주입\"]\n    G[\".big\u003Cbr/>--big: 1.5\"] -->|\"옵션 값\"| K\n    W[\".skew\u003Cbr/>--skew: 30deg\"] -->|\"옵션 값\"| K\n    K -->|\"클래스 조합\"| O[\"transform이 '조립'되어 적용\"]\n  end\n","mermaid","",[26,129,130,138,144,150,156,162,168,175,181,187,193,199,205],{"__ignoreMap":127},[131,132,135],"span",{"class":133,"line":134},"line",1,[131,136,137],{},"flowchart TD\n",[131,139,141],{"class":133,"line":140},2,[131,142,143],{},"  subgraph Color[\"색상 변수의 해석 흐름\"]\n",[131,145,147],{"class":133,"line":146},3,[131,148,149],{},"    R[\":root\u003Cbr/>--text-color: red\"] -->|\"기본값 제공\"| S[\"하위 요소로 상속\"]\n",[131,151,153],{"class":133,"line":152},4,[131,154,155],{},"    T[\".title\u003Cbr/>--text-color: green\"] -->|\"더 가까운 선언이 우선\"| S\n",[131,157,159],{"class":133,"line":158},5,[131,160,161],{},"    S -->|\"color: var(--text-color)\"| C[\"실제 텍스트 색상 결정\"]\n",[131,163,165],{"class":133,"line":164},6,[131,166,167],{},"  end\n",[131,169,171],{"class":133,"line":170},7,[131,172,174],{"emptyLinePlaceholder":173},true,"\n",[131,176,178],{"class":133,"line":177},8,[131,179,180],{},"  subgraph Transform[\"transform 조립 흐름\"]\n",[131,182,1