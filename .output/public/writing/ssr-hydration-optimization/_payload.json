1366,1367],{},"랜덤/시간 값은 렌더가 아니라 **이펙트(마운트 이후)**에서 채운다.",[53,1369,1370,1373,1374,1377,1378,1381],{},[283,1371,1372],{},"window","/",[283,1375,1376],{},"document"," 접근은 ",[19,1379,1380],{},"클라이언트 전용 코드","로 격리한다.",[53,1383,1384],{},"포맷은 서버와 클라이언트가 동일한 기준을 쓰게 한다(특히 날짜).",[30,1386],{},[80,1388,1390],{"id":1389},"_9-결론-ssr은-보이게-하고-hydration은-만지게-한다","9. 결론: SSR은 \"보이게\" 하고, Hydration은 \"만지게\" 한다",[13,1392,1393,1394,1397,1398,1401],{},"SSR로는 ",[19,1395,1396],{},"초기 화면의 인지 속도","를 개선합니다. Hydration으로는 ",[19,1399,1400],{},"상호작용 가능 상태","를 완성합니다.",[13,1403,1404],{},"그래서 성능 목표를 이렇게 잡는 게 실무적으로 낫습니다.",[90,1406,1407,1413,1419],{},[53,1408,1409,1412],{},[19,1410,1411],{},"SSR로 LCP를 당긴다"," (빠르게 보이게)",[53,1414,1415,1418],{},[19,1416,1417],{},"Hydration 범위를 줄인다"," (빠르게 만지게)",[53,1420,1421,1424],{},[19,1422,1423],{},"무거운 컴포넌트는 늦춘다"," (필요할 때만)",[30,1426],{},[80,1428,1430],{"id":1429},"부록-빠른-의사결정-매트릭스","부록: 빠른 의사결정 매트릭스",[90,1432,1433,1442,1450],{},[53,1434,1435,1438,1441],{},[19,1436,1437],{},"SEO 중요 + 콘텐츠 중심 페이지",[1439,1440],"br",{},"→ SSR/SSG 중심, 인터랙션은 부분 클라이언트화",[53,1443,1444,1447,1449],{},[19,1445,1446],{},"대시보드/앱성 UI (인터랙션이 대부분)",[1439,1448],{},"→ SSR은 최소(껍데기/레이아웃), 본체는 클라이언트 + 캐시/코드스플릿",[53,1451,1452,1455,1457],{},[19,1453,1454],{},"3rd-party 스크립트가 많음",[1439,1456],{},"→ 초기 로딩에서 분리(지연 로딩), 성능 영향 측정 후 단계적 적용",[30,1459],{},[80,1461,1463],{"id":1462},"한-줄-요약","한 줄 요약",[10,1465,1466],{},[13,1467,1468],{},"SSR은 \"빨리 보이게\" 만들고, Hydration은 \"빨리 만지게\" 만든다.\n둘 중 하나만 최적화하면 체감 성능은 절반만 좋아진다.",[1470,1471,1472],"style",{},"html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}html pre.shiki code .snl16, html code.shiki .snl16{--shiki-default:#F97583}html pre.shiki code .s95oV, html code.shiki .s95oV{--shiki-default:#E1E4E8}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}html pre.shiki code .s9osk, html 