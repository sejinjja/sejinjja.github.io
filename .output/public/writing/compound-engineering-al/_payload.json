[{"data":1,"prerenderedAt":302},["ShallowReactive",2],{"writing:meta:/writing/compound-engineering-al":3},{"id":4,"title":5,"body":6,"date":291,"description":292,"extension":293,"meta":294,"navigation":105,"notionPageId":295,"path":296,"seo":297,"source":298,"stem":299,"tags":300,"__hash__":301},"content/writing/compound-engineering-al.md","Compound Engineering: Al 네이티브 엔지니어링 철학",{"type":7,"value":8,"toc":273},"minimark",[9,13,18,22,27,30,43,47,51,54,58,70,73,76,171,174,178,182,187,191,196,233,237,242,246,251,255,260,263,266,269],[10,11,5],"h1",{"id":12},"compound-engineering-al-네이티브-엔지니어링-철학",[14,15,17],"h2",{"id":16},"compound-engineering이란","Compound Engineering이란?",[19,20,21],"p",{},"Compound Engineering은 여러 기술 요소를 결합하여 효과적으로 문제를 해결하는 엔지니어링 접근 방식입니다. 복잡한 문제를 해결할 때 여러 가지 기술과 방법론을 체계적으로 통합하는 것이 핵심입니다.",[23,24,26],"h3",{"id":25},"왜-compound-engineering이-중요한가","왜 Compound Engineering이 중요한가?",[19,28,29],{},"오늘날의 소프트웨어 개발 환경은 점점 더 복잡해지고 있습니다. 이러한 복잡성을 관리하고, 다음과 같은 장점을 이끌어내기 위해 Compound Engineering 철학이 주목받고 있습니다.",[31,32,33,37,40],"ul",{},[34,35,36],"li",{},"효율성 향상: 여러 기술을 결합해 시너지를 발휘",[34,38,39],{},"유지보수성 개선: 통합된 솔루션을 통한 코드 품질 향상",[34,41,42],{},"확장성 강화: 유연한 구조를 활용해 추가 요구사항 수용",[14,44,46],{"id":45},"al-네이티브-엔지니어링","Al 네이티브 엔지니어링",[23,48,50],{"id":49},"개념-설명","개념 설명",[19,52,53],{},"Al 네이티브 엔지니어링은 인공지능(AI)을 개발 프로세스에 기본으로 통합하는 방식을 의미합니다. 이는 AI의 강력한 분석 및 자동화 기능을 활용하여 효율적이고 지능적인 개발 환경을 구축합니다.",[23,55,57],{"id":56},"적용-방법","적용 방법",[59,60,61,64,67],"ol",{},[34,62,63],{},"기초 기술 학습",[34,65,66],{},"AI 기반 개발 도구 활용",[34,68,69],{},"성능 최적화",[23,71,72],{"id":72},"예시",[19,74,75],{},"AI 기반의 코드를 간단히 예로 들어보겠습니다. 머신 러닝을 활용해 데이터를 예측하는 Python 코드입니다.",[77,78,83],"pre",{"className":79,"code":80,"language":81,"meta":82,"style":82},"language-python shiki shiki-themes github-dark","from sklearn.linear_model import LinearRegression\nimport numpy as np\n\n# 예제 데이터\nX = np.array([[1], [2], [3], [4]])\ny = np.array([2, 4, 6, 8])\n\n# 모델 초기화\nmodel = LinearRegression()\nmodel.fit(X, y)\n\n# 예측\nprediction = model.predict(np.array([[5]]))\nprint(\"예측 결과:\", prediction)\n","python","",[84,85,86,94,100,107,113,119,125,130,136,142,148,153,159,165],"code",{"__ignoreMap":82},[87,88,91],"span",{"class":89,"line":90},"line",1,[87,92,93],{},"from sklearn.linear_model import LinearRegression\n",[87,95,97],{"class":89,"line":96},2,[87,98,99],{},"import numpy as np\n",[87,101,103],{"class":89,"line":102},3,[87,104,106],{"emptyLinePlaceholder":105},true,"\n",[87,108,110],{"class":89,"line":109},4,[87,111,112],{},"# 예제 데이터\n",[87,114,116],{"class":89,"line":115},5,[87,117,118],{},"X = np.array([[1], [2], [3], [4]])\n",[87,120,122],{"class":89,"line":121},6,[87,123,124],{},"y = np.array([2, 4, 6, 8])\n",[87,126,128],{"class":89,"line":127},7,[87,129,106],{"emptyLinePlaceholder":105},[87,131,133],{"class":89,"line":132},8,[87,134,135],{},"# 모델 초기화\n",[87,137,139],{"class":89,"line":138},9,[87,140,141],{},"model = LinearRegression()\n",[87,143,145],{"class":89,"line":144},10,[87,146,147],{},"model.fit(X, y)\n",[87,149,151],{"class":89,"line":150},11,[87,152,106],{"emptyLinePlaceholder":105},[87,154,156],{"class":89,"line":155},12,[87,157,158],{},"# 예측\n",[87,160,162],{"class":89,"line":161},13,[87,163,164],{},"prediction = model.predict(np.array([[5]]))\n",[87,166,168],{"class":89,"line":167},14,[87,169,170],{},"print(\"예측 결과:\", prediction)\n",[19,172,173],{},"이 예시에서는 sklearn 라이브러리를 활용해 간단한 선형 회귀 모델을 만듭니다. 데이터 학습 후 새로운 입력에 대한 예측을 수행합니다.",[14,175,177],{"id":176},"단계별-실천-방법","단계별 실천 방법",[23,179,181],{"id":180},"_1-요구사항-분석","1. 요구사항 분석",[31,183,184],{},[34,185,186],{},"문제를 명확히 정의하고 목표를 설정합니다.",[23,188,190],{"id":189},"_2-기술-선택-및-결합-전략-수립","2. 기술 선택 및 결합 전략 수립",[31,192,193],{},[34,194,195],{},"프로젝트에 적합한 AI 도구와 기술 스택을 선택합니다.",[77,197,201],{"className":198,"code":199,"language":200,"meta":82,"style":82},"language-mermaid shiki shiki-themes github-dark","graph TD;\n  기술선택 --> AI\n  기술선택 --> 클라우드서비스\n  기술선택 --> 데이터베이스\n  AI --> 머신러닝\n  AI --> 데이터분석\n","mermaid",[84,202,203,208,213,218,223,228],{"__ignoreMap":82},[87,204,205],{"class":89,"line":90},[87,206,207],{},"graph TD;\n",[87,209,210],{"class":89,"line":96},[87,211,212],{},"  기술선택 --> AI\n",[87,214,215],{"class":89,"line":102},[87,216,217],{},"  기술선택 --> 클라우드서비스\n",[87,219,220],{"class":89,"line":109},[87,221,222],{},"  기술선택 --> 데이터베이스\n",[87,224,225],{"class":89,"line":115},[87,226,227],{},"  AI --> 머신러닝\n",[87,229,230],{"class":89,"line":121},[87,231,232],{},"  AI --> 데이터분석\n",[23,234,236],{"id":235},"_3-프로토타입-개발","3. 프로토타입 개발",[31,238,239],{},[34,240,241],{},"초기 버전을 개발하여 테스트 및 피드백 수집",[23,243,245],{"id":244},"_4-반복적-개발-및-최적화","4. 반복적 개발 및 최적화",[31,247,248],{},[34,249,250],{},"Agile 방법론을 적용하여 여러 차례 반복적 개발",[23,252,254],{"id":253},"_5-배포-및-모니터링","5. 배포 및 모니터링",[31,256,257],{},[34,258,259],{},"결과를 배포하고 성능을 모니터링합니다.",[14,261,262],{"id":262},"결론",[19,264,265],{},"Compound Engineering과 AI 네이티브 엔지니어링 철학은 현대 개발의 중요한 요소입니다. 이를 잘 활용하면 기술적 난관을 효과적으로 극복하고, 더 나은 개발 환경을 조성할 수 있습니다. 무엇보다 초보자도 이러한 철학을 이해하고 적용할 수 있도록 쉬운 접근방법을 제시했습니다.",[19,267,268],{},"지금까지의 내용을 바탕으로 여러분의 프로젝트에 적용해 보세요. 개발의 새로운 가능성을 체감할 수 있을 것입니다.",[270,271,272],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":82,"searchDepth":96,"depth":96,"links":274},[275,278,283,290],{"id":16,"depth":96,"text":17,"children":276},[277],{"id":25,"depth":102,"text":26},{"id":45,"depth":96,"text":46,"children":279},[280,281,282],{"id":49,"depth":102,"text":50},{"id":56,"depth":102,"text":57},{"id":72,"depth":102,"text":72},{"id":176,"depth":96,"text":177,"children":284},[285,286,287,288,289],{"id":180,"depth":102,"text":181},{