[{"data":1,"prerenderedAt":916},["ShallowReactive",2],{"writing:meta:/writing/circuit-switching-vs-packet-switching":3},{"id":4,"title":5,"body":6,"date":904,"description":905,"extension":906,"meta":907,"navigation":187,"notionPageId":908,"path":909,"seo":910,"source":911,"stem":912,"tags":913,"__hash__":915},"content/writing/circuit-switching-vs-packet-switching.md","경로를 고정할지, 패킷을 흘려보낼지: 회선 교환 vs 패킷 교환",{"type":7,"value":8,"toc":880},"minimark",[9,13,16,19,22,25,30,33,41,54,56,60,65,68,88,92,99,116,122,124,128,236,239,241,245,248,271,274,297,299,303,310,314,409,412,414,418,559,562,564,568,674,677,686,688,692,745,747,751,755,758,762,765,769,772,776,783,785,789,803,805,808,811,814,817,819,823,876],[10,11,12],"p",{},"회선 교환은 통신 전에 전용 경로(회선)를 “예약”하고, 패킷 교환은 데이터를 쪼개 네트워크 자원을 “공유”하며 보냅니다.",[10,14,15],{},"웹/백엔드에서 이 차이를 알아두면 지연 시간(latency)과 지터(jitter)가 왜 흔들리는지 설명이 됩니다.",[10,17,18],{},"또, 타임아웃·재시도·멱등성(idempotency) 같은 설계 포인트가 “왜 필요한지”가 명확해집니다.",[10,20,21],{},"정리하면, 네트워크가 공유 자원이라는 전제를 코드와 운영에 반영하는 일이 핵심입니다.",[23,24],"hr",{},[26,27,29],"h2",{"id":28},"배경문제","배경/문제",[10,31,32],{},"전화처럼 “통화 중에는 품질이 일정한 연결”이 필요한 시스템이 있는 반면, 인터넷처럼 “여러 트래픽이 동시에 섞여 흘러도 되는” 시스템도 있습니다.",[10,34,35,36,40],{},"문제는 개발자가 패킷 교환 환경에서 ",[37,38,39],"strong",{},"회선 교환처럼 동작할 거라 기대","할 때 생깁니다.",[42,43,44,48,51],"ul",{},[45,46,47],"li",{},"요청이 가끔 느려지는 이유를 서버 문제로만 오해한다",[45,49,50],{},"재시도를 아무 요청에나 붙여 중복 처리(이중 결제 등)를 만든다",[45,52,53],{},"“연결(connection)”이라는 단어를 보고 물리적으로 고정된 경로라고 착각한다",[23,55],{},[26,57,59],{"id":58},"핵심-개념","핵심 개념",[61,62,64],"h3",{"id":63},"_1-회선-교환circuit-switching","1) 회선 교환(Circuit Switching)",[10,66,67],{},"통신을 시작하기 전에 송신자와 수신자 사이에 **전용 경로를 설정(호 설정)**하고, 통신이 끝날 때까지 그 경로의 자원을 점유하는 방식입니다.",[42,69,70,76,82],{},[45,71,72,75],{},[37,73,74],{},"왜 하는지:"," 통신 중 품질(대역폭/지연)을 예측 가능하게 만들기 위해",[45,77,78,81],{},[37,79,80],{},"기대 결과:"," 통신 중에는 비교적 일정한 품질을 기대할 수 있음(자원이 예약되므로)",[45,83,84,87],{},[37,85,86],{},"트레이드오프:"," 사용하지 않는 순간에도 자원을 점유해 효율이 낮아질 수 있음",[61,89,91],{"id":90},"_2-패킷-교환packet-switching","2) 패킷 교환(Packet Switching)",[10,93,94,95,98],{},"메시지를 ",[37,96,97],{},"패킷(packet)"," 으로 쪼개 보내고, 네트워크는 그 순간순간의 상태에 따라 패킷을 전달합니다. 목적지에서는 패킷을 다시 조립합니다.",[42,100,101,106,111],{},[45,102,103,105],{},[37,104,74],{}," 여러 통신이 네트워크 자원을 공유하면서도 확장 가능하게 만들기 위해",[45,107,108,110],{},[37,109,80],{}," 회선 예약 없이도 많은 트래픽을 수용(높은 이용 효율)",[45,112,113,115],{},[37,114,86],{}," 혼잡(congestion)에 따라 지연, 손실, 순서 뒤바뀜(재정렬) 등이 발생할 수 있음",[117,118,119],"blockquote",{},[10,120,121],{},"포인트는 “고정된 한 줄”이 아니라, “공유 도로에서 교통량에 따라 달라지는 흐름”에 가깝다는 점입니다.",[23,123],{},[61,125,127],{"id":126},"구조로-비교하기-mermaid","구조로 비교하기 (Mermaid)",[129,130,135],"pre",{"className":131,"code":132,"language":133,"meta":134,"style":134},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  subgraph CS[\"회선 교환\u003Cbr/>Dedicated path\"]\n    A1[\"송신자\"] -->|\"호 설정(경로 예약)\"| S1[\"교환기/스위치\"]\n    S1 -->|\"전용 경로 유지\"| S2[\"교환기/스위치\"]\n    S2 -->|\"호 설정 완료\"| B1[\"수신자\"]\n    A1 -->|\"데이터 전송(예약된 경로)\"| B1\n  end\n\n  subgraph PS[\"패킷 교환\u003Cbr/>Shared network\"]\n    A2[\"송신자\"] -->|\"패킷 분할\"| P0[\"Packet 1..n\"]\n    P0 -->|\"라우팅 테이블 기준 전달\"| R1[\"라우터\"]\n    P0 -->|\"혼잡/정책에 따라 변동\"| R2[\"라우터\"]\n    R1 -->|\"패킷 전달\"| B2[\"수신자\"]\n    R2 -->|\"패킷 전달\"| B2\n    B2 -->|\"재조립(순서/손실 처리)\"| C2[\"원본 메시지\"]\n  end\n","mermaid","",[136,137,138,146,152,158,164,170,176,182,189,195,201,207,213,219,225,231],"code",{"__ignoreMap":134},[139,140,143],"span",{"class":141,"line":142},"line",1,[139,144,145],{},"flowchart LR\n",[139,147,149],{"class":141,"line":148},2,[139,150,151],{},"  subgraph CS[\"회선 교환\u003Cbr/>Dedicated path\"]\n",[139,153,155],{"class":141,"line":154},3,[139,156,157],{},"    A1[\"송신자\"] -->|\"호 설정(경로 예약)\"| S1[\"교환기/스위치\"]\n",[139,159,161],{"class":141,"line":160},4,[139,162,163],{},"    S1 -->|\"전용 경로 유지\"| S2[\"교환기/스위치\"]\n",[139,165,167],{"class":141,"line":166},5,[139,168,169],{},"    S2 -->|\"호 설정 완료\"| B1[\"수신자\"]\n",[139,171,173],{"class":141,"line":172},6,[139,174,175],{},"    A1 -->|\"데이터 전송(예약된 경로)\"| B1\n",[139,177,179],{"class":141,"line":178},7,[139,180,181],{},"  end\n",[139,183,185],{"class":141,"line":184},8,[139,186,188],{"emptyLinePlaceholder":187},true,"\n",[139,190,192],{"class":141,"line":191},9,[139,193,194],{},"  subgraph PS[\"패킷 교환\u003Cbr/>Shared network\"]\n",[139,196,198],{"class":141,"line":197},10,[139,199,200],{},"    A2[\"송신자\"] -->|\"패킷 분할\"| P0[\"Packet 1..n\"]\n",[139,202,204],{"class":141,"line":203},11,[139,205,206],{},"    P0 -->|\"라우팅 테이블 기준 전달\"| R1[\"라우터\"]\n",[139,208,210],{"class":141,"line":209},12,[139,211,212],{},"    P0 -->|\"혼잡/정책에 따라 변동\"| R2[\"라우터\"]\n",[139,214,216],{"class":141,"line":215},13,[139,217,218],{},"    R1 -->|\"패킷 전달\"| B2[\"수신자\"]\n",[139,220,222],{"class":141,"line":221},14,[139,223,224],{},"    R2 -->|\"패킷 전달\"| B2\n",[139,226,228],{"class":141,"line":227},15,[139,229,230],{},"    B2 -->|\"재조립(순서/손실 처리)\"| C2[\"원본 메시지\"]\n",[139,232,234],{"class":141,"line":233},16,[139,235,181],{},[10,237,238],{},"→ 기대 결과/무엇이 달라졌는지: “전용 경로를 예약해 유지” vs “패킷을 쪼개 공유망으로 흘려보내 재조립”이라는 차이가 한눈에 정리됩니다.",[23,240],{},[26,242,244],{"id":243},"해결-접근","해결 접근",[10,246,247],{},"백엔드/웹 개발 관점에서의 결론은 단순합니다.",[249,250,251,258,264],"ol",{},[45,252,253,254,257],{},"패킷 교환에서는 지연이 흔들릴 수 있으니 ",[37,255,256],{},"타임아웃을 명시","한다",[45,259,260,261,257],{},"손실/일시 장애가 있을 수 있으니 ",[37,262,263],{},"재시도를 설계",[45,265,266,267,270],{},"재시도는 중복을 만들 수 있으니 ",[37,268,269],{},"멱등성을 확보","한다(또는 멱등 키 사용)",[10,272,273],{},"비교/대안도 함께 잡아두면 안정적입니다.",[42,275,276,283,290],{},[45,277,278,279,282],{},"대안 A: “무조건 재시도” 대신 ",[37,280,281],{},"재시도 가능한 요청만 선별","(예: GET, 멱등 키가 있는 POST)",[45,284,285,286,289],{},"대안 B: 재시도 대신 ",[37,287,288],{},"큐(Queue) + 비동기 처리","로 전환해 사용자 요청 경로를 짧게 유지",[45,291,292,293,296],{},"대안 C: 품질이 중요한 내부 통신은 ",[37,294,295],{},"QoS/우선순위/전용망(전용 회선, VPN 등)"," 으로 변동성을 낮춤(환경/정책에 따라 적용 가능 범위가 달라질 수 있습니다.)",[23,298],{},[26,300,302],{"id":301},"구현코드","구현(코드)",[10,304,305,306,309],{},"아래 예시는 “패킷 교환 환경에서 흔한 변동성(지연/실패)”을 가정하고, Next.js에서 ",[37,307,308],{},"타임아웃 + 제한적 재시도","를 구현하는 방법입니다.",[61,311,313],{"id":312},"_1-지연실패를-일부러-만드는-api-route","1) 지연/실패를 일부러 만드는 API Route",[129,315,319],{"className":316,"code":317,"language":318,"meta":134,"style":134},"language-javascript shiki shiki-themes github-dark","// app/api/jitter/route.js\nimport { NextResponse } from \"next/server\";\n\nexport async function GET() {\n  const delayMs = 200 + Math.floor(Math.random() * 1200);\n  const fail = Math.random() \u003C 0.25;\n\n  await new Promise((r) => setTimeout(r, delayMs));\n\n  if (fail) {\n    return NextResponse.json(\n      { ok: false, reason: \"simulated transient failure\", delayMs },\n      { status: 503 }\n    );\n  }\n\n  return NextResponse.json({ ok: true, delayMs });\n}\n","javascript",[136,320,321,326,331,335,340,345,350,354,359,363,368,373,378,383,388,393,397,403],{"__ignoreMap":134},[139,322,323],{"class":141,"line":142},[139,324,325],{},"// app/api/jitter/route.js\n",[139,327,328],{"class":141,"line":148},[139,329,330],{},"import { NextResponse } from \"next/server\";\n",[139,332,333],{"class":141,"line":154},[139,334,188],{"emptyLinePlaceholder":187},[139,336,337],{"class":141,"line":160},[139,338,339],{},"export async function GET() {\n",[139,341,342],{"class":141,"line":166},[139,343,344],{},"  const delayMs = 200 + Math.floor(Math.random() * 1200);\n",[139,346,347],{"class":141,"line":172},[139,348,349],{},"  const fail = Math.random() \u003C 0.25;\n",[139,351,352],{"class":141,"line":178},[139,353,188],{"emptyLinePlaceholder":187},[139,355,356],{"class":141,"line":184},[139,357,358],{},"  await new Promise((r) => setTimeout(r, delayMs));\n",[139,360,361],{"class":141,"line":191},[139,362,188],{"emptyLinePlaceholder":187},[139,364,365],{"class":141,"line":197},[139,366,367],{},"  if (fail) {\n",[139,369,370],{"class":141,"line":203},[139,371,372],{},"    return NextResponse.json(\n",[139,374,375],{"class":141,"line":209},[139,376,377],{},"      { ok: false, reason: \"simulated transient failure\", delayMs },\n",[139,379,380],{"class":141,"line":215},[139,381,382],{},"      { status: 503 }\n",[139,384,385],{"class":141,"line":221},[139,386,387],{},"    );\n",[139,389,390],{"class":141,"line":227},[139,391,392],{},"  }\n",[139,394,395],{"class":141,"line":233},[139,396,188],{"emptyLinePlaceholder":187},[139,398,400],{"class":141,"line":399},17,[139,401,402],{},"  return NextResponse.json({ ok: true, delayMs });\n",[139,404,406],{"class":141,"line":405},18,[139,407,408],{},"}\n",[10,410,411],{},"→ 기대 결과/무엇이 달라졌는지: 요청이 가끔 느려지고(지터), 가끔 실패(일시 장애)하는 상황을 재현할 수 있습니다.",[23,413],{},[61,415,417],{"id":416},"_2-타임아웃-재시도-유틸","2) 타임아웃 + 재시도 유틸",[129,419,421],{"className":316,"code":420,"language":318,"meta":134,"style":134},"// lib/network.js\nexport async function fetchWithTimeout(url, { timeoutMs = 800, ...init } = {}) {\n  const controller = new AbortController();\n  const timer = setTimeout(() => controller.abort(), timeoutMs);\n\n  try {\n    return await fetch(url, { ...init, signal: controller.signal });\n  } finally {\n    clearTimeout(timer);\n  }\n}\n\nexport async function retry(fn, { retries = 2, backoffMs = 200 } = {}) {\n  let lastError;\n\n  for (let attempt = 0; attempt \u003C= retries; attempt++) {\n    try {\n      return await fn(attempt);\n    } catch (e) {\n      lastError = e;\n      if (attempt === retries) break;\n      await new Promise((r) => setTimeout(r, backoffMs * (attempt + 1)));\n    }\n  }\n\n  throw lastError;\n}\n",[136,422,423,428,433,438,443,447,452,457,462,467,471,475,479,484,489,493,498,503,508,514,520,526,532,538,543,548,554],{"__ignoreMap":134},[139,424,425],{"class":141,"line":142},[139,426,427],{},"// lib/network.js\n",[139,429,430],{"class":141,"line":148},[139,431,432],{},"export async function fetchWithTimeout(url, { timeoutMs = 800, ...init } = {}) {\n",[139,434,435],{"class":141,"line":154},[139,436,437],{},"  const controller = new AbortController();\n",[139,439,440],{"class":141,"line":160},[139,441,442],{},"  const timer = setTimeout(() => controller.abort(), timeoutMs);\n",[139,444,445],{"class":141,"line":166},[139,446,188],{"emptyLinePlaceholder":187},[139,448,449],{"class":141,"line":172},[139,450,451],{},"  try {\n",[139,453,454],{"class":141,"line":178},[139,455,456],{},"    return await fetch(url, { ...init, signal: controller.signal });\n",[139,458,459],{"class":141,"line":184},[139,460,461],{},"  } finally {\n",[139,463,464],{"class":141,"line":191},[139,465,466],{},"    clearTimeout(timer);\n",[139,468,469],{"class":141,"line":197},[139,470,392],{},[139,472,473],{"class":141,"line":203},[139,474,408],{},[139,476,477],{"class":141,"line":209},[139,478,188],{"emptyLinePlaceholder":187},[139,480,481],{"class":141,"line":215},[139,482,483],{},"export async function retry(fn, { retries = 2, backoffMs = 200 } = {}) {\n",[139,485,486],{"class":141,"line":221},[139,487,488],{},"  let lastError;\n",[139,490,491],{"class":141,"line":227},[139,492,188],{"emptyLinePlaceholder":187},[139,494,495],{"class":141,"line":233},[139,496,497],{},"  for (let attempt = 0; attempt \u003C= retries; attempt++) {\n",[139,499,500],{"class":141,"line":399},[139,501,502],{},"    try {\n",[139,504,505],{"class":141,"line":405},[139,506,507],{},"      return await fn(attempt);\n",[139,509,511],{"class":141,"line":510},19,[139,512,513],{},"    } catch (e) {\n",[139,515,517],{"class":141,"line":516},20,[139,518,519],{},"      lastError = e;\n",[139,521,523],{"class":141,"line":522},21,[139,524,525],{},"      if (attempt === retries) break;\n",[139,527,529],{"class":141,"line":528},22,[139,530,531],{},"      await new Promise((r) => setTimeout(r, backoffMs * (attempt + 1)));\n",[139,533,535],{"class":141,"line":534},23,[139,536,537],{},"    }\n",[139,539,541],{"class":141,"line":540},24,[139,542,392],{},[139,544,546],{"class":141,"line":545},25,[139,547,188],{"emptyLinePlaceholder":187},[139,549,551],{"class":141,"line":550},26,[139,552,553],{},"  throw lastError;\n",[139,555,557],{"class":141,"line":556},27,[139,558,408],{},[10,560,561],{},"→ 기대 결과/무엇이 달라졌는지: “무한 대기”를 막고, 일시 장애에는 제한적으로 회복을 시도합니다.",[23,563],{},[61,565,567],{"id":566},"_3-server-component에서-호출서버에서-안정적으로-제어","3) Server Component에서 호출(서버에서 안정적으로 제어)",[129,569,571],{"className":316,"code":570,"language":318,"meta":134,"style":134},"// app/page.js\nimport { fetchWithTimeout, retry } from \"@/lib/network\";\n\nexport default async function Page() {\n  const result = await retry(async () => {\n    const res = await fetchWithTimeout(`${process.env.NEXT_PUBLIC_BASE_URL}/api/jitter`, {\n      timeoutMs: 900,\n      cache: \"no-store\",\n    });\n\n    if (!res.ok) throw new Error(`upstream failed: ${res.status}`);\n    return res.json();\n  }, { retries: 2, backoffMs: 200 });\n\n  return (\n    \u003Cmain style={{ padding: 24 }}>\n      \u003Ch1>Network jitter demo\u003C/h1>\n      \u003Cpre>{JSON.stringify(result, null, 2)}\u003C/pre>\n    \u003C/main>\n  );\n}\n",[136,572,573,578,583,587,592,597,602,607,612,617,621,626,631,636,640,645,650,655,660,665,670],{"__ignoreMap":134},[139,574,575],{"class":141,"line":142},[139,576,577],{},"// app/page.js\n",[139,579,580],{"class":141,"line":148},[139,581,582],{},"import { fetchWithTimeout, retry } from \"@/lib/network\";\n",[139,584,585],{"class":141,"line":154},[139,586,188],{"emptyLinePlaceholder":187},[139,588,589],{"class":141,"line":160},[139,590,591],{},"export default async function Page() {\n",[139,593,594],{"class":141,"line":166},[139,595,596],{},"  const result = await retry(async () => {\n",[139,598,599],{"class":141,"line":172},[139,600,601],{},"    const res = await fetchWithTimeout(`${process.env.NEXT_PUBLIC_BASE_URL}/api/jitter`, {\n",[139,603,604],{"class":141,"line":178},[139,605,606],{},"      timeoutMs: 900,\n",[139,608,609],{"class":141,"line":184},[139,610,611],{},"      cache: \"no-store\",\n",[139,613,614],{"class":141,"line":191},[139,615,616],{},"    });\n",[139,618,619],{"class":141,"line":197},[139,620,188],{"emptyLinePlaceholder":187},[139,622,623],{"class":141,"line":203},[139,624,625],{},"    if (!res.ok) throw new Error(`upstream failed: ${res.status}`);\n",[139,627,628],{"class":141,"line":209},[139,629,630],{},"    return res.json();\n",[139,632,633],{"class":141,"line":215},[139,634,635],{},"  }, { retries: 2, backoffMs: 200 });\n",[139,637,638],{"class":141,"line":221},[139,639,188],{"emptyLinePlaceholder":187},[139,641,642],{"class":141,"line":227},[139,643,644],{},"  return (\n",[139,646,647],{"class":141,"line":233},[139,648,649],{},"    \u003Cmain style={{ padding: 24 }}>\n",[139,651,652],{"class":141,"line":399},[139,653,654],{},"      \u003Ch1>Network jitter demo\u003C/h1>\n",[139,656,657],{"class":141,"line":405},[139,658,659],{},"      \u003Cpre>{JSON.stringify(result, null, 2)}\u003C/pre>\n",[139,661,662],{"class":141,"line":510},[139,663,664],{},"    \u003C/main>\n",[139,666,667],{"class":141,"line":516},[139,668,669],{},"  );\n",[139,671,672],{"class":141,"line":522},[139,673,408],{},[10,675,676],{},"→ 기대 결과/무엇이 달라졌는지: 지연/실패가 있어도 페이지 렌더링이 “예측 가능한 시간 안”에 성공하거나, 실패를 명확히 드러내도록 만들 수 있습니다.",[117,678,679],{},[10,680,681,682,685],{},"주의: ",[136,683,684],{},"process.env.NEXT_PUBLIC_BASE_URL"," 같은 베이스 URL 구성은 배포 환경에 따라 달라질 수 있습니다. 서버/클라이언트 경계를 넘는 URL 조립은 팀 규칙에 맞게 정리해두는 편이 안전합니다.",[23,687],{},[26,689,691],{"id":690},"검증-방법체크리스트","검증 방법(체크리스트)",[42,693,696,713,723,733,739],{"className":694},[695],"contains-task-list",[45,697,700,704,705,708,709,712],{"className":698},[699],"task-list-item",[701,702],"input",{"disabled":187,"type":703},"checkbox"," 브라우저 DevTools에서 Network 탭을 열고 ",[136,706,707],{},"/api/jitter"," 호출이 ",[37,710,711],{},"가끔 503 또는 지연","되는지 확인한다",[45,714,716,718,719,722],{"className":715},[699],[701,717],{"disabled":187,"type":703}," 타임아웃을 낮춰서(예: 200ms) ",[37,720,721],{},"Abort가 발생","하는지 확인한다",[45,724,726,728,729,732],{"className":725},[699],[701,727],{"disabled":187,"type":703}," 재시도 횟수를 0으로 바꿔서 ",[37,730,731],{},"회복 로직이 사라지는지"," 비교한다",[45,734,736,738],{"className":735},[699],[701,737],{"disabled":187,"type":703}," 멱등성이 없는 요청(예: 결제/주문)에 재시도를 적용하지 않았는지 점검한다",[45,740,742,744],{"className":741},[699],[701,743],{"disabled":187,"type":703}," 서버 로그/모니터링에서 “재시도로 인한 트래픽 증가”를 감당 가능한지 확인한다",[23,746],{},[26,748,750],{"id":749},"흔한-실수faq","흔한 실수/FAQ",[61,752,754],{"id":753},"q1-tcp-연결은-회선-교환인가요","Q1. “TCP 연결”은 회선 교환인가요?",[10,756,757],{},"아니요. TCP는 연결 지향 프로토콜이지만, 패킷 교환망 위에서 “논리적인 연결 상태”를 제공합니다. 물리적으로 전용 경로를 예약하는 의미와는 다릅니다.",[61,759,761],{"id":760},"q2-패킷-교환이면-경로가-매번-바뀌나요","Q2. 패킷 교환이면 경로가 매번 바뀌나요?",[10,763,764],{},"상황에 따라 다릅니다. 라우팅이 재수렴(reconvergence)하거나 정책이 바뀌면 경로가 바뀔 수 있습니다. 중요한 건 “고정 경로를 전제로 하면 깨질 수 있다”는 점입니다.",[61,766,768],{"id":767},"q3-재시도는-왜-위험할-수-있나요","Q3. 재시도는 왜 위험할 수 있나요?",[10,770,771],{},"멱등성이 없는 요청을 재시도하면 “같은 작업이 두 번” 처리될 수 있습니다. 결제/주문/포인트 차감 같은 작업은 멱등 키(요청 식별자)나 서버 측 중복 방지 장치가 필요합니다.",[61,773,775],{"id":774},"q4-헤더-오버헤드는-얼마나-중요한가요","Q4. 헤더 오버헤드는 얼마나 중요한가요?",[10,777,778,779,782],{},"단일 요청에서는 체감이 작을 수 있지만, 작은 메시지를 매우 자주 보내는 시스템이나 대규모 트래픽에서는 누적 비용이 됩니다. 다만 실무에서는 오버헤드 자체보다 ",[37,780,781],{},"혼잡과 재전송/지연","이 더 큰 병목이 되는 경우가 흔합니다.",[23,784],{},[26,786,788],{"id":787},"요약35줄","요약(3~5줄)",[42,790,791,794,797,800],{},[45,792,793],{},"회선 교환은 통신 전에 경로/자원을 예약해 예측 가능한 품질을 얻는 대신 효율이 떨어질 수 있습니다.",[45,795,796],{},"패킷 교환은 자원을 공유해 확장성이 좋지만, 혼잡에 따라 지연/손실/지터가 생길 수 있습니다.",[45,798,799],{},"백엔드/웹에서는 타임아웃, 제한적 재시도, 멱등성 설계가 이 변동성을 다루는 기본 도구입니다.",[45,801,802],{},"“연결”이라는 용어를 물리적 전용 회선으로 오해하지 않는 게 출발점입니다.",[23,804],{},[26,806,807],{"id":807},"결론",[10,809,810],{},"패킷 교환망은 “공유 자원”입니다. 그래서 빠를 때도, 느릴 때도 있습니다.",[10,812,813],{},"안정적인 시스템은 네트워크가 흔들리는 걸 전제로 설계합니다: 타임아웃으로 경계를 긋고, 재시도로 회복을 시도하며, 멱등성으로 중복을 통제합니다.",[10,815,816],{},"이 3가지를 코드에 박아두면, 네트워크 특성을 “운”이 아니라 “설계”로 다루게 됩니다.",[23,818],{},[26,820,822],{"id":821},"참고공식-문서-링크","참고(공식 문서 링크)",[42,824,825,834,841,848,855,862,869],{},[45,826,827],{},[828,829,833],"a",{"href":830,"rel":831},"https://nextjs.org/docs/app/building-your-application/routing/route-handlers",[832],"nofollow","Next.js Route Handlers",[45,835,836],{},[828,837,840],{"href":838,"rel":839},"https://developer.mozilla.org/docs/Web/API/fetch",[832],"MDN: fetch()",[45,842,843],{},[828,844,847],{"href":845,"rel":846},"https://developer.mozilla.org/docs/Web/API/AbortController",[832],"MDN: AbortController",[45,849,850],{},[828,851,854],{"href":852,"rel":853},"https://www.rfc-editor.org/rfc/rfc791",[832],"RFC Editor: RFC 791 (Internet Protocol)",[45,856,857],{},[828,858,861],{"href":859,"rel":860},"https://www.rfc-editor.org/rfc/rfc9293",[832],"RFC Editor: RFC 9293 (Transmission Control Protocol)",[45,863,864],{},[828,865,868],{"href":866,"rel":867},"https://en.wikipedia.org/wiki/Circuit_switching",[832],"Wikipedia: Circuit switching",[45,870,871],{},[828,872,875],{"href":873,"rel":874},"https://en.wikipedia.org/wiki/Packet_switching",[832],"Wikipedia: Packet switching",[877,878,879],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":134,"searchDepth":148,"depth":148,"links":881},[882,883,888,889,894,895,901,902,903],{"id":28,"depth":148,"text":29},{"id":58,"depth":148,"text":59,"children":884},[885,886,887],{"id":63,"depth":154,"text":64},{"id":90,"depth":154,"text":91},{"id":126,"depth":154,"text":127},{"id":243,"depth":148,"text":244},{"id":301,"depth":148,"text":302,"children":890},[891,892,893],{"id":312,"depth":154,"text":313},{"id":416,"depth":154,"text":417},{"id":566,"depth":154,"text":567},{"id":690,"depth":148,"text":691},{"id":749,"depth":148,"text":750,"children":896},[897,898,899,900],{"id":753,"depth":154,"text":754},{"id":760,"depth":154,"text":761},{"id":767,"depth":154,"text":768},{"id":774,"depth":154,"text":775},{"id":787,"depth":148,"text":788},{"id":807,"depth":148,"text":807},{"id":821,"depth":148,"text":822},"2026-02-10","회선 교환은 통신 전에 전용 경로(회선)를 \"예약\"하고, 패킷 교환은 데이터를 쪼개 네트워크 자원을 \"공유\"하며 보냅니다. 백엔드/웹에서는 타임아웃, 제한적 재시도, 멱등성 설계가 이 변동성을 다루는 기본 도구입니다.","md",{},"303c01ed-7f98-80a7-affb-ea002a97ab9b","/writing/circuit-switching-vs-packet-switching",{"title":5,"description":905},"notion","writing/circuit-switching-vs-packet-switching",[914],"네트워크","M3f_-O_h0vrVd6uSnDPjXt5pR-n4PV-g0D0eTGrva5w",1772810799901]