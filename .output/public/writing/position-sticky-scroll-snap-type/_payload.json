[{"data":1,"prerenderedAt":1702},["ShallowReactive",2],{"writing:meta:/writing/position-sticky-scroll-snap-type":3},{"id":4,"title":5,"body":6,"date":1690,"description":1691,"extension":1692,"meta":1693,"navigation":188,"notionPageId":1694,"path":1695,"seo":1696,"source":1697,"stem":1698,"tags":1699,"__hash__":1701},"content/writing/position-sticky-scroll-snap-type.md","sticky + scroll-snap으로 섹션 고정하기",{"type":7,"value":8,"toc":1664},"minimark",[9,14,31,34,37,40,54,57,62,65,76,81,87,89,93,98,107,118,122,134,145,148,226,229,231,235,239,256,269,273,285,308,317,335,337,341,349,353,838,841,1370,1382,1384,1388,1455,1457,1461,1468,1477,1484,1488,1502,1511,1518,1524,1534,1538,1545,1553,1555,1559,1596,1598,1601,1610,1613,1615,1619,1660],[10,11,13],"h1",{"id":12},"스크롤을-멈추면-정렬하라-sticky-scroll-snap으로-섹션-고정하기","스크롤을 멈추면 정렬하라: sticky + scroll-snap으로 섹션 고정하기",[15,16,17,21,22,26,27,30],"p",{},[18,19,20],"strong",{},"한 문장 결론:"," ",[23,24,25],"code",{},"position: sticky","로 “붙는 제목”을 만들고, ",[23,28,29],{},"scroll-snap-*","으로 “멈추는 위치”를 고정하면 스크롤 UI가 훨씬 예측 가능해진다.",[15,32,33],{},"스크롤 기반 UI는 사용자가 멈추는 지점이 애매하면 레이아웃이 흐트러진다.",[15,35,36],{},"특히 섹션이 길고 제목이 반복되는 화면에서는 “지금 어디를 보고 있는지”가 금방 흐려진다.",[15,38,39],{},"여기서 중요한 건 두 가지다.",[41,42,43,49],"ul",{},[44,45,46],"li",{},[18,47,48],{},"제목은 스크롤 중에도 상단에 남게(sticky)",[44,50,51],{},[18,52,53],{},"스크롤이 멈추면 섹션 시작점에 딱 맞게(snap)",[55,56],"hr",{},[58,59,61],"h2",{"id":60},"배경문제","배경/문제",[15,63,64],{},"아래 같은 화면을 만들고 싶을 때가 많다.",[41,66,67,70,73],{},[44,68,69],{},"섹션을 스크롤로 넘기되, 각 섹션의 제목이 상단에 붙어 따라온다.",[44,71,72],{},"스크롤을 멈추면 애매한 위치가 아니라 “다음 섹션 시작점”으로 정렬된다.",[44,74,75],{},"추가 JS 없이 CSS만으로 구현하고 싶다.",[15,77,78,80],{},[23,79,25],{},"만 쓰면 “붙는 제목”은 만들 수 있지만, 스크롤 정지 지점이 들쑥날쑥해 UX가 흔들릴 수 있다.",[15,82,83,84,86],{},"이때 ",[23,85,29],{},"이 같이 들어오면 “멈추는 위치”까지 제어할 수 있다.",[55,88],{},[58,90,92],{"id":91},"핵심-개념","핵심 개념",[94,95,97],"h3",{"id":96},"sticky는-스크롤-컨테이너-기준으로-붙는다","sticky는 “스크롤 컨테이너” 기준으로 붙는다",[15,99,100,102,103,106],{},[23,101,25],{},"는 요소가 스크롤되다가 특정 지점(",[23,104,105],{},"top"," 등)에 도달하면 그 위치에 “붙는” 동작을 한다.",[15,108,109,110,117],{},"실무에서는 “어느 스크롤을 기준으로 붙는지”가 제일 중요하다. 규칙은 ",[111,112,116],"a",{"href":113,"rel":114},"https://developer.mozilla.org/en-US/docs/Web/CSS/position",[115],"nofollow","MDN: position","을 기준으로 잡아두면 안전하다.",[94,119,121],{"id":120},"scroll-snap은-멈추는-지점을-정렬한다","scroll-snap은 “멈추는 지점”을 정렬한다",[15,123,124,127,128,133],{},[23,125,126],{},"scroll-snap-type","은 스크롤 컨테이너에 적용해 스냅 동작을 켠다. (",[111,129,132],{"href":130,"rel":131},"https://developer.mozilla.org/en-US/docs/Web/CSS/scroll-snap-type",[115],"MDN: scroll-snap-type",")",[15,135,136,139,140,133],{},[23,137,138],{},"scroll-snap-align","은 각 섹션(스냅 대상)이 어디에 맞춰질지 정한다. (",[111,141,144],{"href":142,"rel":143},"https://developer.mozilla.org/en-US/docs/Web/CSS/scroll-snap-align",[115],"MDN: scroll-snap-align",[15,146,147],{},"아래 다이어그램처럼, sticky는 “스크롤 중 제목 고정”, snap은 “정지 후 위치 보정” 역할로 분리하면 설계가 단순해진다.",[149,150,155],"pre",{"className":151,"code":152,"language":153,"meta":154,"style":154},"language-mermaid shiki shiki-themes github-dark","sequenceDiagram\n  participant U as User\n  participant S as Scroll container\n  participant B as Browser layout\n\n  U->>S: wheel/touch/keyboard scroll\n  S->>B: scrollTop changes\n  B-->>S: sticky header sticks (top: 0)\n  U-->>S: stop input\n  S->>B: evaluate snap points\n  B-->>S: adjust to nearest snap position\n","mermaid","",[23,156,157,165,171,177,183,190,196,202,208,214,220],{"__ignoreMap":154},[158,159,162],"span",{"class":160,"line":161},"line",1,[158,163,164],{},"sequenceDiagram\n",[158,166,168],{"class":160,"line":167},2,[158,169,170],{},"  participant U as User\n",[158,172,174],{"class":160,"line":173},3,[158,175,176],{},"  participant S as Scroll container\n",[158,178,180],{"class":160,"line":179},4,[158,181,182],{},"  participant B as Browser layout\n",[158,184,186],{"class":160,"line":185},5,[158,187,189],{"emptyLinePlaceholder":188},true,"\n",[158,191,193],{"class":160,"line":192},6,[158,194,195],{},"  U->>S: wheel/touch/keyboard scroll\n",[158,197,199],{"class":160,"line":198},7,[158,200,201],{},"  S->>B: scrollTop changes\n",[158,203,205],{"class":160,"line":204},8,[158,206,207],{},"  B-->>S: sticky header sticks (top: 0)\n",[158,209,211],{"class":160,"line":210},9,[158,212,213],{},"  U-->>S: stop input\n",[158,215,217],{"class":160,"line":216},10,[158,218,219],{},"  S->>B: evaluate snap points\n",[158,221,223],{"class":160,"line":222},11,[158,224,225],{},"  B-->>S: adjust to nearest snap position\n",[15,227,228],{},"→ 기대 결과/무엇이 달라졌는지: 스크롤 “진행 중”과 “정지 후” 동작이 분리돼, 어떤 속성이 어떤 역할인지 한 번에 정리된다.",[55,230],{},[58,232,234],{"id":233},"해결-접근","해결 접근",[94,236,238],{"id":237},"조합의-핵심은-3줄이다","조합의 핵심은 3줄이다",[41,240,241,246,251],{},[44,242,243,244],{},"컨테이너: ",[23,245,126],{},[44,247,248,249],{},"섹션: ",[23,250,138],{},[44,252,253,254],{},"제목: ",[23,255,25],{},[15,257,258,259,262,263,262,266,268],{},"원문에서 언급한 ",[23,260,261],{},"scroll-snap-type: y mandatory",", ",[23,264,265],{},"scroll-snap-align: start",[23,267,25],{},"가 바로 이 조합이다.",[94,270,272],{"id":271},"대안비교최소-2개","대안/비교(최소 2개)",[274,275,276],"ol",{},[44,277,278,281,282],{},[23,279,280],{},"scroll-snap-type: mandatory"," vs ",[23,283,284],{},"proximity",[41,286,287,293],{},[44,288,289,292],{},[23,290,291],{},"mandatory",": 멈출 때 항상 스냅 지점으로 정렬된다. “섹션 페이지” 느낌이 강하다.",[44,294,295,297,298,301,302,307],{},[23,296,284],{},": 스냅 지점 근처일 때만 정렬된다. 트랙패드/휠에서 덜 강압적이다.\n공식 개념은 ",[111,299,132],{"href":130,"rel":300},[115],"과 ",[111,303,306],{"href":304,"rel":305},"https://www.w3.org/TR/css-scroll-snap-1/",[115],"W3C: CSS Scroll Snap","을 참고하면 된다.",[274,309,310],{},[44,311,312,281,314],{},[23,313,25],{},[23,315,316],{},"position: fixed",[41,318,319,325],{},[44,320,321,324],{},[23,322,323],{},"sticky",": 섹션 흐름 안에서 자연스럽게 “붙었다가 밀려난다”.",[44,326,327,330,331,334],{},[23,328,329],{},"fixed",": 뷰포트에 고정되므로 항상 떠 있지만, 내용 가림/오프셋 보정이 필수다.\n기준은 ",[111,332,116],{"href":113,"rel":333},[115],".",[55,336],{},[58,338,340],{"id":339},"구현코드","구현(코드)",[15,342,343,344,133],{},"아래 예시는 Next.js에서