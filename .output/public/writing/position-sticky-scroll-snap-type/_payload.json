9,1441],{"className":1438},[1395],[1397,1440],{"disabled":188,"type":1399}," 휠/트랙패드/터치/키보드(PageDown/Space)로 스크롤했을 때도 의도대로 스냅되는가?",[44,1443,1445,1447,1448,1451,1452,133],{"className":1444},[1395],[1397,1446],{"disabled":188,"type":1399}," 스냅이 너무 강압적이라면 ",[23,1449,1450],{},"mandatory → proximity","로 바꿨을 때 UX가 개선되는가? (",[111,1453,132],{"href":130,"rel":1454},[115],[55,1456],{},[58,1458,1460],{"id":1459},"흔한-실수faq","흔한 실수/FAQ",[94,1462,1464,1465,1467],{"id":1463},"q1-position-sticky가-전혀-안-붙는다","Q1. ",[23,1466,25],{},"가 전혀 안 붙는다",[15,1469,1470,1471,1473,1474,1476],{},"A. ",[23,1472,323],{},"는 스크롤 컨테이너/레이아웃 조건에 영향을 받는다. 특히 ",[23,1475,105],{},"이 없으면 붙는 지점이 정의되지 않는다.",[15,1478,1479,1480,1483],{},"규칙 점검은 ",[111,1481,116],{"href":113,"rel":1482},[115]," 기준으로 하면 된다.",[94,1485,1487],{"id":1486},"q2-스냅이-안-된다","Q2. 스냅이 안 된다",[15,1489,1470,1490,1492,1493,262,1496,1492,1498,1501],{},[23,1491,126],{},"은 ",[18,1494,1495],{},"컨테이너",[23,1497,138],{},[18,1499,1500],{},"자식(스냅 대상)"," 에 있어야 한다.",[15,1503,1504,1505,1510],{},"개념 정리는 ",[111,1506,1509],{"href":1507,"rel":1508},"https://developer.mozilla.org/en-US/docs/Web/CSS/Guides/Scroll_snap",[115],"MDN: Scroll snap guide","가 가장 빠르다.",[94,1512,1514,1515,1517],{"id":1513},"q3-mandatory가-너무-잡아당기는-느낌이다","Q3. ",[23,1516,291],{},"가 너무 “잡아당기는 느낌”이다",[15,1519,1520,1521,1523],{},"A. 트랙패드/휠 환경에서는 ",[23,1522,284],{},"가 더 자연스러운 경우가 있다.",[15,1525,1526,1527,301,1530,1533],{},"강도 조절은 ",[111,1528,132],{"href":130,"rel":1529},[115],[111,1531,306],{"href":304,"rel":1532},[115],"을 참고해 선택한다.",[94,1535,1537],{"id":1536},"q4-중첩-스크롤에서-바깥-페이지까지-같이-스크롤된다","Q4. 중첩 스크롤에서 바깥 페이지까지 같이 스크롤된다",[15,1539,1540,1541,1544],{},"A. 스크롤 체이닝(scroll chaining)이 거슬리면 컨테이너에 ",[23,1542,1543],{},"overscroll-behavior","를 검토할 수 있다.",[15,1546,1547,1548,334],{},"설명은 ",[111,1549,1552],{"href":1550,"rel":1551},"https://developer.mozilla.org/en-US/docs/Web/CSS/overscroll-behavior",[115],"MDN: overscroll-behavior",[55,1554],{},[58,1556,1558],{"id":1557},"요약35줄","요약(3~5줄)",[41,1560,1561,1569,1581,1590],{},[44,1562,1563,1565,1566,1568],{},[23,1564,323],{},"는 “스크롤 중 제목 고정”, ",[23,1567,1409],{},"은 “정지 후 위치 정렬”을 담당한다.",[44,1570,1571,1572,1574,1575,1577,1578,1580],{},"컨테이너에 ",[23,1573,126],{},", 섹션에 ",[23,1576,138],{},", 제목에 ",[23,1579,25],{},"를 배치하면 조합이 깔끔해진다.",[44,1582,1583,1584,1586,1587,1589],{},"스냅 강도는 ",[23,1585,291],{},"와 ",[23,1588,284],{},"로 조절한다.",[44,1591,1592,1593,1595],{},"중첩 스크롤에서는 ",[23,1594,1543],{}," 같은 옵션이 도움이 될 수 있다.",[55,1597],{},[58,1599,1600],{"id":1600},"결론",[15,1602,1603,1604,1606,1607,1609],{},"스크롤 UI를 “페이지처럼” 만들고 싶다면, 먼저 제목을 ",[23,1605,323],{},"로 고정하고 정지 지점을 ",[23,1608,1409],{},"으로 고정하자.",[15,1611,1612],{},"이 조합은 JS 없이도 충분히 강력하고, 설계 포인트가 명확해 유지보수 비용이 낮다.",[55,1614],{},[58,1616,1618],{"id":1617},"참고공식-문서-링크","참고(공식 문서 링크)",[41,1620,1621,1626,1631,1636,1641,1647,1654],{},[44,1622,1623],{},[111,1624,348],{"href":346,"rel":1625},[115],[44,1627,1628],{},[111,1629,116],{"href":113,"rel":1630},[115],[44,1632,1633],{},[111,1634,132],{"href":130,"rel":1635},[115],[44,1637,1638],{},[111,1639,144],{"href":142,"rel":1640},[115],[44,1642,1643],{},[111,1644,1646],{"href":1507,"rel":1645},[115],"MDN: CSS Scroll Snap guide",[44,1648,1649],{},[111,1650,1653],{"href":1651,"rel":1652},"https://web.dev/articles/css-scroll-snap",[115],"web.dev: CSS Scroll Snap",[44,1655,1656],{},[111,1657,1659],{"href":304,"rel":1658},[115],"W3C: CSS Scroll Snap Module",[1661,1662,1663],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sAwPA, html code.shiki .sAwPA{--shiki-default:#6A737D}html pre.shiki code .snl16, html code.shiki .