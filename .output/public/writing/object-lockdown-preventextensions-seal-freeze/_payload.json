[{"data":1,"prerenderedAt":1339},["ShallowReactive",2],{"writing:meta:/writing/object-lockdown-preventextensions-seal-freeze":3},{"id":4,"title":5,"body":6,"date":1327,"description":1328,"extension":1329,"meta":1330,"navigation":134,"notionPageId":1331,"path":1332,"seo":1333,"source":1334,"stem":1335,"tags":1336,"__hash__":1338},"content/writing/object-lockdown-preventextensions-seal-freeze.md","상태를 고정하라: 변경을 차단하는 법",{"type":7,"value":8,"toc":1299},"minimark",[9,26,42,47,50,53,79,86,89,93,100,166,173,186,214,221,223,227,252,255,260,262,266,273,280,474,488,490,497,683,695,697,704,915,927,929,933,1037,1044,1046,1050,1109,1111,1115,1122,1135,1145,1149,1160,1163,1170,1180,1192,1194,1198,1231,1233,1236,1243,1254,1256,1260,1295],[10,11,13,14,18,19,18,22,25],"h1",{"id":12},"상태를-고정하라-objectpreventextensions-objectseal-objectfreeze로-변경을-차단하는-법","상태를 고정하라: ",[15,16,17],"code",{},"Object.preventExtensions"," · ",[15,20,21],{},"Object.seal",[15,23,24],{},"Object.freeze","로 변경을 차단하는 법",[27,28,29,30,34,35,38,39],"p",{},"한 문장 결론: ",[31,32,33],"strong",{},"“추가/삭제/수정” 중 무엇을 막을지 먼저 정하고, 그에 맞는"," **",[15,36,37],{},"preventExtensions → seal → freeze","**",[31,40,41],{},"를 선택하면 된다.",[43,44,46],"h2",{"id":45},"배경문제","배경/문제",[27,48,49],{},"자바스크립트에서 배열(Array)도 결국 객체(Object)다. 그래서 “배열에 값을 더 못 넣게 하거나”, “길이를 줄이지 못하게 하거나”, “아예 내부 값을 바꾸지 못하게” 만들고 싶을 때가 있다.",[27,51,52],{},"이런 제어는 특히 다음 상황에서 의미가 크다.",[54,55,56,67,73],"ul",{},[57,58,59,62,63,66],"li",{},[31,60,61],{},"유지보수",": 의도치 않은 ",[15,64,65],{},"push/pop"," 같은 변경이 들어오면 버그가 늦게 터진다.",[57,68,69,72],{},[31,70,71],{},"안정성",": “읽기 전용으로 다루자”는 규칙을 코드 레벨로 강제할 수 있다.",[57,74,75,78],{},[31,76,77],{},"디버깅 효율",": 변경이 일어나는 순간 바로 에러로 잡아내면 원인 추적이 빨라진다.",[27,80,81,82,85],{},"포인트는 하나다. ",[31,83,84],{},"어떤 종류의 변경을 막을지(추가/삭제/수정)를 선택","하는 것.",[87,88],"hr",{},[43,90,92],{"id":91},"핵심-개념","핵심 개념",[27,94,95,96,99],{},"세 API는 모두 ",[31,97,98],{},"해당 객체의 “속성(프로퍼티) 상태”를 바꿔서"," 변경을 제한한다. 아래 다이어그램처럼 “막는 범위”가 점점 넓어진다.",[101,102,107],"pre",{"className":103,"code":104,"language":105,"meta":106,"style":106},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  A[\"preventExtensions\u003Cbr/>새 속성 추가 금지\"] -->|\"더 강하게\"| B[\"seal\u003Cbr/>추가 + 삭제 금지\"]\n  B -->|\"더 강하게\"| C[\"freeze\u003Cbr/>추가 + 삭제 + 값 변경 금지\"]\n\n  subgraph ARRAY[\"배열에서 자주 보는 행동\"]\n    P[\"push\u003Cbr/>새 인덱스 추가\"] -->|\"추가\"| A\n    O[\"pop\u003Cbr/>마지막 요소 삭제\"] -->|\"삭제\"| B\n    S[\"arr[i] = ...\u003Cbr/>기존 값 변경\"] -->|\"변경\"| C\n  end\n","mermaid","",[15,108,109,117,123,129,136,142,148,154,160],{"__ignoreMap":106},[110,111,114],"span",{"class":112,"line":113},"line",1,[110,115,116],{},"flowchart LR\n",[110,118,120],{"class":112,"line":119},2,[110,121,122],{},"  A[\"preventExtensions\u003Cbr/>새 속성 추가 금지\"] -->|\"더 강하게\"| B[\"seal\u003Cbr/>추가 + 삭제 금지\"]\n",[110,124,126],{"class":112,"line":125},3,[110,127,128],{},"  B -->|\"더 강하게\"| C[\"freeze\u003Cbr/>추가 + 삭제 + 값 변경 금지\"]\n",[110,130,132],{"class":112,"line":131},4,[110,133,135],{"emptyLinePlaceholder":134},true,"\n",[110,137,139],{"class":112,"line":138},5,[110,140,141],{},"  subgraph ARRAY[\"배열에서 자주 보는 행동\"]\n",[110,143,145],{"class":112,"line":144},6,[110,146,147],{},"    P[\"push\u003Cbr/>새 인덱스 추가\"] -->|\"추가\"| A\n",[110,149,151],{"class":112,"line":150},7,[110,152,153],{},"    O[\"pop\u003Cbr/>마지막 요소 삭제\"] -->|\"삭제\"| B\n",[110,155,157],{"class":112,"line":156},8,[110,158,159],{},"    S[\"arr[i] = ...\u003Cbr/>기존 값 변경\"] -->|\"변경\"| C\n",[110,161,163],{"class":112,"line":162},9,[110,164,165],{},"  end\n",[27,167,168,169,172],{},"→ 기대 결과/무엇이 달라졌는지: ",[31,170,171],{},"어떤 메서드가 “추가/삭제/변경”에 해당하는지","가 먼저 고정되고, 그에 따라 어떤 API를 선택해야 하는지 빠르게 정리된다.",[174,175,177,178,181,182,185],"h3",{"id":176},"배열에서-왜-pop은-되고-push는-막힐까","배열에서 왜 ",[15,179,180],{},"pop","은 되고 ",[15,183,184],{},"push","는 막힐까?",[54,187,188,197,205],{},[57,189,190,192,193,196],{},[15,191,184],{},": ",[31,194,195],{},"새 인덱스(새 속성)를 추가","한다 → “확장”에 해당",[57,198,199,192,201,204],{},[15,200,180],{},[31,202,203],{},"기존 마지막 인덱스를 삭제","한다 → “축소(삭제)”에 해당",[57,206,207,192,210,213],{},[15,208,209],{},"arr[0] = 5",[31,211,212],{},"이미 존재하는 인덱스 값을 변경","한다 → “변경”에 해당",[27,215,216,217,220],{},"즉, ",[31,218,219],{},"막는 규칙이 “추가/삭제/변경” 중 어디에 걸리는지","로 결과가 갈린다.",[87,222],{},[43,224,226],{"id":225},"해결-접근","해결 접근",[228,229,230,238,245],"ol",{},[57,231,232,235,236],{},[31,233,234],{},"추가만 막고 싶다"," → ",[15,237,17],{},[57,239,240,235,243],{},[31,241,242],{},"추가와 삭제를 막고 싶다",[15,244,21],{},[57,246,247,235,250],{},[31,248,249],{},"추가/삭제/수정까지 모두 막고 싶다",[15,251,24],{},[27,253,254],{},"그리고 중요한 한 가지:",[54,256,257],{},[57,258,259],{},"실패가 “조용히 무시”되면 디버깅이 어렵다.\n가능하면 **실패를 에러로 드러내는 실행 환경(모듈/엄격 모드)**에서 확인하는 습관이 안전하다. (관련 동작은 실행 환경에 따라 달라질 수 있다.)",[87,261],{},[43,263,265],{"id":264},"구현코드","구현(코드)",[27,267,268,269,272],{},"아래 예시는 ",[31,270,271],{},"Next.js에서 그대로 실행해도 되는 형태","로 정리했다. 콘솔 결과로 확인하면 된다.",[174,274,276,277,279],{"id":275},"_1-objectpreventextensions-확장추가만-막기","1) ",[15,278,17],{},": 확장(추가)만 막기",[101,281,285],{"className":282,"code":283,"language":284,"meta":106,"style":106},"language-javascript shiki shiki-themes github-dark","'use strict';\n\nconst arr = [1, 2, 3];\n\nObject.preventExtensions(arr);\n\narr[0] = 5;     // 기존 값 변경: 가능\narr.pop();      // 기존 요소 삭제: 가능\n\ntry {\n  arr.push(3);  // 새 요소 추가: 불가\n} catch (err) {\n  console.error('push failed:', err);\n}\n\nconsole.log(arr);\n","javascript",[15,286,287,297,301,334,338,350,354,378,391,395,404,423,435,452,458,463],{"__ignoreMap":106},[110,288,289,293],{"class":112,"line":113},[110,290,292],{"class":291},"sU2Wk","'use strict'",[110,294,296],{"class":295},"s95oV",";\n",[110,298,299],{"class":112,"line":119},[110,300,135],{"emptyLinePlaceholder":134},[110,302,303,307,311,314,317,320,323,326,328,331],{"class":112,"line":125},[110,304,306],{"class":305},"snl16","const",[110,308,310],{"class":309},"sDLfK"," arr",[110,312,313],{"class":305}," =",[110,315,316],{"class":295}," [",[110,318,319],{"class":309},"1",[110,321,322],{"class":295},", ",[110,324,325],{"class":309},"2",[110,327,322]