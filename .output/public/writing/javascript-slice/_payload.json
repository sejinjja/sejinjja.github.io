0,2198],{"disabled":331,"type":2160}," TypedArray에서 \"복사\"가 필요하면 ",[15,2201,17],{},", \"view\"가 필요하면 ",[15,2204,220],{},"를 선택했다.",[59,2207,2209,2211,2212,217,2214,2163,2216,2219,2220,2222],{"className":2208},[2157],[1840,2210],{"disabled":331,"type":2160}," Buffer에서 ",[15,2213,17],{},[15,2215,220],{},[27,2217,2218],{},"view","일 수 있음을 고려했고, 필요 시 ",[15,2221,224],{},"로 복사했다.",[59,2224,2226,2228],{"className":2225},[2157],[1840,2227],{"disabled":331,"type":2160}," Next.js에서 Buffer는 서버 런타임에서 다뤄야 함을 인지했고(환경에 따라 달라질 수 있음), 클라이언트에서는 문자열/배열/TypedArray 위주로 구성했다.",[45,2230],{},[48,2232,2234],{"id":2233},"흔한-실수faq","흔한 실수/FAQ",[82,2236,2238,2239,2241,2242,2244],{"id":2237},"q1-slice의-end는-왜-포함되지-않나요","Q1. ",[15,2240,17],{},"의 ",[15,2243,174],{},"는 왜 포함되지 않나요?",[20,2246,2247,2248,2251],{},"A. 구간 연산을 조합하기 쉽게 만들기 위해서다. ",[15,2249,2250],{},"len = end - start","가 직관적으로 맞아떨어지고, 연속 구간을 붙일 때 경계가 덜 헷갈린다.",[20,2253,267,2254],{},[269,2255,274],{"href":271,"rel":2256},[273],[82,2258,2260,2261,2264],{"id":2259},"q2-slice로-깊은-복사가-되나요","Q2. ",[15,2262,2263],{},"slice()","로 \"깊은 복사\"가 되나요?",[20,2266,2267,2268,2271],{},"A. 아니다. 배열은 얕은 복사다. 요소가 객체라면 참조가 공유된다. \"진짜 분리\"가 목적이면 ",[15,2269,2270],{},"structuredClone"," 같은 별도 전략을 써야 한다.",[20,2273,267,2274,305,2277],{},[269,2275,274],{"href":271,"rel":2276},[273],[269,2278,2281],{"href":2279,"rel":2280},"https://developer.mozilla.org/en-US/docs/Web/API/structuredClone",[273],"MDN structuredClone()",[82,2283,2285,2286,2288],{"id":2284},"q3-buffer에서-slice-했는데-원본이-바뀌어요-버그인가요","Q3. Buffer에서 ",[15,2287,17],{}," 했는데 원본이 바뀌어요. 버그인가요?",[20,2290,2291,2292,2294,2295,2297],{},"A. Buffer의 ",[15,2293,17],{},"는 view일 수 있다. 원본과 메모리를 공유하면, view를 수정하는 순간 원본도 바뀔 수 있다. 복사가 필요하면 ",[15,2296,224],{}," 같은 방식으로 새 Buffer를 만든다.",[20,2299,267,2300],{},[269,2301,1102],{"href":1100,"rel":2302},[273],[82,2304,2306,2307,2309],{"id":2305},"q4-typedarray도-slice가-view인가요","Q4. TypedArray도 ",[15,2308,17],{},"가 view인가요?",[20,2311,2312,2313,2315,2316,2318],{},"A. TypedArray의 ",[15,2314,17],{},"는 보통 복사다. view가 목적이면 ",[15,2317,220],{},"가 더 직접적이다.",[20,2320,267,2321,305,2324],{},[269,2322,684],{"href":682,"rel":2323},[273],[269,2325,703],{"href":701,"rel":2326},[273],[45,2328],{},[48,2330,2332],{"id":2331},"요약35줄","요약(3~5줄)",[56,2334,2335,2340,2343,2350],{},[59,2336,2337,2339],{},[15,2338,17],{},"는 기본적으로 \"원본을 유지하고 일부를 잘라 새 값을 만드는\" 패턴이다.",[59,2341,2342],{},"Array는 얕은 복사, String은 새 문자열, TypedArray는 복사, Buffer는 view가 될 수 있다.",[59,2344,2345,198,2347,2349],{},[15,2346,17],{},[15,2348,201],{},"는 \"원본 변경 여부\"에서 갈린다.",[59,2351,2352],{},"대용량/바이너리에서는 \"복사 vs view\" 선택이 성능·메모리에 직결된다.",[45,2354],{},[48,2356,2357],{"id":2357},"결론",[20,2359,2360,2362],{},[15,2361,17],{},"는 가장 자주 쓰이는 \"비파괴 파생\" 도구다.",[20,2364,2365],{},"하지만 타입별로 \"새 값\"의 의미가 다르기 때문에, Array/String/TypedArray/Buffer를 한 번에 같은 방식으로 취급하면 위험해진다.",[20,2367,2368],{},"특히 Buffer와 TypedArray는 \"복사\"와 \"view\"를 분리해서 사고하면, 데이터 오염과 메모리 이슈를 동시에 줄일 수 있다.",[45,2370],{},[48,2372,2374],{"id":2373},"참고공식-문서-링크","참고(공식 문서 링크)",[56,2376,2377,2382,2387,2392,2397,2402,2407,2412],{},[59,2378,2379],{},[269,2380,274],{"href":271,"rel":2381},[273],[59,2383,2384],{},[269,2385,524],{"href":522,"rel":2386},[273],[59,2388,2389],{},[269,2390,684],{"href":682,"rel":2391},[273],[59,2393,2394],{},[269,2395,703],{"href":701,"rel":2396},[273],[59,2398,2399],{},[269,2400,932],{"href":930,"rel":2401},[273],[59,2403,2404],{},[269,2405,1102],{"href":1100,"rel":2406},[273],[59,2408,2409],{},[269,2410,1402],{"href":1400,"rel":2411},[273],[59,2413,2414],{},[269,2415,1616],{"href":1614,"rel":2416},[273],[1874,2418,2419],{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var