8,1110,1112,1114,1117,1120,1122,1125,1128,1131,1133],{"class":221,"line":271},[219,1107,1071],{"class":593},[219,1109,1074],{"class":612},[219,1111,1077],{"class":589},[219,1113,619],{"class":579},[219,1115,1116],{"class":649},"\"/logout\"",[219,1118,1119],{"class":589}," prefetch",[219,1121,619],{"class":579},[219,1123,1124],{"class":593},"{",[219,1126,1127],{"class":612},"false",[219,1129,1130],{"class":593},"}>Logout\u003C/",[219,1132,1074],{"class":612},[219,1134,1066],{"class":593},[219,1136,1137,1140,1142],{"class":221,"line":276},[219,1138,1139],{"class":593},"    \u003C/",[219,1141,1063],{"class":1062},[219,1143,1066],{"class":593},[219,1145,1146],{"class":221,"line":282},[219,1147,1148],{"class":593},"  )\n",[219,1150,1151],{"class":221,"line":288},[219,1152,747],{"class":593},[15,1154,1155],{},"→ 기대 결과/무엇이 달라졌는지: 사용자 의도와 무관한 “미리 로드”가 상태 변경으로 이어지는 가능성을 낮춥니다. (근본적으로는 “상태 변경은 POST/PUT/PATCH/DELETE 뒤로” 숨기는 게 핵심입니다.)",[77,1157],{},[80,1159,1161],{"id":1160},"검증-방법체크리스트","검증 방법(체크리스트)",[50,1163,1166,1182,1195,1206,1214,1228],{"className":1164},[1165],"contains-task-list",[53,1167,1170,21,1174,1177,1178,1181],{"className":1168},[1169],"task-list-item",[1171,1172],"input",{"disabled":249,"type":1173},"checkbox",[23,1175,1176],{},"GET/HEAD"," 호출로 ",[18,1179,1180],{},"비즈니스 상태","(로그인/결제/삭제/구독 등)가 바뀌지 않는다.",[53,1183,1185,21,1187,1190,1191,1194],{"className":1184},[1169],[1171,1186],{"disabled":249,"type":1173},[23,1188,1189],{},"PUT/DELETE","는 ",[18,1192,1193],{},"같은 요청을 반복해도"," 의도된 결과가 동일하다(데이터 최종 상태 기준).",[53,1196,1198,21,1200,1190,1202,1205],{"className":1197},[1169],[1171,1199],{"disabled":249,"type":1173},[23,1201,376],{},[18,1203,1204],{},"중복 호출","이 들어올 수 있음을 가정하고(클라이언트 재전송/사용자 더블클릭 등) 중복 처리 전략이 있다.",[53,1207,1209,21,1211,1213],{"className":1208},[1169],[1171,1210],{"disabled":249,"type":1173},[23,1212,40],{}," 프리패치, 크롤러, 링크 미리보기로 호출되어도 문제가 없는 엔드포인트만 GET으로 공개한다.",[53,1215,1217,1219,1220,1223,1224,1227],{"className":1216},[1169],[1171,1218],{"disabled":249,"type":1173}," “복잡한 조회 조건”이 필요하면 ",[23,1221,1222],{},"GET + query","를 우선 고려하고, 정말 필요할 때만 ",[23,1225,1226],{},"POST /search"," 같은 대안을 쓴다.",[53,1229,1231,1233],{"className":1230},[1169],[1171,1232],{"disabled":249,"type":1173}," 캐시(브라우저/프록시/CDN/프레임워크)의 적용 범위를 문서/설정으로 확인하고 기대치를 조정한다.",[77,1235],{},[80,1237,1239],{"id":1238},"흔한-실수faq","흔한 실수/FAQ",[85,1241,1243],{"id":1242},"q1-get이면-서버에서-아무-변화도-일어나면-안-되나요","Q1. “GET이면 서버에서 아무 변화도 일어나면 안 되나요?”",[15,1245,1246,1247,1250],{},"A. “클라이언트가 상태 변경을 요청/기대하지 않는다”가 핵심입니다. 로깅 같은 부수 효과는 있을 수 있지만, ",[18,1248,1249],{},"비즈니스 상태 변경","은 GET에 두지 않는 쪽이 안전합니다.",[15,1252,151,1253,159,1256],{},[153,1254,158],{"href":155,"rel":1255},[157],[153,1257,164],{"href":162,"rel":1258},[157],[85,1260,1262],{"id":1261},"q2-멱등이면-응답도-항상-같아야-하나요","Q2. “멱등이면 응답도 항상 같아야 하나요?”",[15,1264,1265],{},"A. 아닙니다. “의도된 효과”가 같으면 멱등이고, 응답 상태코드/본문은 달라질 수 있어요.",[15,1267,151,1268],{},[153,1269,182],{"href":180,"rel":1270},[157],[85,1272,1274],{"id":1273},"q3-조회-조건이-길어서-get-body로-보내면-안-되나요","Q3. “조회 조건이 길어서 GET body로 보내면 안 되나요?”",[15,1276,1277,1278,1281,1282,21,1284,1288],{},"A. GET body는 일반적으로 정의된 의미가 없고, 구현체에 따라 거부될 수도 있습니다. 조회라면 먼저 ",[18,1279,1280],{},"query string","을 검토하고, 정말 필요할 때 ",[18,1283,376],{},[18,1285,1286],{},[23,1287,490],{}," 같은 대안을 선택합니다.",[15,1290,151,1291],{},[153,1292,158],{"href":155,"rel":1293},[157],[85,1295,1297],{"id":1296},"q4-patch는-무조건-비멱등인가요","Q4. “PATCH는 무조건 비멱등인가요?”",[15,1299,1300],{},"A. 기본 보장은 없지만, 설계에 따라 멱등에 가깝게 만들 수 있습니다. 예: “+1”은 위험, “최종 값을 3으로 설정”은 상대적으로 안전.",[85,1302,1304],{"id":1303},"q5-delete를-여러-번-보내면-404가-뜨는데-멱등이-아닌-거-아닌가요","Q5. “DELETE를 여러 번 보내면 404가 뜨는데, 멱등이 아닌 거 아닌가요?”",[15,1306,1307,1308,1311,1312,1315],{},"A. 멱등은 ",[18,1309,1310],{},"응답 동일성","이 아니라 ",[18,1313,1314],{},"의도된 효과","(삭제 상태 유지)에 대한 성질입니다.",[85,1317,1319],{"id":1318},"q6-trace는-써도-되나요","Q6. “TRACE는 써도 되나요?”",[15,1321,1322],{},"A. 진단 목적 메서드지만, 보안 정책에 따라 서버에서 비활성화되는 경우가 있습니다. 사용 여부는 운영 정책에 맞춰 결정하는 편이 안전합니다.",[15,1324,151,1325],{},[153,1326,1329],{"href":1327,"rel":1328},"https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Methods/TRACE",[157],"MDN: TRACE",[77,1331],{},[80,1333,1335],{"id":1334},"요약35줄","요약(3~5줄)",[50,1337,1338,1343,1348,1366],{},[53,1339,1340,1342],{},[23,1341,25],{},"은 자동화가 호출해도 “의도된 상태 변경”이 없다는 약속에 가깝습니다.",[53,1344,1345,1347],{},[23,1346,29],{},"는 재시도/중복 호출 상황에서 시스템을 안정적으로 만듭니다.",[53,1349,1350,1351,1353,1354,1356,1357,1359,1360,1362,1363,1365],{},"조회는 ",[23,1352,335],{},", 최종 상태를 맞추는 갱신은 ",[23,1355,348],{},", 삭제는 ",[23,1358,364],{},", 생성/작업은 ",[23,1361,376],{},", 부분 수정은 ",[23,1364,389],{},"가 기본 축입니다.",[53,1367,1368],{},"Next.js의 프리패치 같은 자동 요청을 고려하면 “GET에 상태 변경 숨기기”는 특히 위험합니다.",[77,1370],{},[80,1372,1373],{"id":1373},"결론",[15,1375,1376,1377,1380],{},"HTTP 메서드는 “취향”이 아니라 ",[18,1378,1379],{},"자동화(재시도·캐시·프리패치)가 안전하게 움직이기 위한 계약","입니다.",[15,1382,1383],{},"조회는 GET로 열고, 상태 변경은 POST/PUT/PATCH/DELETE 뒤로 밀어두고, 갱신/삭제는 멱등하게 설계하세요. 그 순간부터 장애 대응(재시도)도, 성능(캐시)도, UX(프리패치)도 같이 정리됩니다.",[77,1385],{},[80,1387,1389],{"id":1388},"참고공식-문서-링크","참고(공식 문서 링크)",[50,1391,1392,1397,1404,1409,1414,1419,1424,1429,1434,1441],{},[53,1393,1394],{},[153,1395,158],{"href":155,"rel":1396},[157],[53,1398,1399],{},[153,1400,1403],{"href":1401,"rel":1402},"https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Methods",[157],"MDN: HTTP request methods",[53,1405,1406],{},[153,1407,164],{"href":162,"rel":1408},[157],[53,1410,1411],{},[153,1412,182],{"href":180,"rel":1413},[157],[53,1415,1416],{},[153,1417,1007],{"href":1005,"rel":1418},[157],[53,1420,1421],{},[153,1422,1012],{"href":1010,"rel":1423},[157],[53,1425,1426],{},[153,1427,552],{"href":550,"rel":1428},[157],[53,1430,1431],{},[153,1432,557],{"href":555,"rel":1433},[157],[53,1435,1436],{},[153,1437,1440],{"href":1438,"rel":1439},"https://nextjs.org/docs/app/api-reference/functions/fetch",[157],"Next.js fetch",[53,1442,1443],{},[153,1444,1447],{"href":1445,"rel":1446},"https://nextjs.org/docs/app/guides/caching",[157],"Next.js Caching Guide",[1449,1450,1451],"style",{},"html .default .shik