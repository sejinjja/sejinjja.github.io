nce';\n\nasync function saveDraft(text: string) {\n  // 예시: 실제로는 Route Handler나 API 엔드포인트로 전송\n  await fetch('/api/draft', {\n    method: 'POST',\n    headers: { 'content-type': 'application/json' },\n    body: JSON.stringify({ text }),\n  });\n}\n\nexport default function DebouncedEditor() {\n  const [text, setText] = useState('');\n\n  // 핵심: debounce로 만든 함수는 \"렌더마다 새로 만들지\" 않는 게 중요\n  const debouncedSave = useMemo(() => debounce(saveDraft, 600), []);\n\n  // 언마운트 시점에 남은 타이머/예약 실행을 정리\n  useEffect(() => {\n    return () => {\n      debouncedSave.cancel();\n    };\n  }, [debouncedSave]);\n\n  return (\n    \u003Clabel style={{ display: 'block' }}>\n      \u003Cdiv style={{ marginBottom: 8 }}>Draft\u003C/div>\n      \u003Ctextarea\n        value={text}\n        onChange={(e) => {\n          const next = e.target.value;\n          setText(next);\n          debouncedSave(next);\n        }}\n        rows={6}\n        style={{ width: '100%' }}\n      />\n    \u003C/label>\n  );\n}\n","typescript",[15,356,357,367,371,388,402,406,435,441,457,469,486,504,510,516,521,538,571,576,582,614,619,625,638,651,663,669,675,680,689,717,754,762,773,784,798,807,815,821,837,858,864,875,881],{"__ignoreMap":101},[105,358,359,363],{"class":107,"line":108},[105,360,362],{"class":361},"sU2Wk","'use client'",[105,364,366],{"class":365},"s95oV",";\n",[105,368,369],{"class":107,"line":114},[105,370,136],{"emptyLinePlaceholder":135},[105,372,373,377,380,383,386],{"class":107,"line":120},[105,374,376],{"class":375},"snl16","import",[105,378,379],{"class":365}," { useEffect, useMemo, useState } ",[105,381,382],{"class":375},"from",[105,384,385],{"class":361}," 'react'",[105,387,366],{"class":365},[105,389,390,392,395,397,400],{"class":107,"line":126},[105,391,376],{"class":375},[105,393,394],{"class":365}," debounce ",[105,396,382],{"class":375},[105,398,399],{"class":361}," 'lodash/debounce'",[105,401,366],{"class":365},[105,403,404],{"class":107,"line":132},[105,405,136],{"emptyLinePlaceholder":