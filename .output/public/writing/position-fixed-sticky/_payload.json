[{"data":1,"prerenderedAt":1943},["ShallowReactive",2],{"writing:meta:/writing/position-fixed-sticky":3},{"id":4,"title":5,"body":6,"date":1930,"description":1931,"extension":1932,"meta":1933,"navigation":817,"notionPageId":1934,"path":1935,"seo":1936,"source":1937,"stem":1938,"tags":1939,"__hash__":1942},"content/writing/position-fixed-sticky.md","부모가 기준이 되는 순간을 막아라: position: fixed·sticky의 진짜 기준",{"type":7,"value":8,"toc":1894},"minimark",[9,34,48,57,60,63,66,71,76,105,112,114,118,125,134,146,149,190,200,205,244,283,285,292,300,307,315,340,349,358,360,364,371,419,426,463,475,502,509,517,519,523,530,537,995,998,1003,1026,1028,1032,1046,1053,1274,1284,1296,1303,1610,1620,1622,1626,1695,1697,1701,1708,1725,1732,1754,1761,1773,1775,1779,1802,1804,1807,1816,1824,1826,1830,1890],[10,11,13,17,18,22,27,30,31],"h1",{"id":12},"부모가-기준이-되는-순간을-막아라-position-fixedsticky의-진짜-기준",[14,15,16],"strong",{},"부모가 기준이 되는 순간을 막아라:"," **",[19,20,21],"code",{},"position: fixed",[14,23,24],{},[14,25,26],{},"·",[19,28,29],{},"sticky","**",[14,32,33],{},"의 진짜 기준",[35,36,37,40,41,44,45,47],"p",{},[14,38,39],{},"한 문장 결론:"," ",[19,42,43],{},"fixed","는 “뷰포트 기준”이 깨지는 순간이 있고, ",[19,46,29],{},"는 “스크롤 컨테이너 기준”이 잡히는 순간이 있다. 둘 다 **기준(컨테이닝 블록/스크롤 컨테이너)**부터 확인하면 대부분의 삽질이 사라진다.",[35,49,50,51,53,54,56],{},"UI에서 헤더/툴바/플로팅 버튼은 자주 ",[19,52,43],{},"나 ",[19,55,29],{},"로 구현한다.",[35,58,59],{},"그런데 특정 페이지에서만 “갑자기 부모 기준으로 붙는다”, “스크롤해도 안 따라온다”, “z-index가 먹지 않는다” 같은 문제가 튀어나온다.",[35,61,62],{},"포인트는 단순하다. **“어디를 기준으로 위치를 계산하느냐”**가 바뀌는 순간이 있기 때문이다.",[64,65],"hr",{},[67,68,70],"h2",{"id":69},"배경문제","배경/문제",[72,73,75],"h3",{"id":74},"흔히-만나는-증상","흔히 만나는 증상",[77,78,79,88,96],"ul",{},[80,81,82,84,85],"li",{},[19,83,21],{},"인데 ",[14,86,87],{},"뷰포트가 아니라 부모 박스 기준으로 움직임",[80,89,90,84,93],{},[19,91,92],{},"position: sticky",[14,94,95],{},"스크롤해도 고정되지 않음",[80,97,98,101,102],{},[19,99,100],{},"z-index","를 올려도 ",[14,103,104],{},"레이어가 기대대로 안 올라감",[35,106,107,108,111],{},"이런 증상은 대부분 ",[14,109,110],{},"컨테이닝 블록(containing block: 위치 계산 기준이 되는 박스)"," 또는 **스크롤 컨테이너(scroll container: 스크롤이 실제로 발생하는 박스)**를 잘못 잡아서 생긴다.",[64,113],{},[67,115,117],{"id":116},"핵심-개념","핵심 개념",[72,119,121,122,124],{"id":120},"_1-fixed의-기준-대부분-뷰포트-가끔-조상","1) ",[19,123,43],{},"의 기준: “대부분 뷰포트, 가끔 조상”",[35,126,127,129,130,133],{},[19,128,21],{},"는 기본적으로 **뷰포트(viewport: 브라우저에서 실제로 보이는 화면 영역)**를 기준으로 ",[19,131,132],{},"top/right/bottom/left","를 계산한다.",[35,135,136,137,142,143,145],{},"다만 특정 CSS 속성이 조상(ancestor)에 걸리면, 그 조상이 ",[14,138,139,141],{},[19,140,43],{},"****의 컨테이닝 블록","이 될 수 있다. 이때부터 ",[19,144,43],{},"가 “부모 기준처럼” 보인다.",[35,147,148],{},"아래 다이어그램을 보면, 기준이 어떻게 갈리는지 한 번에 정리된다.",[150,151,156],"pre",{"className":152,"code":153,"language":154,"meta":155,"style":155},"language-mermaid shiki shiki-themes github-dark","flowchart TD\n  A[\"fixed 적용 요소\"] -->|\"기본\"| B[\"기준: 뷰포트\"]\n  A -->|\"조상이 특정 조건 만족\"| C[\"기준: 해당 조상(컨테이닝 블록)\"]\n  C --> D[\"top/right/bottom/left가\u003Cbr/>뷰포트가 아닌 조상 기준\"]\n  C --> E[\"새로운 쌓임 맥락 생성 가능\u003Cbr/>(z-index 체감 변화)\"]\n","mermaid","",[19,157,158,166,172,178,184],{"__ignoreMap":155},[159,160,163],"span",{"class":161,"line":162},"line",1,[159,164,165],{},"flowchart TD\n",[159,167,169],{"class":161,"line":168},2,[159,170,171],{},"  A[\"fixed 적용 요소\"] -->|\"기본\"| B[\"기준: 뷰포트\"]\n",[159,173,175],{"class":161,"line":174},3,[159,176,177],{},"  A -->|\"조상이 특정 조건 만족\"| C[\"기준: 해당 조상(컨테이닝 블록)\"]\n",[159,179,181],{"class":161,"line":180},4,[159,182,183],{},"  C --> D[\"top/right/bottom/left가\u003Cbr/>뷰포트가 아닌 조상 기준\"]\n",[159,185,187],{"class":161,"line":186},5,[159,188,189],{},"  C --> E[\"새로운 쌓임 맥락 생성 가능\u003Cbr/>(z-index 체감 변화)\"]\n",[35,191,192,193,195,196,199],{},"→ 기대 결과/무엇이 달라졌는지: ",[19,194,43],{},"가 “왜 부모 기준처럼 보이는지”를 ",[14,197,198],{},"기준 변경"," 관점에서 바로 진단할 수 있다.",[35,201,202],{},[14,203,204],{},"대표적으로 기준을 바꾸는 조상 조건(환경에 따라 달라질 수 있음):",[77,206,207,221,232,238],{},[80,208,209,212,213,216,217,220],{},[19,210,211],{},"transform"," / ",[19,214,215],{},"perspective","가 ",[19,218,219],{},"none","이 아님",[80,222,223,216,2