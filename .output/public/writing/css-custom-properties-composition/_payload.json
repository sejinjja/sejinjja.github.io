ox"," DevTools에서 ",[26,946,343],{}," 요소의 ",[26,949,950],{},"-text-color","가 초록으로 계산되는가",[44,953,955,957,958,960],{"className":954},[939],[941,956],{"disabled":173,"type":943}," ",[26,959,375],{}," 안의 일반 텍스트는 기본값(빨강)으로 보이는가",[44,962,964,957,966,968,969,859,971,974],{"className":963},[939],[941,965],{"disabled":173,"type":943},[26,967,482],{}," 단독일 때 ",[26,970,28],{},[26,972,973],{},"scale(1) skew(0deg)","로 계산되는가",[44,976,978,957,980,982,983,985,986,988],{"className":977},[939],[941,979],{"disabled":173,"type":943},[26,981,567],{},"만 붙이면 ",[26,984,494],{},"만 바뀌고 ",[26,987,514],{},"는 기본값으로 남는가",[44,990,992,957,994,982,996,985,998,1000],{"className":991},[939],[941,993],{"disabled":173,"type":943},[26,995,594],{},[26,997,514],{},[26,999,494],{},"은 기본값으로 남는가",[44,1002,1004,957,1006,1009,1010,1012],{"className":1003},[939],[941,1005],{"disabled":173,"type":943},[26,1007,1008],{},".big.skew"," 조합에서도 ",[26,1011,28],{},"이 “둘 다 적용”되는가",[54,1014],{},[57,1016,1018],{"id":1017},"흔한-실수와-faq","흔한 실수와 FAQ",[276,1020,1022,1025],{"id":1021},"color-var-text-color-로-걸면-안-되나",[26,1023,1024],{},"{ color: var(--text-color) }","로 걸면 안 되나?",[15,1027,1028],{},"가능은 하지만 영향 범위가 너무 넓어질 수 있다. 링크, 버튼, 폼 요소 등까지 한 번에 바뀌면 스타일 충돌이 나기 쉽다.",[15,1030,1031,957,1034,1039],{},[19,1032,1033],{},"래퍼(예:",[19,1035,1036,1038],{},[26,1037,375],{},"****)에만 적용","해서 범위를 제한하는 편이 안정적이다.",[276,1041,1043,1046],{"id":1042},"var-big-1의-기본값은-언제-쓰이나",[26,1044,1045],{},"var(--big, 1)","의 기본값은 언제 쓰이나?",[15,1048,1049,1050,1053],{},"변수가 ",[19,1051,1052],{},"정의되지 않았을 때"," 기본값이 사용된다.",[15,1055,1056,1057,957,1060,1062],{},"반대로, 변수가 정의되어 있어도 ",[19,1058,1059],{},"값 형태가 속성 문법에 맞지 않으면",[26,1061,28],{}," 자체가 무효가 될 수 있으니 단위/형식을 맞춰야 한다.",[276,1064,1066,1069],{"id":1065},"big-transform-scale15-처럼-쓰면-뭐가-문제지",[26,1067,1068],{},".big { transform: scale(1.5) }","처럼 쓰면 뭐가 문제지?",[15,1071,1072,1074,1075,1078],{},[26,1073,28],{},"은 덮어쓰기 속성이라 ",[26,1076,1077],{},".skew { transform: skew(...) }","와 같이 조합하면 한쪽이 날아갈 수 있다.",[15,1080,1081,1082,1084,1085,1087],{},"커스텀 프로퍼티로 “값만” 바꾸면, ",[26,1083,482],{},"의 ",[26,1086,28],{}," 구조가 유지된다.",[276,1089,1091],{"id":1090},"대안은-뭐가-있나","대안은 뭐가 있나?",[41,1093,1094,1100,1106],{},[44,1095,1096,1099],{},[19,1097,1098],{},"Sass 변수","\n빌드 시점에 값이 확정된다. 런타임에서 테마/상태로 바꾸려면 추가 전략이 필요하다.",[44,1101,1102,1105],{},[19,1103,1104],{},"CSS-in-JS의 theme 토큰","\n컴포넌트 단위로 관리가 쉽지만, 스타일 생성/주입 방식이 프로젝트 정책에 영향을 받을 수 있다.",[44,1107,1108,1111,1112,1114],{},[19,1109,1110],{},"유틸리티 클래스","\n조합 속도가 빠르지만, ",[26,1113,28],{},"처럼 “한 속성 안에서 함수 조립”이 필요한 경우엔 별도 패턴이 필요하다.",[54,1116],{},[57,1118,1119],{"id":1119},"요약",[41,1121,1122,1125,1130,1135],{},[44,1123,1124],{},"커스텀 프로퍼티는 캐스케이드/상속을 따라 “가까운 값”이 우선된다.",[44,1126,1127,1129],{},[26,1128,28],{},"은 “속성 재정의”가 아니라 “값 주입”으로 조합을 만든다.",[44,1131,1132,1134],{},[26,1133,263],{},"로 기본값을 넣어두면 옵션이 없어도 안전하다.",[44,1136,1137],{},"조합이 늘어도 CSS 선언이 폭발하지 않는 구조를 만들 수 있다.",[54,1139],{},[57,1141,1142],{"id":1142},"결론",[15,1144,1145],{},"스타일을 “클래스 = 속성 선언”으로만 생각하면, 조합이 늘어날수록 코드가 무너진다.",[15,1147,1148],{},"반대로 “속성은 고정, 값은 변수로 주입”으로 바꾸면, CSS는 조립 가능한 부품이 된다.",[15,1150,1151,1152,1154],{},"특히 ",[26,1153,28],{}," 같은 조합형 속성에서 이 패턴은 효과가 크다.",[54,1156],{},[57,1158,1159],{"id":1159},"참고",[41,1161,1162,1171,1178,1185,1192,1199],{},[44,1163,1164],{},[1165,1166,1170],"a",{"href":1167,"rel":1168},"https://nextjs.org/docs/app/building-your-application/styling",[1169],"nofollow","Next.js Docs - Styling",[44,1172,1173],{},[1165,1174,1177],{"href":1175,"rel":1176},"https://developer.mozilla.org/en-US/docs/Web/CSS/Using_CSS_custom_properties",[1169],"MDN Web Docs - Using CSS custom properties",[44,1179,1180],{},[1165,1181,1184],{"href":1182,"rel":1183},"https://developer.mozilla.org/en-US/docs/Web/CSS/var",[1169],"MDN Web Docs - var()",[44,1186,1187],{},[1165,1188,1191],{"href":1189,"rel":1190},"https://developer.mozilla.org/en-US/docs/Web/CSS/transform",[1169],"MDN Web Docs - transform",[44,1193,1194],{},[1165,1195,1198],{"href":1196,"rel":1197},"https://web.dev/learn/css/variables/",[1169],"web.dev - CSS v