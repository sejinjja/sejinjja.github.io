[{"data":1,"prerenderedAt":857},["ShallowReactive",2],{"writing:meta:/writing/sql-injection-account-lock":3},{"id":4,"title":5,"body":6,"date":845,"description":17,"extension":846,"meta":847,"navigation":133,"notionPageId":848,"path":849,"seo":850,"source":851,"stem":852,"tags":853,"__hash__":856},"content/writing/sql-injection-account-lock.md","입력값을 쿼리로 만들지 마라: “전 계정 잠금”을 부르는 한 줄",{"type":7,"value":8,"toc":825},"minimark",[9,14,18,26,37,40,45,48,71,74,80,82,86,89,92,153,156,158,162,170,178,185,199,206,218,225,248,250,254,259,316,323,325,329,400,407,409,413,416,419,446,452,455,478,481,483,487,494,633,636,638,642,690,692,696,700,707,710,714,721,730,734,741,748,750,754,772,774,777,784,787,790,792,796,821],[10,11,13],"h1",{"id":12},"입력값을-쿼리로-만들지-마라-로그인-우회와-전-계정-잠금을-부르는-한-줄","입력값을 쿼리로 만들지 마라: 로그인 우회와 “전 계정 잠금”을 부르는 한 줄",[15,16,17],"p",{},"사용자 입력을 SQL 문자열에 붙여 넣는 순간, 로그인 우회는 물론 “전체 사용자 UPDATE” 같은 운영 장애까지 한 번에 터질 수 있다.",[15,19,20,21,25],{},"이 글은 ",[22,23,24],"strong",{},"운영 유지보수 중 실제로 “전 사용자 계정 잠금”이 발생했던 사건","을 바탕으로, 같은 유형의 사고가 다시 나지 않도록 재현과 해결 원칙을 정리한다.",[15,27,28,29,32,33,36],{},"포인트는 단순하다. ",[22,30,31],{},"SQL(코드)과 입력값(데이터)을 분리","하라. 그 시작이 ",[22,34,35],{},"파라미터 바인딩(parameter binding)"," 이다.",[38,39],"hr",{},[41,42,44],"h2",{"id":43},"배경문제","배경/문제",[15,46,47],{},"운영에서 실제로 다음 상황이 발생했다.",[49,50,51,55,61,68],"ul",{},[52,53,54],"li",{},"“로그인 5회 실패 시 계정 잠금” 정책이 켜져 있는 환경에서",[52,56,57,60],{},[22,58,59],{},"모든 계정이 동시에 블록(잠금) 처리","되었다.",[52,62,63,64,67],{},"로그인 실패 카운트가 올라간 시간이 ",[22,65,66],{},"한 타임스탬프에 수렴","했고, 즉시 장애로 이어졌다.",[52,69,70],{},"응급 조치로 운영 데이터에서 실패 카운트를 초기화해 서비스 접근을 복구한 뒤, 원인을 추적했다.",[15,72,73],{},"원인 추적의 핵심 단서는 “실패 카운트를 올리는 쿼리의 영향 범위”였다.",[15,75,76,79],{},[22,77,78],{},"한 번의 요청으로 다수(또는 전체) 사용자의 실패 카운트를 올릴 수 있는 형태","라면, 계정 잠금 정책 자체가 공격 표면이 된다.",[38,81],{},[41,83,85],{"id":84},"핵심-개념","핵심 개념",[15,87,88],{},"SQL Injection은 “입력값이 데이터로만 취급되지 않고, SQL의 구조를 바꾸는 순간” 발생한다.",[15,90,91],{},"즉, 아래 두 흐름은 결과가 완전히 다르다.",[93,94,99],"pre",{"className":95,"code":96,"language":97,"meta":98,"style":98},"language-mermaid shiki shiki-themes github-dark","flowchart LR\n  A[\"사용자 입력\u003Cbr/>userId, userPwd\"] -->|\"문자열 결합\"| B[\"SQL 문자열이 완성됨\u003Cbr/>WHERE가 조작될 수 있음\"]\n  B -->|\"DB가 SQL을 파싱\"| C[\"의도치 않은 조건\u003Cbr/>1=1 등\"]\n  C -->|\"SELECT/UPDATE가 확대\"| D[\"로그인 우회\u003Cbr/>또는 전 유저 실패 카운트 증가\"]\n\n  A -->|\"파라미터 바인딩\"| E[\"SQL 템플릿 유지\u003Cbr/>값은 별도 전달\"]\n  E -->|\"DB가 템플릿을 고정\"| F[\"입력값은 데이터로만 처리\"]\n  F -->|\"영향 범위 고정\"| G[\"조건식 조작 불가\u003Cbr/>대상 사용자만 영향\"]\n","mermaid","",[100,101,102,110,116,122,128,135,141,147],"code",{"__ignoreMap":98},[103,104,107],"span",{"class":105,"line":106},"line",1,[103,108,109],{},"flowchart LR\n",[103,111,113],{"class":105,"line":112},2,[103,114,115],{},"  A[\"사용자 입력\u003Cbr/>userId, userPwd\"] -->|\"문자열 결합\"| B[\"SQL 문자열이 완성됨\u003Cbr/>WHERE가 조작될 수 있음\"]\n",[103,117,119],{"class":105,"line":118},3,[103,120,121],{},"  B -->|\"DB가 SQL을 파싱\"| C[\"의도치 않은 조건\u003Cbr/>1=1 등\"]\n",[103,123,125],{"class":105,"line":124},4,[103,126,127],{},"  C -->|\"SELECT/UPDATE가 확대\"| D[\"로그인 우회\u003Cbr/>또는 전 유저 실패 카운트 증가\"]\n",[103,129,131],{"class":105,"line":130},5,[103,132,134],{"emptyLinePlaceholder":133},true,"\n",[103,136,138],{"class":105,"line":137},6,[103,139,140],{},"  A -->|\"파라미터 바인딩\"| E[\"SQL 템플릿 유지\u003Cbr/>값은 별도 전달\"]\n",[103,142,144],{"class":105,"line":143},7,[103,145,146],{},"  E -->|\"DB가 템플릿을 고정\"| F[\"입력값은 데이터로만 처리\"]\n",[103,148,150],{"class":105,"line":149},8,[103,151,152],{},"  F -->|\"영향 범위 고정\"| G[\"조건식 조작 불가\u003Cbr/>대상 사용자만 영향\"]\n",[15,154,155],{},"→ 기대 결과/무엇이 달라졌는지: 입력값이 SQL 구조를 바꾸는 경로가 차단된다. 같은 입력이라도 “조건식”이 아니라 “문자열 값”으로만 처리된다.",[38,157],{},[41,159,161],{"id":160},"해결-접근","해결 접근",[163,164,165],"ol",{},[52,166,167],{},[22,168,169],{},"문자열 결합으로 쿼리를 만들지 않는다",[49,171,172,175],{},[52,173,174],{},"왜: 입력값이 따옴표/주석/연산자를 포함하면 WHERE 절이 깨질 수 있다.",[52,176,177],{},"기대 결과: 로그인 우회, 전 행 UPDATE 같은 확장이 막힌다.",[163,179,180],{},[52,181,182],{},[22,183,184],{},"파라미터 바인딩을 사용한다",[49,186,187,193,196],{},[52,188,189,190],{},"JDBC라면 ",[100,191,192],{},"PreparedStatement",[52,194,195],{},"Next.js 서버 코드라면 “드라이버의 파라미터 쿼리” 또는 ORM(예: Prisma)의 쿼리 API",[52,197,198],{},"기대 결과: SQL 템플릿과 데이터가 분리되어, DB가 SQL을 안전하게 해석한다.",[163,200,201],{},[52,202,203],{},[22,204,205],{},"실패 카운트 UPDATE까지 같은 기준으로 고정한다",[49,207,208,211],{},[52,209,210],{},"왜: 실제 사건에서도 “로그인 쿼리”보다 “실패 카운트 증가 쿼리”가 더 큰 장애로 이어졌다.",[52,212,213,214,217],{},"기대 결과: 실패 카운트 증가는 ",[22,215,216],{},"단일 사용자","로만 제한된다.",[163,219,220],{},[52,221,222],{},[22,223,224],{},"서버 경계를 고정한다 (Next.js)",[49,226,227],{},[52,228,229,230],{},"인증/DB 접근은 서버에서만 처리하고, 비밀정보는 환경 변수로만 관리한다.\n",[49,231,232,241],{},[52,233,234],{},[235,236,240],"a",{"href":237,"rel":238},"https://nextjs.org/docs/app/building-your-application/routing/route-handlers",[239],"nofollow","Next.js Route Handlers",[52,242,243],{},[235,244,247],{"href":245,"rel":246},"https://nextjs.org/docs/app/building-your-application/configuring/environment-variables",[239],"Next.js Environment Variables",[38,249],{},[41,251,253],{"id":252},"구현코드","구현(코드)",[255,256,258],"h3",{"id":257},"_1-문자열-결합취약-입력값이-where를-바꾼다-jdbc-예시","1) 문자열 결합(취약) — 입력값이 WHERE를 바꾼다 (JDBC 예시)",[93,260,264],{"className":261,"code":262,"language":263,"meta":98,"style":98},"language-java shiki shiki-themes github-dark","String userId = \"' or 1=1 #\";\nString userPwd = \"5678\";\n\nString loginSql =\n  \"SELECT * \" +\n  \"FROM `test-user`.tb_user \" +\n  \"WHERE user_id = '\" + userId + \"' and user_pw = '\" + userPwd + \"'\";\n\nStatement stmt = conn.createStatement();\nResultSet rs = stmt.executeQuery(loginSql);\n","java",[100,265,266,271,276,280,285,290,295,300,304,310],{"__ignoreMap":98},[103,267,268],{"class":105,"line":106},[103,269,270],{},"String userId = \"' or 1=1 #\";\n",[103,272,273],{"class":105,"line":112},[103,274,275],{},"String userPwd = \"5678\";\n",[103,277,278],{"class":105,"line":118},[103,279,134],{"emptyLinePlaceholder":133},[103,281,282],{"class":105,"line":124},[103,283,284],{},"String loginSql =\n",[103,286,287],{"class":105,